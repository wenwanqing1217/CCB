.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #020617 50%, #0f0f23 100%);
  padding: 24rpx;
  padding-bottom: 160rpx;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(236, 72, 153, 0.06) 0%, transparent 40%),
              radial-gradient(circle at 50% 80%, rgba(59, 130, 246, 0.05) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

.header {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.3);
}

.paste-section {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.3s ease;
}

.paste-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

.paste-section:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.2);
}

.paste-input-wrap {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

.paste-input {
  flex: 1;
  min-height: 80rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 20rpx;
  color: #f8fafc;
  font-size: 28rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.paste-input:focus {
  border-color: rgba(139, 92, 246, 0.5);
  box-shadow: 0 0 16rpx rgba(139, 92, 246, 0.2);
}

.paste-btn {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  white-space: nowrap;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.3s ease;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.paste-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.paste-btn:active::before {
  left: 100%;
}

.paste-btn:active {
  transform: scale(0.95);
}

.paste-btn.active {
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.4) 0%, rgba(219, 39, 119, 0.4) 100%);
  color: #f8fafc;
  font-weight: 500;
  border-color: rgba(236, 72, 153, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(236, 72, 153, 0.3);
}

.paste-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  position: relative;
  z-index: 1;
}

.tip-icon {
  font-size: 24rpx;
  color: #a78bfa;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.4;
}

.address-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  z-index: 1;
  animation: fadeInUp 0.5s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.address-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(139, 92, 246, 0.3) 50%, transparent 100%);
}

.address-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(139, 92, 246, 0.2);
}

.address-card.default {
  border-color: rgba(236, 72, 153, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), 0 0 20rpx rgba(236, 72, 153, 0.1);
}

.address-main {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 1;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  letter-spacing: 0.5rpx;
}

.default-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.3) 0%, rgba(219, 39, 119, 0.2) 100%);
  color: #f8fafc;
  font-size: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(236, 72, 153, 0.3);
  font-weight: 500;
}

.address-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 400;
}

.address-location {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.location-icon {
  font-size: 24rpx;
  margin-top: 4rpx;
  color: #a78bfa;
}

.address-detail {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
  flex: 1;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  padding-top: 16rpx;
  position: relative;
  z-index: 1;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.action-item:active::before {
  left: 100%;
}

.action-item:active {
  background: rgba(255, 255, 255, 0.03);
  transform: scale(0.95);
}

.action-icon {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.3s ease;
}

.action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.action-item.delete .action-icon,
.action-item.delete .action-text {
  color: #ef4444;
}

.action-item.edit .action-icon,
.action-item.edit .action-text {
  color: #a78bfa;
}

.action-item.set-default .action-icon,
.action-item.set-default .action-text {
  color: #fbbf24;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #a78bfa 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: emptyFloat 3s ease-in-out infinite;
}

@keyframes emptyFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
  text-align: center;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  line-height: 1.4;
}

.form-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.95) 0%, rgba(2, 6, 23, 0.95) 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 100;
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(139, 92, 246, 0.2);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.3);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.form-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
  border-radius: 50%;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.form-close::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.form-close:active::before {
  left: 100%;
}

.form-close:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.1);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.required {
  color: #ec4899;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  outline: none;
}

.form-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 30rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.form-picker::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.form-picker:active::before {
  left: 100%;
}

.form-picker:active {
  border-color: rgba(139, 92, 246, 0.5);
  box-shadow: 0 0 16rpx rgba(139, 92, 246, 0.2);
}

.picker-value {
  font-size: 30rpx;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.picker-placeholder {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.4);
  position: relative;
  z-index: 1;
}

.picker-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.form-picker:active .picker-arrow {
  transform: rotate(180deg);
  color: #a78bfa;
}

.form-switch {
  transform: scale(0.9);
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.form-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.form-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.form-btn:active::before {
  left: 100%;
}

.form-btn.cancel {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
  color: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
}

.form-btn.confirm {
  background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
  color: #f8fafc;
  box-shadow: 0 8rpx 32rpx rgba(236, 72, 153, 0.3);
}

.form-btn:active {
  transform: scale(0.98);
}

.add-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(236, 72, 153, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 99;
  border: 1rpx solid rgba(236, 72, 153, 0.3);
  position: relative;
  overflow: hidden;
}

.add-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s;
}

.add-btn:active::before {
  left: 100%;
}

.add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 12rpx 40rpx rgba(236, 72, 153, 0.4);
}

.add-icon {
  font-size: 40rpx;
  color: #f8fafc;
  font-weight: 300;
  animation: addIconPulse 2s ease-in-out infinite;
  position: relative;
  z-index: 1;
}

@keyframes addIconPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.add-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  letter-spacing: 0.5rpx;
  position: relative;
  z-index: 1;
}





