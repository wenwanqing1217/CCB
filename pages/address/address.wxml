<view class="container">
  <view class="header">
    <text class="title">收货地址</text>
  </view>

  <view class="paste-section">
    <view class="paste-input-wrap">
      <textarea class="paste-input" placeholder="粘贴地址信息，自动识别姓名、电话、地址..." value="{{pasteText}}" bindinput="onPasteInput" auto-height maxlength="500" />
      <view class="paste-btn {{pasteText ? 'active' : ''}}" bindtap="parseAddress">识别</view>
    </view>
    <view class="paste-tip">
      <text class="tip-icon">💡</text>
      <text class="tip-text">支持粘贴淘宝、京东、拼多多等平台复制的地址</text>
    </view>
  </view>

  <view wx:if="{{addresses.length > 0}}">
    <view class="address-card {{item.isDefault ? 'default' : ''}}" wx:for="{{addresses}}" wx:key="_id">
      <view class="address-main" bindtap="selectAddress" data-id="{{item._id}}">
        <view class="address-header">
          <view class="name-wrap">
            <text class="address-name">{{item.name}}</text>
            <view class="default-tag" wx:if="{{item.isDefault}}">默认</view>
          </view>
          <text class="address-phone">{{item.phone}}</text>
        </view>
        <view class="address-location">
          <text class="location-icon">📍</text>
          <text class="address-detail">{{item.dorm}} {{item.room}}</text>
        </view>
      </view>
      <view class="address-actions">
        <view class="action-item" catchtap="setDefault" data-id="{{item._id}}" wx:if="{{!item.isDefault}}">
          <text class="action-icon">⭐</text>
          <text class="action-text">设为默认</text>
        </view>
        <view class="action-item" catchtap="editAddress" data-id="{{item._id}}">
          <text class="action-icon">✏️</text>
          <text class="action-text">编辑</text>
        </view>
        <view class="action-item delete" catchtap="deleteAddress" data-id="{{item._id}}">
          <text class="action-icon">×</text>
          <text class="action-text">删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{addresses.length === 0 && !showForm}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无收货地址</text>
    <text class="empty-hint">点击下方按钮添加新地址</text>
  </view>

  <view class="form-section" wx:if="{{showForm}}">
    <view class="form-header">
      <text class="form-title">{{editingId ? '编辑地址' : '新增地址'}}</text>
      <view class="form-close" bindtap="closeForm">×</view>
    </view>
    
    <view class="form-item">
      <text class="form-label">收货人<text class="required">*</text></text>
      <input class="form-input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
    </view>
    
    <view class="form-item">
      <text class="form-label">手机号<text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onFormInput" data-field="phone" maxlength="11" />
    </view>
    
    <view class="form-item">
      <text class="form-label">宿舍楼<text class="required">*</text></text>
      <picker mode="selector" range="{{dormList}}" value="{{form.dormIndex}}" bindchange="onDormChange">
        <view class="form-picker">
          <text class="{{form.dormIndex >= 0 ? 'picker-value' : 'picker-placeholder'}}">
            {{form.dormIndex >= 0 ? dormList[form.dormIndex] : '请选择宿舍楼'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <text class="form-label">房间号<text class="required">*</text></text>
      <input class="form-input" placeholder="如: 302室" value="{{form.room}}" bindinput="onFormInput" data-field="room" />
    </view>

    <view class="form-item">
      <text class="form-label">设为默认</text>
      <switch class="form-switch" checked="{{form.isDefault}}" bindchange="onSwitchChange" color="#FFB6C1" />
    </view>

    <view class="form-actions">
      <view class="form-btn cancel" bindtap="closeForm">取消</view>
      <view class="form-btn confirm" bindtap="saveAddress">保存</view>
    </view>
  </view>

  <view class="add-btn" bindtap="addAddress" wx:if="{{!showForm}}">
    <text class="add-icon">+</text>
    <text class="add-text">添加新地址</text>
  </view>
</view>