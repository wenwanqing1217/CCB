page { background: #020208; }

.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 100rpx;
}

.section-title { margin: 24rpx 0 16rpx; }
.title-text { font-size: 32rpx; font-weight: 700; color: rgba(255,255,255,0.9); }

/* 活动卡片 */
.activity-card {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.act-banner {
  position: relative;
  height: 240rpx;
}

.act-banner.purple { background: linear-gradient(135deg, #4C1D95, #7C3AED); }
.act-banner.blue { background: linear-gradient(135deg, #1E3A5F, #2563EB); }
.act-banner.green { background: linear-gradient(135deg, #065F46, #059669); }
.act-banner.gold { background: linear-gradient(135deg, #92400E, #F59E0B); }
.act-banner.pink { background: linear-gradient(135deg, #831843, #DB2777); }

.act-image {
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.act-countdown {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.countdown-label { font-size: 20rpx; color: rgba(255,255,255,0.6); }
.countdown-time { font-size: 28rpx; color: #FBBF24; font-weight: 700; }

.act-body {
  padding: 24rpx;
}

.act-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.act-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.act-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.act-participants {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.participant-icon { font-size: 24rpx; }
.participant-count { font-size: 22rpx; color: rgba(255,255,255,0.5); }

.act-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.act-tag.hot { background: rgba(255,107,107,0.15); color: #FF6B6B; border: 1rpx solid rgba(255,107,107,0.3); }
.act-tag.new { background: rgba(78,205,196,0.15); color: #4ECDC4; border: 1rpx solid rgba(78,205,196,0.3); }
.act-tag.limited { background: rgba(251,191,36,0.15); color: #FBBF24; border: 1rpx solid rgba(251,191,36,0.3); }

.act-progress { margin-top: 16rpx; }
.act-progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 4rpx;
}
.act-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7c3aed, #c8a2ff);
  border-radius: 999rpx;
  box-shadow: 0 0 10rpx rgba(147,112,219,0.4);
}
.act-progress-text { font-size: 20rpx; color: rgba(255,255,255,0.4); }

/* 已结束活动 */
.act-banner.ended {
  filter: grayscale(0.8);
  opacity: 0.6;
}

.act-ended-badge {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 12rpx 40rpx;
  background: rgba(0,0,0,0.7);
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.6);
  letter-spacing: 4rpx;
}

.act-result { margin-top: 12rpx; }
.result-text { font-size: 24rpx; color: rgba(255,255,255,0.5); }
