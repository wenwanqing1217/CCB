<view class="container particle-bg">
  <!-- 签到头部 -->
  <view class="checkin-header glass-card-v2">
    <view class="header-left">
      <text class="checkin-title">每日签到</text>
      <text class="checkin-subtitle">坚持签到，获取更多奖励</text>
    </view>
    <view class="header-right">
      <text class="checkin-streak-num">{{streak}}</text>
      <text class="checkin-streak-label">天连续</text>
    </view>
  </view>

  <!-- 签到按钮 -->
  <view class="checkin-action {{checkedIn ? 'done' : ''}}" bindtap="doCheckin">
    <view class="action-ring {{checkedIn ? 'pulse' : ''}}">
      <text class="action-icon">{{checkedIn ? '✓' : '🔆'}}</text>
    </view>
    <text class="action-text">{{checkedIn ? '今日已签到' : '点击签到'}}</text>
    <text class="action-reward" wx:if="{{!checkedIn}}">+{{todayReward}}积分</text>
  </view>

  <!-- 连续签到奖励预览 -->
  <view class="streak-preview glass-card-v2">
    <text class="preview-title">连续签到奖励</text>
    <scroll-view class="streak-scroll" scroll-x>
      <view class="streak-list">
        <view class="streak-item {{streak >= 7 ? 'achieved' : ''}}" wx:for="{{streakRewards}}" wx:key="day">
          <view class="streak-day-wrap {{streak >= item.day ? 'achieved' : ''}}">
            <text class="streak-day">{{item.day}}天</text>
          </view>
          <text class="streak-reward">{{item.reward}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 签到月历 -->
  <view class="calendar glass-card-v2">
    <view class="calendar-header">
      <text class="calendar-title">{{year}}年{{month}}月</text>
    </view>
    <view class="calendar-weekdays">
      <text class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="calendar-days">
      <view class="day empty" wx:for="{{emptyDays}}" wx:key="*this"></view>
      <view class="day {{item.checked ? 'checked' : ''}} {{item.today ? 'today' : ''}} {{item.canCheckin ? 'can-checkin' : ''}}"
            wx:for="{{days}}" wx:key="day" bindtap="onDayTap" data-day="{{item.day}}">
        <text class="day-num">{{item.day}}</text>
        <text class="day-check-mark" wx:if="{{item.checked}}">✓</text>
        <text class="day-reward" wx:elif="{{item.canCheckin}}">+{{dailyReward}}</text>
      </view>
    </view>
  </view>

  <!-- 签到记录 -->
  <view class="checkin-records glass-card-v2">
    <view class="records-header">
      <text class="records-title">签到记录</text>
      <text class="records-total">本月{{monthCheckins}}天</text>
    </view>
    <view class="records-list">
      <view class="record-item" wx:for="{{records}}" wx:key="date">
        <text class="record-date">{{item.date}}</text>
        <text class="record-reward">+{{item.reward}}积分</text>
        <text class="record-time">{{item.time}}</text>
      </view>
    </view>
    <view class="empty-state" wx:if="{{records.length === 0}}">
      <text class="empty-text">暂无签到记录，开始签到吧</text>
    </view>
  </view>
</view>
