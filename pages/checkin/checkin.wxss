page { background: #020208; }

.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* 签到头部 */
.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.checkin-title { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }
.checkin-subtitle { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; display: block; }

.checkin-streak-num {
  font-size: 64rpx;
  font-weight: 800;
  color: #FBBF24;
  text-shadow: 0 0 30rpx rgba(251,191,36,0.5);
  display: block;
  text-align: center;
}

.checkin-streak-label { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; text-align: center; }

/* 签到按钮 */
.checkin-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 24rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.checkin-action.done { opacity: 0.7; }

.action-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(147,112,219,0.3), rgba(124,58,237,0.2));
  border: 4rpx solid rgba(147,112,219,0.5);
  margin-bottom: 16rpx;
  box-shadow: 0 0 40rpx rgba(147,112,219,0.3);
  transition: all 0.3s;
}

.action-ring.pulse { animation: ringPulse 2s ease-in-out infinite; }

.action-icon { font-size: 64rpx; }

.action-text { font-size: 32rpx; font-weight: 600; color: #c8a2ff; margin-bottom: 8rpx; }
.action-reward { font-size: 28rpx; color: #FBBF24; font-weight: 600; }

/* 连续签到 */
.streak-preview { padding: 24rpx; margin-bottom: 24rpx; }

.preview-title { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.8); display: block; margin-bottom: 16rpx; }

.streak-scroll { white-space: nowrap; }
.streak-list { display: flex; gap: 20rpx; padding: 4rpx 0; }

.streak-item { text-align: center; flex-shrink: 0; }

.streak-day-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(255,255,255,0.1);
  margin-bottom: 8rpx;
  transition: all 0.3s;
}

.streak-day-wrap.achieved {
  background: linear-gradient(135deg, rgba(147,112,219,0.3), rgba(124,58,237,0.2));
  border-color: rgba(147,112,219,0.5);
  box-shadow: 0 0 20rpx rgba(147,112,219,0.3);
}

.streak-day { font-size: 26rpx; font-weight: 600; color: rgba(255,255,255,0.6); }
.streak-day-wrap.achieved .streak-day { color: #c8a2ff; }
.streak-reward { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; }

/* 月历 */
.calendar { padding: 24rpx; margin-bottom: 24rpx; }

.calendar-header { text-align: center; margin-bottom: 20rpx; }

.calendar-title { font-size: 30rpx; font-weight: 600; color: rgba(255,255,255,0.8); }

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 12rpx;
}

.weekday { font-size: 22rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s;
}

.day.empty { visibility: hidden; }

.day-num { font-size: 28rpx; font-weight: 500; color: rgba(255,255,255,0.8); }

.day.today .day-num {
  color: #c8a2ff;
  font-weight: 700;
}

.day.today {
  border: 2rpx solid rgba(147,112,219,0.4);
  box-shadow: 0 0 15rpx rgba(147,112,219,0.2);
}

.day.checked {
  background: rgba(78,205,196,0.15);
}

.day.checked .day-num { color: #4ECDC4; }

.day.can-checkin {
  animation: canCheckinPulse 2s ease-in-out infinite;
}

.day-can-checkin .day-num { color: #c8a2ff; }

.day-check-mark {
  font-size: 16rpx;
  color: #4ECDC4;
  position: absolute;
  bottom: 4rpx;
}

.day-reward {
  font-size: 14rpx;
  color: rgba(251,191,36,0.7);
}

/* 签到记录 */
.checkin-records { padding: 24rpx; }

.records-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.records-title { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.8); }
.records-total { font-size: 24rpx; color: #c8a2ff; }

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.record-item:last-child { border-bottom: none; }

.record-date { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.record-reward { font-size: 24rpx; color: #FBBF24; font-weight: 600; }
.record-time { font-size: 20rpx; color: rgba(255,255,255,0.3); }

.empty-state { text-align: center; padding: 40rpx; }
.empty-text { font-size: 26rpx; color: rgba(255,255,255,0.3); }

@keyframes ringPulse {
  0% { box-shadow: 0 0 30rpx rgba(147,112,219,0.3), 0 0 0 0 rgba(147,112,219,0.3); }
  70% { box-shadow: 0 0 30rpx rgba(147,112,219,0.3), 0 0 0 30rpx rgba(147,112,219,0); }
  100% { box-shadow: 0 0 30rpx rgba(147,112,219,0.3), 0 0 0 0 rgba(147,112,219,0); }
}

@keyframes canCheckinPulse {
  0%, 100% { background: rgba(147,112,219,0.05); }
  50% { background: rgba(147,112,219,0.12); }
}
