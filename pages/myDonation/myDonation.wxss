.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
}

.header {
  margin-bottom: 16rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15);
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  display: block;
}

.tab-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.tab-item.active {
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.3) 0%, rgba(255, 160, 180, 0.2) 100%);
  color: #f8fafc;
}

.donation-card {
  padding: 20rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, rgba(12, 12, 28, 0.95) 50%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.card-status {
  font-size: 24rpx;
  color: #c8a2ff;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.2) 0%, rgba(255, 160, 180, 0.15) 100%);
  border-radius: 8rpx;
}

.card-content {
  display: flex;
  gap: 16rpx;
}

.card-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, rgba(12, 12, 28, 0.95) 50%, rgba(5, 5, 15, 0.98) 100%);
}

.card-info {
  flex: 1;
}

.card-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.card-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: rgba(255, 255, 255, 0.4);
}






