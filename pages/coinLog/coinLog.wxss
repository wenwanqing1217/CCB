.container {
  min-height: 100vh;
  background: #020208;
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  padding-top: 24rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
}

.stats-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(147, 112, 219, 0.5) 50%, transparent 100%);
}

.stats-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stats-icon {
  font-size: 56rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.log-list {
  padding: 0;
  position: relative;
  z-index: 1;
}

.list-header {
  padding: 24rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.log-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  margin: 16rpx 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.2);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.log-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.log-icon text {
  font-size: 36rpx;
}

.log-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.log-desc {
  font-size: 28rpx;
  color: #fff;
}

.log-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.log-amount {
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.loading-more {
  text-align: center;
  padding: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
}