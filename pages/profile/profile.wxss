/* 个人资料页面样式 - 紫色霓虹灯风格 */

.container {
  min-height: 100vh;
  background: #020208;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 头部区域 */
.profile-header {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  padding: 40rpx 24rpx 60rpx;
  position: relative;
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  margin-bottom: 20rpx;
}

.profile-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.6) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 18rpx rgba(147, 112, 219, 0.5);
}

/* 用户信息区域 */
.user-info {
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

.avatar-wrap {
  position: relative;
  margin-right: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(147, 112, 219, 0.8);
  background: rgba(5, 5, 15, 0.8);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.4),
              0 0 50rpx rgba(147, 112, 219, 0.2);
}

/* VIP徽章 */
.vip-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #ba55d3 0%, #9370db 100%);
  border-radius: 8rpx;
  font-size: 16rpx;
  font-weight: 700;
  color: #fff;
  border: 2rpx solid #020208;
  box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.6);
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5);
}

.user-detail {
  flex: 1;
  padding-top: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-right: 16rpx;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
}

/* 编辑按钮 */
.edit-btn {
  padding: 8rpx 20rpx;
  background: rgba(147, 112, 219, 0.2);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.5);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.edit-btn text {
  font-size: 24rpx;
  color: #c4b5fd;
  text-shadow: 0 0 10rpx rgba(196, 181, 253, 0.5);
}

/* 标签�?*/
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.user-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  background: rgba(147, 112, 219, 0.2);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #c4b5fd;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.2);
}

.user-tag.rider {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  color: #ffffff;
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.4);
  font-weight: 600;
}

.user-tag.merchant {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  color: #ffffff;
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.4);
  font-weight: 600;
}

.user-tag.admin {
  background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
  color: #ffffff;
  border-color: rgba(252, 165, 165, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(220, 38, 38, 0.4);
  font-weight: 600;
}

/* ID�?*/
.id-row {
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 校园信息 */
.campus-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.campus-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.campus-text.empty {
  color: rgba(255, 255, 255, 0.4);
}

.edit-campus {
  font-size: 24rpx;
  color: #c4b5fd;
  padding: 4rpx 12rpx;
  background: rgba(147, 112, 219, 0.15);
  border-radius: 6rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 10rpx rgba(196, 181, 253, 0.4);
}

/* 校园信息表单 */
.campus-form {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.15);
}

.form-item {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 100rpx;
}

.picker {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
  padding: 16rpx 20rpx;
  background: rgba(10, 10, 26, 0.8);
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.form-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.form-btn.cancel {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.form-btn.submit {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
              0 0 40rpx rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

/* 登录区域 */
.login-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.login-content {
  display: flex;
  align-items: center;
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2);
}

.login-avatar text {
  font-size: 48rpx;
  color: rgba(196, 181, 253, 0.6);
}

.login-info {
  flex: 1;
}

.login-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 6rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.login-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.login-btn {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.5);
  border-radius: 28rpx;
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.5),
    0 0 15rpx rgba(147, 112, 219, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  text-shadow: 
    0 0 8rpx rgba(147, 112, 219, 0.7),
    0 0 15rpx rgba(147, 112, 219, 0.5);
  backdrop-filter: blur(20rpx);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 28rpx;
  z-index: -1;
}

.login-btn:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4);
  border-color: rgba(147, 112, 219, 0.7);
}

.login-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #c8a2ff;
  text-shadow: 
    0 0 8rpx rgba(147, 112, 219, 0.7),
    0 0 15rpx rgba(147, 112, 219, 0.5);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  margin: -30rpx 24rpx 24rpx;
  padding: 30rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  position: relative;
  z-index: 10;
  backdrop-filter: blur(15rpx);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.7);
  transition: all 0.3s ease;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
}

.stats-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.6) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.stats-item {
  flex: 1;
  text-align: center;
  padding: 0 10rpx;
  transition: transform 0.3s ease;
}

.stats-item:hover {
  transform: translateY(-2rpx);
}

.stats-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
  }
  50% {
    text-shadow: 0 0 25rpx rgba(147, 112, 219, 0.8), 0 0 35rpx rgba(186, 85, 211, 0.6);
  }
}

.stats-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  transition: color 0.3s ease;
}

.stats-item:hover .stats-label {
  color: rgba(196, 181, 253, 0.8);
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, 
    transparent 0%,
    rgba(147, 112, 219, 0.5) 50%,
    transparent 100%);
  margin: 0 5rpx;
}

/* VIP卡片 */
.vip-card {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.vip-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
}

.vip-info {
  margin-bottom: 16rpx;
}

.vip-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.vip-badge-text {
  padding: 4rpx 10rpx;
  background: rgba(147, 112, 219, 0.3);
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #c4b5fd;
  border: 1rpx solid rgba(147, 112, 219, 0.5);
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.vip-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.vip-progress {
  margin-top: 12rpx;
}

.progress-bar {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3rpx;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  border-radius: 3rpx;
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.progress-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 骑手卡片 */
.rider-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 24rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(186, 85, 211, 0.3);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 25rpx rgba(186, 85, 211, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.rider-info {
  display: flex;
  align-items: center;
}

.rider-badge {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  border: 2rpx solid rgba(200, 162, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(124, 58, 237, 0.4);
}

.rider-badge text {
  font-size: 36rpx;
}

.rider-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 2rpx;
  text-shadow: 0 0 10rpx rgba(186, 85, 211, 0.4);
}

.rider-level {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.rider-action {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(186, 85, 211, 0.3) 0%, rgba(147, 112, 219, 0.3) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(186, 85, 211, 0.5);
  box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.3);
}

.rider-action text {
  font-size: 24rpx;
  font-weight: 600;
  color: #d8b4fe;
  text-shadow: 0 0 10rpx rgba(216, 180, 254, 0.5);
}

/* 菜单区域 */
.menu-section {
  padding: 0 24rpx 40rpx;
  position: relative;
  z-index: 1;
}

.menu-group {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  transition: all 0.3s ease;
}

.menu-group:hover {
  border-color: rgba(147, 112, 219, 0.5);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.25),
              0 12rpx 48rpx rgba(0, 0, 0, 0.7);
}

.menu-group::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.5) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.5) 80%,
    transparent 100%);
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.15);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-item::before {
  content: '';
  position: absolute;
  left: -100%;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(147, 112, 219, 0.1) 50%, transparent 100%);
  transition: left 0.5s ease;
}

.menu-item:hover::before {
  left: 100%;
}

.menu-item:hover {
  background: rgba(147, 112, 219, 0.05);
  transform: translateX(5rpx);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background: rgba(147, 112, 219, 0.2);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.menu-item:hover .menu-icon {
  transform: scale(1.05);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.menu-icon text {
  font-size: 32rpx;
  color: #c4b5fd;
  text-shadow: 0 0 10rpx rgba(196, 181, 253, 0.5);
}

.menu-icon.rider {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.4);
}

.menu-icon.rider text {
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.6);
}

.menu-icon.merchant {
  background: rgba(147, 112, 219, 0.2);
  border-color: rgba(147, 112, 219, 0.4);
}

.menu-icon.merchant text {
  color: #c4b5fd;
  text-shadow: 0 0 10rpx rgba(196, 181, 253, 0.5);
}

.menu-icon.ai {
  background: rgba(186, 85, 211, 0.2);
  border-color: rgba(186, 85, 211, 0.4);
  box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.3);
}

.menu-icon.ai text {
  color: #d8b4fe;
  text-shadow: 0 0 15rpx rgba(216, 180, 254, 0.6);
  font-weight: 700;
}

.menu-icon.admin {
  background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
  border-color: rgba(252, 165, 165, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(220, 38, 38, 0.4);
}

.menu-icon.admin text {
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.6);
  font-weight: 700;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
  transition: color 0.3s ease;
}

.menu-item:hover .menu-text {
  color: #c4b5fd;
}

.menu-arrow {
  font-size: 32rpx;
  color: rgba(147, 112, 219, 0.5);
  transition: all 0.3s ease;
  margin-left: 10rpx;
}

.menu-item:hover .menu-arrow {
  color: #c4b5fd;
  transform: translateX(5rpx);
}

.menu-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(186, 85, 211, 0.4) 0%, rgba(147, 112, 219, 0.4) 100%);
  color: #d8b4fe;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-right: 12rpx;
  border: 1rpx solid rgba(186, 85, 211, 0.5);
  box-shadow: 0 0 10rpx rgba(186, 85, 211, 0.4);
  transition: all 0.3s ease;
}

.menu-item:hover .menu-badge {
  background: linear-gradient(135deg, rgba(186, 85, 211, 0.6) 0%, rgba(147, 112, 219, 0.6) 100%);
  box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.6);
}

.menu-status {
  font-size: 24rpx;
  margin-right: 12rpx;
  transition: all 0.3s ease;
}

.menu-status.verified {
  color: #c4b5fd;
  text-shadow: 0 0 8rpx rgba(196, 181, 253, 0.4);
}

.menu-status.pending {
  color: #ba55d3;
  text-shadow: 0 0 8rpx rgba(186, 85, 211, 0.4);
}

.menu-status.none {
  color: rgba(255, 255, 255, 0.4);
}

.menu-item:hover .menu-status {
  text-shadow: 0 0 15rpx rgba(196, 181, 253, 0.6);
}

.menu-tag {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(186, 85, 211, 0.3) 0%, rgba(147, 112, 219, 0.3) 100%);
  color: #d8b4fe;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-right: 12rpx;
  border: 1rpx solid rgba(186, 85, 211, 0.5);
  box-shadow: 0 0 10rpx rgba(186, 85, 211, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-tag.admin {
  background: linear-gradient(135deg, rgba(220, 38, 38, 0.4) 0%, rgba(239, 68, 68, 0.4) 100%);
  color: #fca5a5;
  border: 1rpx solid rgba(252, 165, 165, 0.5);
  box-shadow: 0 0 10rpx rgba(220, 38, 38, 0.4);
}

.menu-tag::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transform: rotate(45deg);
  animation: shine 2s infinite;
}

@keyframes shine {
  0% { transform: rotate(45deg) translateX(-100%); }
  100% { transform: rotate(45deg) translateX(100%); }
}

.menu-item:hover .menu-tag {
  background: linear-gradient(135deg, rgba(186, 85, 211, 0.5) 0%, rgba(147, 112, 219, 0.5) 100%);
  box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.5);
}

.menu-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ba55d3;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.6);
  animation: pulse-dot 2s infinite;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

@keyframes pulse-dot {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 15rpx rgba(186, 85, 211, 0.6);
  }
  50% {
    transform: scale(1.2);
    box-shadow: 0 0 25rpx rgba(186, 85, 211, 0.8);
  }
}

/* 盲盒积分卡片 */
.coins-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.4);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 25rpx rgba(251, 191, 36, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
}

.coins-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(251, 191, 36, 0.8) 20%,
    rgba(253, 224, 71, 0.8) 50%,
    rgba(251, 191, 36, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(251, 191, 36, 0.6);
}

.coins-info {
  display: flex;
  align-items: center;
}

.coins-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.3) 0%, rgba(253, 224, 71, 0.2) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.3);
}

.coins-icon text {
  font-size: 40rpx;
}

.coins-detail {
  display: flex;
  flex-direction: column;
}

.coins-arrow {
  margin-left: auto;
  padding: 8rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 36rpx;
}

.coins-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 4rpx;
}

.coins-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fbbf24;
  text-shadow: 0 0 15rpx rgba(251, 191, 36, 0.6);
}

.coins-actions {
  display: flex;
  gap: 16rpx;
}

.sign-btn {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 28rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.5),
              0 0 20rpx rgba(251, 191, 36, 0.3);
  transition: all 0.3s ease;
}

.sign-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.6);
}

.sign-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.4);
}

.sign-btn.signed {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  box-shadow: none;
}

.sign-btn.signed text {
  color: rgba(255, 255, 255, 0.5);
  text-shadow: none;
}

.goto-btn {
  padding: 16rpx 24rpx;
  background: rgba(251, 191, 36, 0.2);
  border-radius: 28rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.5);
  box-shadow: 0 0 15rpx rgba(251, 191, 36, 0.3);
  transition: all 0.3s ease;
}

.goto-btn:active {
  background: rgba(251, 191, 36, 0.3);
  transform: scale(0.95);
}

.goto-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fbbf24;
  text-shadow: 0 0 10rpx rgba(251, 191, 36, 0.5);
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 32rpx;
  margin-top: 16rpx;
}

.version text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}





/* 成就预览 */
.achievement-preview {
  margin: 20rpx 24rpx;
  padding: 24rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-title { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); }
.preview-more { font-size: 22rpx; color: #c8a2ff; }

.preview-badges {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.preview-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.badge-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: rgba(255,255,255,0.05);
  border: 2rpx solid rgba(255,255,255,0.1);
}

.badge-icon.common { border-color: rgba(156,163,175,0.4); }
.badge-icon.uncommon { border-color: rgba(52,211,153,0.4); box-shadow: 0 0 10rpx rgba(52,211,153,0.3); }
.badge-icon.rare { border-color: rgba(96,165,250,0.4); box-shadow: 0 0 10rpx rgba(96,165,250,0.3); }
.badge-icon.epic { border-color: rgba(167,139,250,0.5); box-shadow: 0 0 15rpx rgba(167,139,250,0.4); }
.badge-icon.legendary { border-color: rgba(251,191,36,0.5); box-shadow: 0 0 15rpx rgba(251,191,36,0.4); }

.badge-name { font-size: 18rpx; color: rgba(255,255,255,0.5); }

.preview-progress { }

.progress-label { font-size: 20rpx; color: rgba(255,255,255,0.4); margin-bottom: 8rpx; display: block; }

.mini-progress-bar {
  height: 6rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 999rpx;
  overflow: hidden;
}

.mini-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7c3aed, #c8a2ff);
  border-radius: 999rpx;
  box-shadow: 0 0 10rpx rgba(147,112,219,0.4);
  transition: width 0.8s ease-out;
}

