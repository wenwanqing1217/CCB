<view class="page">
  <!-- 顶部统计 -->
  <view class="header-stats">
    <view class="stat-card">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">全部通知</text>
    </view>
    <view class="stat-card unread">
      <text class="stat-num">{{unreadCount}}</text>
      <text class="stat-label">未读</text>
    </view>
  </view>

  <!-- 通知列表 -->
  <view class="notice-list">
    <view class="notice-item {{item.read ? '' : 'unread'}}" 
          wx:for="{{notices}}" 
          wx:key="id"
          bindtap="handleNoticeTap"
          data-id="{{item.id}}">
      
      <!-- 左侧图标 -->
      <view class="notice-icon-wrap {{item.type}}">
        <text class="notice-icon">{{item.icon}}</text>
        <view class="unread-dot" wx:if="{{!item.read}}"></view>
      </view>
      
      <!-- 内容区域 -->
      <view class="notice-content">
        <view class="notice-header">
          <text class="notice-title">{{item.title}}</text>
          <text class="notice-time">{{item.time}}</text>
        </view>
        <text class="notice-desc">{{item.content}}</text>
        
        <!-- 操作按钮 -->
        <view class="notice-actions" wx:if="{{item.action}}">
          <view class="action-btn" catchtap="handleAction" data-action="{{item.action.type}}" data-url="{{item.action.url}}">
            {{item.action.text}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{notices.length === 0}}">
    <view class="empty-icon">📭</view>
    <text class="empty-text">暂无系统通知</text>
    <text class="empty-hint">有新通知时会在这里显示</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{notices.length > 0}}">
    <view class="bottom-btn" bindtap="markAllRead">
      <text class="btn-icon">✓</text>
      <text class="btn-text">全部已读</text>
    </view>
    <view class="bottom-btn clear" bindtap="clearRead">
      <text class="btn-icon">🗑</text>
      <text class="btn-text">清除已读</text>
    </view>
  </view>
</view>
