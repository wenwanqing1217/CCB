<view class="page">
  <!-- 顶部统计 -->
  <view class="header-stats">
    <view class="stat-card">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">全部消息</text>
    </view>
    <view class="stat-card unread">
      <text class="stat-num">{{unreadCount}}</text>
      <text class="stat-label">未读</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <view class="message-list">
    <view class="message-item {{item.read ? '' : 'unread'}}" 
          wx:for="{{messages}}" 
          wx:key="id"
          bindtap="handleMessageTap"
          data-id="{{item.id}}">
      
      <!-- 左侧图标 -->
      <view class="message-icon-wrap {{item.type}}">
        <text class="message-icon">{{item.icon}}</text>
        <view class="unread-dot" wx:if="{{!item.read}}"></view>
      </view>
      
      <!-- 内容区域 -->
      <view class="message-content">
        <view class="message-header">
          <text class="message-title">{{item.title}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
        <text class="message-desc">{{item.content}}</text>
        
        <!-- 订单信息卡片 -->
        <view class="order-preview" wx:if="{{item.orderInfo}}">
          <image class="order-image" src="{{item.orderInfo.image}}" mode="aspectFill" />
          <view class="order-info">
            <text class="order-name">{{item.orderInfo.name}}</text>
            <text class="order-price">¥{{item.orderInfo.price}}</text>
          </view>
        </view>
        
        <!-- 操作按钮 -->
        <view class="message-actions" wx:if="{{item.action}}">
          <view class="action-btn" catchtap="handleAction" data-action="{{item.action.type}}" data-url="{{item.action.url}}" data-orderid="{{item.orderId}}">
            {{item.action.text}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{messages.length === 0}}">
    <view class="empty-icon">📦</view>
    <text class="empty-text">暂无订单消息</text>
    <text class="empty-hint">有新的订单动态时会在这里显示</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{messages.length > 0}}">
    <view class="bottom-btn" bindtap="markAllRead">
      <text class="btn-icon">✓</text>
      <text class="btn-text">全部已读</text>
    </view>
    <view class="bottom-btn clear" bindtap="clearRead">
      <text class="btn-icon">🗑</text>
      <text class="btn-text">清除已读</text>
    </view>
  </view>
</view>
