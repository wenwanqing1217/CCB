<view class="container particle-bg">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="title-wrap">
      <text class="page-title">我的收藏</text>
      <text class="page-subtitle">共 {{favorites.length}} 件宝贝</text>
    </view>
    <view class="edit-btn" bindtap="toggleEdit" wx:if="{{favorites.length > 0}}">
      <text>{{isEditing ? '完成' : '管理'}}</text>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="favorite-list" wx:if="{{favorites.length > 0}}">
    <view class="favorite-card {{isEditing ? 'editing' : ''}}" 
          wx:for="{{favorites}}" 
          wx:key="_id" 
          bindtap="{{isEditing ? '' : 'navigateToDetail'}}" 
          data-id="{{item._id}}">
      
      <!-- 选择框 -->
      <view class="select-box" wx:if="{{isEditing}}" catchtap="toggleSelect" data-id="{{item._id}}">
        <view class="select-circle {{item.selected ? 'selected' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
      </view>
      
      <!-- 图片区域 -->
      <view class="image-section">
        <image class="product-image" 
               src="{{item.images[0]}}" 
               mode="aspectFill"
               wx:if="{{item.images && item.images[0]}}" />
        <view class="image-placeholder" wx:else>
          <text class="placeholder-icon">{{item.typeIcon || '📦'}}</text>
          <text class="placeholder-text">{{item.typeName || '盲盒'}}</text>
        </view>
        
        <!-- 类型标签 -->
        <view class="type-tag">
          <text>{{item.typeName || '盲盒'}}</text>
        </view>
        
        <!-- 状态标签 -->
        <view class="status-tag {{item.status}}" wx:if="{{item.status}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>
      
      <!-- 内容区域 -->
      <view class="content-section">
        <text class="product-title">{{item.title}}</text>
        
        <view class="product-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>
        
        <view class="product-meta">
          <text class="meta-item" wx:if="{{item.campus}}">
            <text class="meta-icon">📍</text>
            <text>{{item.campus}}</text>
          </text>
          <text class="meta-item" wx:if="{{item.sales}}">
            <text class="meta-icon">🔥</text>
            <text>已售 {{item.sales}}</text>
          </text>
        </view>
        
        <view class="price-section">
          <view class="price-wrap">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
          </view>
          <view class="original-price" wx:if="{{item.originalPrice}}">
            <text>¥{{item.originalPrice}}</text>
          </view>
        </view>
      </view>
      
      <!-- 移除按钮 -->
      <view class="remove-btn" catchtap="removeFavorite" data-id="{{item._id}}" wx:if="{{!isEditing}}">
        <text class="remove-icon">×</text>
      </view>
    </view>
  </view>

  <!-- 批量操作栏 -->
  <view class="batch-actions" wx:if="{{isEditing && favorites.length > 0}}">
    <view class="select-all" bindtap="selectAll">
      <view class="select-circle {{allSelected ? 'selected' : ''}}">
        <text wx:if="{{allSelected}}">✓</text>
      </view>
      <text class="select-text">全选</text>
    </view>
    <view class="batch-delete {{selectedCount > 0 ? 'active' : ''}}" bindtap="batchDelete">
      <text>删除({{selectedCount}})</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{favorites.length === 0}}">
    <view class="empty-icon">💝</view>
    <text class="empty-title">暂无收藏</text>
    <text class="empty-desc">看到喜欢的盲盒，点击收藏图标即可收藏</text>
    <view class="empty-btn" bindtap="navigateToMarket">去逛逛</view>
  </view>

  <!-- 猜你喜欢 -->
  <view class="recommend-section" wx:if="{{favorites.length > 0}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="title-dot"></view>
        <text class="section-title">猜你喜欢</text>
      </view>
      <view class="view-more" bindtap="navigateToMarket">
        <text>查看更多</text>
        <text class="arrow">→</text>
      </view>
    </view>
    
    <view class="recommend-list">
      <view class="recommend-item" wx:for="{{recommendations}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}">
        <view class="recommend-image-wrap">
          <image class="recommend-image" src="{{item.images[0]}}" mode="aspectFill" wx:if="{{item.images && item.images[0]}}" />
          <view class="recommend-placeholder" wx:else>
            <text>{{item.typeIcon || '📦'}}</text>
          </view>
        </view>
        <text class="recommend-title">{{item.title}}</text>
        <text class="recommend-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area"></view>
</view>
