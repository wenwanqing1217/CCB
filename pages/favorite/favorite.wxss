/* ж”¶и—ҸйЎөйқў - ж·ұиүІйң“иҷ№зҒҜдё»йў?*/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #020617 50%, #0f0f23 100%);
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 20%, rgba(139, 92, 246, 0.06) 0%, transparent 40%),
              radial-gradient(circle at 70% 70%, rgba(236, 72, 153, 0.04) 0%, transparent 40%);
  pointer-events: none;
}

/* йЎөйқўж Үйўҳ */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.title-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.edit-btn {
  padding: 12rpx 24rpx;
  background: rgba(139, 92, 246, 0.15);
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #c8a2ff;
  transition: all 0.3s;
}

.edit-btn:active {
  background: rgba(139, 92, 246, 0.25);
  transform: scale(0.95);
}

/* ж”¶и—ҸеҲ—иЎЁ */
.favorite-list {
  position: relative;
  z-index: 1;
}

.favorite-card {
  display: flex;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(12rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.5s ease-out;
  position: relative;
  overflow: hidden;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.favorite-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.2);
}

.favorite-card.editing {
  padding-left: 80rpx;
}

/* йҖүжӢ©жЎ?*/
.select-box {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 20rpx;
}

.select-circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.select-circle.selected {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  border-color: transparent;
}

.select-circle text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

/* еӣҫзүҮеҢәеҹҹ */
.image-section {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.product-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(236, 72, 153, 0.08) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.image-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(236, 72, 153, 0.1) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.placeholder-icon {
  font-size: 48rpx;
}

.placeholder-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* зұ»еһӢж Үзӯҫ */
.type-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #ffffff;
  backdrop-filter: blur(8rpx);
}

/* зҠ¶жҖҒж Үзӯ?*/
.status-tag {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-tag.onsale {
  background: rgba(34, 197, 94, 0.8);
  color: #ffffff;
}

.status-tag.soldout {
  background: rgba(239, 68, 68, 0.8);
  color: #ffffff;
}

/* еҶ…е®№еҢәеҹҹ */
.content-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background: rgba(139, 92, 246, 0.15);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #a78bfa;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.meta-icon {
  font-size: 20rpx;
}

/* д»·ж јеҢәеҹҹ */
.price-section {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #fbbf24;
  font-weight: 600;
}

.price-value {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.original-price {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  text-decoration: line-through;
}

/* з§»йҷӨжҢүй’® */
.remove-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(239, 68, 68, 0.15);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.remove-btn:active {
  background: rgba(239, 68, 68, 0.3);
  transform: scale(0.9);
}

.remove-icon {
  font-size: 32rpx;
  color: #f87171;
  font-weight: 300;
}

/* жү№йҮҸж“ҚдҪңж ?*/
.batch-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-top: 1rpx solid rgba(139, 92, 246, 0.2);
  backdrop-filter: blur(20rpx);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-text {
  font-size: 28rpx;
  color: #f8fafc;
}

.batch-delete {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  transition: all 0.3s;
}

.batch-delete.active {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  border-color: transparent;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.3);
}

/* з©әзҠ¶жҖ?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
  text-align: center;
}

.empty-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(139, 92, 246, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 12rpx rgba(139, 92, 246, 0.4);
}

/* зҢңдҪ е–ңж¬ў */
.recommend-section {
  margin-top: 48rpx;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-dot {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #8b5cf6 0%, #ec4899 100%);
  border-radius: 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.view-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.arrow {
  font-size: 24rpx;
}

/* жҺЁиҚҗеҲ—иЎЁ */
.recommend-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.recommend-item {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 12rpx;
  transition: all 0.3s;
}

.recommend-item:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.2);
}

.recommend-image-wrap {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.recommend-image {
  width: 100%;
  height: 100%;
}

.recommend-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(236, 72, 153, 0.08) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.recommend-title {
  font-size: 24rpx;
  color: #f8fafc;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommend-price {
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* еә•йғЁе®үе…ЁеҢәеҹҹ */
.safe-area {
  height: 40rpx;
}





