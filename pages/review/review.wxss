.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
  padding-bottom: 120rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
}

.order-card {
  display: flex;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.order-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  margin-right: 20rpx;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.order-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.order-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #c8a2ff;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  display: block;
  margin-bottom: 16rpx;
}

.rating-section {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.star-item {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.4);
}

.star-item.active {
  color: #fbbf24;
}

.rating-text {
  font-size: 28rpx;
  color: #c8a2ff;
}

.tags-section {
  margin-bottom: 24rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 1rpx solid rgba(123, 104, 238, 0.2);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tag-item.active {
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.3) 0%, rgba(147, 112, 219, 0.2) 100%);
  border-color: #c8a2ff;
  color: #c8a2ff;
}

.content-section {
  margin-bottom: 24rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 1rpx solid rgba(123, 104, 238, 0.2);
  border-radius: 20rpx;
  color: #f8fafc;
  font-size: 28rpx;
  box-sizing: border-box;
}

.content-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

.images-section {
  margin-bottom: 24rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
}

.preview-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ef4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.add-image {
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx dashed #1e293b;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-image::before {
  content: '';
  display: block;
  padding-bottom: 100%;
}

.add-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%);
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
}

.add-text {
  position: absolute;
  top: 60%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.submit-btn {
  position: fixed;
  bottom: 40rpx;
  left: 24rpx;
  right: 24rpx;
  padding: 24rpx;
  background: #1e293b;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.submit-btn.active {
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.3) 0%, rgba(147, 112, 219, 0.2) 100%);
  color: #f8fafc;
}





