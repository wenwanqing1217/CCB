<view class="user-profile-container">
  <!-- 顶部用户信息 -->
  <view class="user-header">
    <view class="header-bg"></view>
    <view class="user-info" wx:if="{{userInfo}}">
      <view class="avatar-wrap">
        <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
        <view class="vip-badge {{userInfo.vipLevel > 0 ? 'level' + userInfo.vipLevel : ''}}" wx:if="{{userInfo.vipLevel > 0}}">
          <text>VIP{{userInfo.vipLevel}}</text>
        </view>
      </view>
      <view class="user-detail">
        <view class="name-row">
          <text class="user-name">{{userInfo.name}}</text>
        </view>
        <view class="tags-row">
          <view class="user-tag" wx:if="{{userInfo.isCertified}}">
            <text class="tag-icon">√</text>
            <text>已认证</text>
          </view>
          <view class="user-tag rider" wx:if="{{userInfo.isRider}}">
            <text>骑手</text>
          </view>
          <view class="user-tag merchant" wx:if="{{userInfo.isMerchant}}">
            <text class="tag-icon">商</text>
            <text>商家</text>
          </view>
        </view>
        <view class="campus-info" wx:if="{{userInfo.college && userInfo.dorm}}">
          <text class="campus-text">{{userInfo.college}} · {{userInfo.dorm}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons" wx:if="{{userInfo}}">
    <view class="follow-btn {{isFollowing ? 'active' : ''}}" bindtap="toggleFollow">
      <text>{{isFollowing ? '已关注' : '关注'}}</text>
    </view>
    <view class="contact-btn" bindtap="contactUser">
      <text>联系</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card" wx:if="{{userStats}}">
    <view class="stats-item">
      <text class="stats-num">{{userStats.publish}}</text>
      <text class="stats-label">发布</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{userStats.sold}}</text>
      <text class="stats-label">售出</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{userStats.bought}}</text>
      <text class="stats-label">购买</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{userStats.score}}</text>
      <text class="stats-label">活跃度</text>
    </view>
  </view>

  <!-- 发布的盲盒 -->
  <view class="section" wx:if="{{userBoxes.length > 0}}">
    <view class="section-header">
      <text class="section-title">发布的盲盒</text>
    </view>
    <view class="box-list">
      <view class="box-item" wx:for="{{userBoxes}}" wx:key="_id" bindtap="viewBoxDetail" data-id="{{item._id}}">
        <image class="box-image" src="{{item.images[0]}}" mode="aspectFill" />
        <view class="box-info">
          <text class="box-title">{{item.title}}</text>
          <view class="box-meta">
            <text class="box-price">¥{{item.price}}</text>
            <text class="box-status {{item.status}}">{{item.status === 'selling' ? '在售' : '已售罄'}}</text>
          </view>
          <view class="box-stats">
            <text class="stat">已开{{item.sales}}次</text>
            <text class="stat">赞{{item.likes}}</text>
            <text class="stat">评{{item.comments}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 捐赠记录 -->
  <view class="section" wx:if="{{userDonations.length > 0}}">
    <view class="section-header">
      <text class="section-title">爱心捐赠</text>
    </view>
    <view class="donation-list">
      <view class="donation-item" wx:for="{{userDonations}}" wx:key="_id" bindtap="viewDonationDetail" data-id="{{item._id}}">
        <image class="donation-image" src="{{item.image}}" mode="aspectFill" />
        <view class="donation-info">
          <text class="donation-title">{{item.title}}</text>
          <text class="donation-time">{{item.time}}</text>
          <view class="donation-status completed">
            <text>已完成</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && (!userBoxes || userBoxes.length === 0) && (!userDonations || userDonations.length === 0)}}">
    <text>该用户还没有发布任何内容</text>
  </view>
</view>
