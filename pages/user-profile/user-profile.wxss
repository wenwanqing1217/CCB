/* 用户主页 - 紫色霓虹灯主题 */

.user-profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #1a1a2e 100%);
  position: relative;
  overflow: hidden;
  padding-bottom: 40rpx;
}

.user-profile-container::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 30%, rgba(147, 112, 219, 0.08) 0%, transparent 50%),
              radial-gradient(circle at 70% 70%, rgba(186, 85, 211, 0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 顶部用户信息 */
.user-header {
  position: relative;
  padding: 40rpx 24rpx 32rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, #020208 50%, rgba(186, 85, 211, 0.12) 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 50rpx rgba(147, 112, 219, 0.2);
  margin-bottom: 24rpx;
  z-index: 1;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 50% 50%, rgba(147, 112, 219, 0.2) 0%, transparent 70%);
  pointer-events: none;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.avatar-wrap {
  position: relative;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(147, 112, 219, 0.5);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.4);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
}

.vip-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  border: 2rpx solid #0a0a1a;
  box-shadow: 0 2rpx 10rpx rgba(124, 58, 237, 0.4);
}

.vip-badge text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(124, 58, 237, 0.6);
}

.user-detail {
  flex: 1;
}

.name-row {
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.tags-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.user-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border-radius: 8rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 2rpx 8rpx rgba(147, 112, 219, 0.2);
}

.user-tag.rider {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.4);
}

.user-tag text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.user-tag.rider text {
  color: #ffffff;
  font-weight: 600;
}

.campus-info {
  margin-top: 8rpx;
}

.campus-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx 24rpx;
  z-index: 1;
  position: relative;
}

.follow-btn {
  flex: 1;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  text-align: center;
  transition: all 0.3s ease;
}

.follow-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.follow-btn.active {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.follow-btn.active text {
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
}

.contact-btn {
  flex: 1;
  padding: 20rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(200, 162, 255, 0.5);
  text-align: center;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
  transition: all 0.3s ease;
}

.contact-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
}

.contact-btn:active {
  transform: scale(0.98);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.6);
}

/* 统计数据 */
.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 24rpx;
  margin: 0 32rpx 32rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.2);
  backdrop-filter: blur(20rpx);
  z-index: 1;
  position: relative;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

.stats-divider {
  width: 1rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(147, 112, 219, 0.3) 50%, transparent 100%);
  margin: 0 16rpx;
}

/* 通用 section 样式 */
.section {
  margin-bottom: 32rpx;
  z-index: 1;
  position: relative;
}

.section-header {
  padding: 0 32rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

/* 盲盒列表 */
.box-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.box-item {
  display: flex;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  overflow: hidden;
  transition: all 0.3s ease;
}

.box-item:active {
  transform: scale(0.98);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.4);
  border-color: rgba(147, 112, 219, 0.6);
}

.box-image {
  width: 160rpx;
  height: 160rpx;
  object-fit: cover;
}

.box-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.box-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.box-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.box-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.4);
}

.box-status {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.box-status.selling {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  color: #c8a2ff;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
}

.box-status.sold {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.box-stats {
  display: flex;
  gap: 24rpx;
}

.stat {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

/* 捐赠记录 */
.donation-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.donation-item {
  display: flex;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  overflow: hidden;
  transition: all 0.3s ease;
}

.donation-item:active {
  transform: scale(0.98);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.4);
  border-color: rgba(147, 112, 219, 0.6);
}

.donation-image {
  width: 120rpx;
  height: 120rpx;
  object-fit: cover;
}

.donation-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.donation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.donation-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
  margin-bottom: 8rpx;
}

.donation-status {
  align-self: flex-start;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.donation-status.completed {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  color: #c8a2ff;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
}

/* 加载�?*/
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  z-index: 1;
  position: relative;
}

.loading text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

/* 空状态 */
.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  z-index: 1;
  position: relative;
}

.empty text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.1);
}





