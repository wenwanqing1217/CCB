/* 发布盲盒页面 - 紫色霓虹灯风格 */

page {
  height: 100vh;
  overflow: hidden;
}

.page {
  min-height: 100vh;
  background: #020208;
  position: relative;
  padding: 8rpx 16rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  height: 100vh;
  overflow-y: auto;
}

.page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 卡片样式 */
.card {
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
}

/* 表单样式 */
.form {
  position: relative;
  z-index: 1;
}

.form-item {
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.form-item .label {
  font-size: 26rpx;
  color: #ffffff;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 600;
}

/* 输入框样式 - 修复点击跳动问题 */
input,
textarea,
.picker {
  width: 100%;
  background: #020208;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #ffffff;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-sizing: border-box;
  caret-color: #c8a2ff;
}

input {
  height: 76rpx;
}

textarea {
  min-height: 100rpx;
}

/* placeholder样式 */
.placeholder {
  color: rgba(255, 255, 255, 0.4);
  opacity: 1;
}

/* 输入框获得焦点时 */
input:focus,
textarea:focus {
  border-color: rgba(147, 112, 219, 0.8);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
}

/* picker样式 */
.picker {
  line-height: 36rpx;
  color: rgba(255, 255, 255, 0.45);
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 76rpx;
}

.picker.has-value {
  color: #ffffff;
}

.picker-arrow {
  font-size: 24rpx;
  color: #c8a2ff;
  transition: transform 0.3s ease;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(186, 85, 211, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4);
  animation: arrowGlow 2s ease-in-out infinite;
}

@keyframes arrowGlow {
  0%, 100% {
    text-shadow: 
      0 0 10rpx rgba(147, 112, 219, 0.8),
      0 0 20rpx rgba(186, 85, 211, 0.6),
      0 0 30rpx rgba(147, 112, 219, 0.4);
  }
  50% {
    text-shadow: 
      0 0 15rpx rgba(147, 112, 219, 1),
      0 0 30rpx rgba(186, 85, 211, 0.8),
      0 0 45rpx rgba(147, 112, 219, 0.6);
  }
}

.picker:active .picker-arrow {
  transform: rotate(180deg) scale(1.1);
  text-shadow: 
    0 0 15rpx rgba(147, 112, 219, 1),
    0 0 30rpx rgba(186, 85, 211, 0.8),
    0 0 45rpx rgba(147, 112, 219, 0.6);
}

/* 图片区域 */
.img-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.img-container {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.img {
  width: 100%;
  height: 100%;
}

.img-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 50%, #ba55d3 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.img-remove text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.img-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed rgba(147, 112, 219, 0.5);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(147, 112, 219, 0.1);
  transition: all 0.3s;
}

.img-add:active {
  background: rgba(147, 112, 219, 0.2);
  border-color: rgba(186, 85, 211, 0.7);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
}

.img-add text {
  font-size: 56rpx;
  color: rgba(147, 112, 219, 0.8);
  font-weight: 300;
}

/* 提示文字 */
.hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 简介容器 */
.desc-container {
  position: relative;
  background: rgba(147, 112, 219, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.desc-container textarea {
  background: transparent;
  border: none;
  padding: 0;
  min-height: 80rpx;
  width: 100%;
  font-size: 24rpx;
  line-height: 1.5;
  color: #ffffff;
}

.desc-container textarea::placeholder {
  color: rgba(200, 162, 255, 0.5);
  font-size: 24rpx;
  line-height: 1.5;
}

/* 表单说明文字 - 在简介框下方 */
.form-note {
  font-size: 20rpx;
  color: rgba(200, 162, 255, 0.7);
  margin-top: 16rpx;
  line-height: 1.4;
  text-align: center;
  background: rgba(147, 112, 219, 0.1);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  backdrop-filter: blur(5rpx);
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.1);
}

/* 快速填写建议 - AI润色移到右边 */
.suggestions {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
}

.suggestion-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: rgba(200, 162, 255, 0.9);
  line-height: 1.4;
  transition: all 0.3s;
}

.suggestion-tag.ai-polish {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.3) 0%, rgba(22, 163, 74, 0.25) 100%);
  border-color: rgba(34, 197, 94, 0.6);
  color: #86efac;
  animation: aiPulse 2s ease-in-out infinite;
}

@keyframes aiPulse {
  0%, 100% { 
    box-shadow: 0 0 10rpx rgba(34, 197, 94, 0.3);
  }
  50% { 
    box-shadow: 0 0 20rpx rgba(34, 197, 94, 0.6);
  }
}

/* 提交按钮区域 - 悬浮固定定位 */
.submit-section {
  position: fixed;
  bottom: 200rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  justify-content: center;
  z-index: 999;
}

/* 发布按钮 - 霓虹灯风格 */
.btn-primary {
  width: 100%;
  max-width: 800rpx;
  padding: 28rpx 0;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border: 1rpx solid rgba(147, 112, 219, 0.1);
  background: #020208;
  color: #c8a2ff;
  box-shadow: 
    0 2rpx 12rpx rgba(0, 0, 0, 0.7);
  text-shadow: none;
  backdrop-filter: blur(5rpx);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
}

.btn-primary::before {
  display: none;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 
    0 4rpx 16rpx rgba(0, 0, 0, 0.8);
  border-color: rgba(147, 112, 219, 0.2);
}

.btn-primary[disabled] {
  opacity: 0.6;
  animation: none;
}

/* 分类选择弹窗 */
.category-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.category-content {
  width: 100%;
  max-height: 70vh;
  background: #020208;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
  border-top: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 -10rpx 40rpx rgba(147, 112, 219, 0.2);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.modal-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.category-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: rgba(5, 5, 15, 0.8);
  border-radius: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s;
}

.category-option.active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.25) 100%);
  border-color: rgba(186, 85, 211, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
