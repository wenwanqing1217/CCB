<view class="page">
  <view class="card form">
    <view class="form-item">
      <view class="label">盲盒标题</view>
      <input placeholder="例如：中园公寓二手书本盲盒" placeholder-class="placeholder" value="{{form.title}}" bindinput="onInput" data-field="title" />
    </view>

    <view class="form-item">
      <view class="label">盲盒类型</view>
      <picker bindchange="bindTypeChange" value="{{typeIndex}}" range="{{types}}" range-key="label">
        <view class="picker {{selectedTypeLabel ? 'has-value' : ''}}">
          {{selectedTypeLabel || '请选择盲盒类型'}}
          <view class="picker-arrow">▼</view>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">盲盒简介</view>
      <view class="desc-container">
        <textarea placeholder="简单介绍包含哪些物品、成色如何" placeholder-class="placeholder" value="{{form.desc}}" bindinput="onInput" data-field="desc" />
      </view>
      <view class="form-note">填写盲盒信息，支持二手 / 文创，默认满 15 天可进入爱心池</view>
      <view class="suggestions" wx:if="{{form.desc}}">
        <text class="suggestion-tag ai-polish" bindtap="aiPolish">AI 润色</text>
      </view>
    </view>

    <view class="form-item">
      <view class="label">盲盒图片（可选）</view>
      <view class="img-row">
        <block wx:for="{{images}}" wx:key="*this" wx:for-index="index">
          <view class="img-container">
            <image class="img" src="{{item}}" mode="aspectFill" />
            <view class="img-remove" bindtap="removeImage" data-index="{{index}}">
              <text>×</text>
            </view>
          </view>
        </block>
        <view class="img-add" bindtap="chooseImage" wx:if="{{images.length < 9}}">
          <text>+</text>
        </view>
      </view>
      <view class="hint">不上传图片也可以发布，建议至少上传 1 张示意图，最多可上传 9 张</view>
    </view>

    <view class="form-item">
      <view class="label">盲盒模式</view>
      <picker bindchange="bindModeChange" value="{{modeIndex}}" range="{{modes}}" range-key="label">
        <view class="picker {{selectedModeLabel ? 'has-value' : ''}}">
          {{selectedModeLabel || '请选择盲盒模式'}}
          <view class="picker-arrow">▼</view>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">价格（元）</view>
      <input type="digit" placeholder="建议 1~20 元之间" placeholder-class="placeholder" value="{{form.price}}" bindinput="onInput" data-field="price" />
    </view>

    <view class="form-item">
      <view class="label">校园区域</view>
      <picker bindchange="bindCampusChange" value="{{campuses.indexOf(form.campus)}}" range="{{campuses}}">
        <view class="picker {{form.campus ? 'has-value' : ''}}">
          {{form.campus || '请选择校园区域'}}
          <view class="picker-arrow">▼</view>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">宿舍号</view>
      <input placeholder="例如：302" placeholder-class="placeholder" value="{{form.dormNumber}}" bindinput="onInput" data-field="dormNumber" />
    </view>

    <view class="hint" style="margin-top: 16rpx;">
      发布后盲盒默认上架 7 天，15 天内无人成交将进入爱心候选，可由你决定是否捐赠。
    </view>
  </view>

  <view class="submit-section">
    <button class="btn-primary" loading="{{submitting}}" bindtap="onSubmit">发布盲盒</button>
  </view>
</view>
