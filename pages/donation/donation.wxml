<view class="container">
  <view class="header">
    <text class="title">二手捐赠</text>
    <view class="publish-btn" bindtap="navigateToPublish">发布捐赠</view>
  </view>

  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">累计捐赠</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.users}}</text>
      <text class="stat-label">参与人数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.today}}</text>
      <text class="stat-label">今日新增</text>
    </view>
  </view>

  <view class="filter-bar">
    <view class="filter-item {{activeCategory === 'all' ? 'active' : ''}}" bindtap="setCategory" data-category="all">全部</view>
    <view class="filter-item {{activeCategory === 'book' ? 'active' : ''}}" bindtap="setCategory" data-category="book">图书</view>
    <view class="filter-item {{activeCategory === 'tech' ? 'active' : ''}}" bindtap="setCategory" data-category="tech">数码</view>
    <view class="filter-item {{activeCategory === 'daily' ? 'active' : ''}}" bindtap="setCategory" data-category="daily">日用品</view>
    <view class="filter-item {{activeCategory === 'other' ? 'active' : ''}}" bindtap="setCategory" data-category="other">其他</view>
  </view>

  <view class="donation-list">
    <view class="donation-card" wx:for="{{donationItems}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}">
      <image class="donation-img" src="{{item.images[0]}}" mode="aspectFill" />
      <view class="donation-content">
        <view class="donation-header">
          <text class="donation-title">{{item.title}}</text>
          <view class="donation-status {{item.status}}">{{item.statusText}}</view>
        </view>
        <text class="donation-desc">{{item.description}}</text>
        <view class="donation-footer">
          <view class="donation-user">
            <image class="user-avatar" src="{{item.userAvatar}}" />
            <text class="user-name">{{item.userName}}</text>
          </view>
          <view class="donation-location">
            <text class="location-icon">📍</text>
            <text class="location-text">{{item.location}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="no-more" wx:if="{{!hasMore && donationItems.length > 0 && !loading}}">
    <text>没有更多了</text>
  </view>

  <view class="empty" wx:if="{{!loading && donationItems.length === 0}}">
    <text class="empty-text">暂无捐赠物品</text>
    <text class="empty-hint">成为第一个捐赠者吧</text>
    <view class="empty-btn" bindtap="navigateToPublish">发布捐赠</view>
  </view>
</view>