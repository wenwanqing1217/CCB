.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
}

.publish-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  backdrop-filter: blur(10rpx);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
}

.publish-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.publish-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.15),
    0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  z-index: 1;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.stats-row::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(56, 189, 248, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 24rpx;
}

.stats-row:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.stats-row:active::before {
  opacity: 1;
}

.stat-item {
  text-align: center;
  position: relative;
  z-index: 1;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-variant-numeric: tabular-nums;
  margin-bottom: 8rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.filter-bar::-webkit-scrollbar {
  display: none;
}

.filter-item {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  backdrop-filter: blur(15rpx);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: rgba(200, 162, 255, 0.7);
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.1);
}

.filter-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.filter-item:active::before {
  left: 100%;
}

.filter-item.active {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  color: #ffffff;
  font-weight: 700;
  border: 1rpx solid rgba(147, 112, 219, 0.6);
  box-shadow: 
    0 0 20rpx rgba(147, 112, 219, 0.4),
    0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.filter-item:active {
  transform: scale(0.95);
}

.donation-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.donation-card {
  display: flex;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.15),
    0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.5s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.donation-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(56, 189, 248, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.donation-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.donation-card:active::before {
  opacity: 1;
}

.donation-img {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, rgba(12, 12, 28, 0.95) 50%, rgba(5, 5, 15, 0.98) 100%);
  flex-shrink: 0;
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: transform 0.3s ease;
}

.donation-card:active .donation-img {
  transform: scale(1.05);
}

.donation-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.donation-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.donation-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
  line-height: 1.4;
}

.donation-status {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid transparent;
  transition: all 0.3s ease;
}

.donation-status.pending {
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.2) 0%, rgba(255, 160, 180, 0.2) 100%);
  color: #FFB6C1;
  border-color: rgba(255, 182, 193, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(255, 182, 193, 0.2);
}

.donation-status.claimed {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
  color: #3b82f6;
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
}

.donation-status.completed {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(16, 185, 129, 0.2) 100%);
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

.donation-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.donation-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.donation-user {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  border: 2rpx solid rgba(56, 189, 248, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #c8a2ff;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.1) 100%);
}

.user-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.donation-location {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.location-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.location-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.loading, .no-more {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  position: relative;
  z-index: 1;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  position: relative;
  z-index: 1;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 12rpx;
  text-align: center;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 32rpx;
  text-align: center;
  line-height: 1.5;
  padding: 0 48rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  backdrop-filter: blur(10rpx);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
}

.empty-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.empty-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}







