.container{
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
  padding-bottom: 120rpx;
}

.header{
  margin-bottom: 24rpx;
}

.title{
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
}

.form-section{
  margin-bottom: 24rpx;
}

.form-label{
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  display: block;
  margin-bottom: 12rpx;
}

.required{
  color: #c8a2ff;
  margin-left: 4rpx;
}

.form-input{
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  outline: none;
}

.form-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 30rpx;
}

.form-textarea{
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-textarea:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  outline: none;
}

.form-textarea::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 30rpx;
}

.char-count{
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
}

.form-picker{
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  transition: all 0.2s ease;
}

.picker-value{
  font-size: 30rpx;
  color: #ffffff;
}

.picker-placeholder{
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.4);
}

.images-grid{
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item{
  position: relative;
  width: 100%;
  padding-bottom: 100%;
}

.preview-img{
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
}

.remove-btn{
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ef4444;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.add-image{
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx dashed #1e293b;
  border-radius: 12rpx;
}

.add-icon{
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
}

.submit-btn{
  position: fixed;
  bottom: 40rpx;
  left: 24rpx;
  right: 24rpx;
  padding: 24rpx;
  background: #1e293b;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.submit-btn.active{
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.3) 0%, rgba(147, 112, 219, 0.2) 100%);
  color: #f8fafc;
}





