<view class="container">
  <view class="header">
    <text class="title">发布求换</text>
  </view>

  <view class="form-section">
    <text class="form-label">求换物品<text class="required">*</text></text>
    <input class="form-input" placeholder="你想要换什么？" value="{{wantItem}}" bindinput="onWantInput" />
  </view>

  <view class="form-section">
    <text class="form-label">可换物品<text class="required">*</text></text>
    <input class="form-input" placeholder="你可以提供什么？" value="{{haveItem}}" bindinput="onHaveInput" />
  </view>

  <view class="form-section">
    <text class="form-label">物品图片</text>
    <view class="images-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill" />
        <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="add-image" wx:if="{{images.length < 9}}" bindtap="addImage">
        <text class="add-icon">+</text>
      </view>
    </view>
  </view>

  <view class="form-section">
    <text class="form-label">详细描述</text>
    <textarea class="form-textarea" placeholder="描述一下物品情况、交换要求等..." value="{{description}}" bindinput="onDescInput" maxlength="500" />
    <text class="char-count">{{description.length}}/500</text>
  </view>

  <view class="form-section">
    <text class="form-label">所在楼栋<text class="required">*</text></text>
    <picker class="form-picker" value="{{dormIndex}}" range="{{dorms}}" bindchange="onDormChange">
      <text class="{{dormIndex >= 0 ? 'picker-value' : 'picker-placeholder'}}">
        {{dormIndex >= 0 ? dorms[dormIndex] : '请选择楼栋'}}
      </text>
    </picker>
  </view>

  <view class="form-section">
    <text class="form-label">联系方式</text>
    <input class="form-input" placeholder="微信号/手机号（选填）" value="{{contact}}" bindinput="onContactInput" />
  </view>

  <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="submitExchange">发布</view>
</view>