/* 聊天页面 - 紫色霓虹灯主�?*/

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.chat-container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 30%, rgba(147, 112, 219, 0.08) 0%, transparent 50%),
              radial-gradient(circle at 70% 70%, rgba(186, 85, 211, 0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 顶部标题�?- 微信风格 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.2);
  backdrop-filter: blur(20rpx);
  position: relative;
  z-index: 1;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  flex: 1;
}

.header-more {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-icon {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.message-item {
  margin-bottom: 32rpx;
}

.message-time {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

.message-content {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
  flex-shrink: 0;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  position: relative;
  word-wrap: break-word;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
}

/* 接收的消�?*/
.message-item.receive .message-content {
  flex-direction: row;
}

.message-item.receive .message-bubble {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  border-top-left-radius: 4rpx;
}

.message-item.receive .message-text {
  color: #f8fafc;
}

/* 发送的消息 */
.message-item.send .message-content {
  flex-direction: row-reverse;
}

.message-item.send .message-bubble {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border: 1rpx solid rgba(200, 162, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
  border-top-right-radius: 4rpx;
}

.message-item.send .message-text {
  color: #ffffff;
}

/* 底部输入�?*/
.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(20, 20, 40, 0.95) 100%);
  border-top: 1rpx solid rgba(147, 112, 219, 0.3);
  backdrop-filter: blur(20rpx);
  gap: 16rpx;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.input-wrap {
  flex: 1;
  background: rgba(147, 112, 219, 0.1);
  border-radius: 40rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  padding: 16rpx 24rpx;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.1);
}

.chat-input {
  font-size: 28rpx;
  color: #f8fafc;
  background: transparent;
  border: none;
  outline: none;
  width: 100%;
}

.input-placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.send-btn {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  border-radius: 40rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
}

.send-btn text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 600;
}

.send-btn.active {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.send-btn.active text {
  color: #ffffff;
}





