/* 钱包页面 - 紫色霓虹灯风格 */

.container {
  min-height: 100vh;
  background: #020208;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 钱包卡片 */
.wallet-card {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(12rpx);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.15);
}

.wallet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.wallet-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.wallet-eyes {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(147, 112, 219, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.wallet-balance {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 30rpx rgba(200, 162, 255, 0.5);
  margin-bottom: 32rpx;
}

.wallet-actions {
  display: flex;
  gap: 20rpx;
}

.wallet-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  color: #fff;
}

.wallet-btn.primary {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.4);
}

/* 统计栏 */
.stats-row {
  display: flex;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #c8a2ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 区块 */
.section {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.coin-rate {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.section-more {
  font-size: 24rpx;
  color: #c8a2ff;
}

/* 金币中心 */
.earn-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.earn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.earn-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.earn-icon-wrap.spin {
  background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
}

.earn-icon-wrap.quiz {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
}

.earn-icon-wrap.sign {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.earn-icon-wrap.share {
  background: linear-gradient(135deg, #ec4899 0%, #f472b6 100%);
}

.earn-icon {
  font-size: 40rpx;
}

.earn-name {
  font-size: 24rpx;
  color: #fff;
  margin-bottom: 4rpx;
}

.earn-reward {
  font-size: 20rpx;
  color: #fbbf24;
}

/* 交易记录 */
.record-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.2);
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
}

.record-icon.income {
  background: rgba(16, 185, 129, 0.2);
  color: #34d399;
}

.record-icon.expense {
  background: rgba(239, 68, 68, 0.2);
  color: #f87171;
}

.record-info {
  flex: 1;
}

.record-title {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 4rpx;
}

.record-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.record-amount {
  font-size: 28rpx;
  font-weight: 600;
}

.record-amount.income {
  color: #34d399;
}

.record-amount.expense {
  color: #f87171;
}

.empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 100;
}

.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #0a0a1a 0%, #020617 100%);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  z-index: 101;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.withdraw-balance {
  text-align: center;
  margin-bottom: 32rpx;
}

.withdraw-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.withdraw-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #c8a2ff;
}

.withdraw-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(147, 112, 219, 0.1);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.withdraw-currency {
  font-size: 36rpx;
  color: #fff;
  margin-right: 16rpx;
}

.withdraw-input {
  flex: 1;
  font-size: 36rpx;
  color: #fff;
  background: transparent;
  border: none;
}

.withdraw-all {
  font-size: 24rpx;
  color: #c8a2ff;
  padding: 8rpx 16rpx;
  background: rgba(147, 112, 219, 0.2);
  border-radius: 12rpx;
}

.withdraw-tip {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.modal-btn.cancel {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  color: #fff;
}

.modal-btn.confirm.disabled {
  opacity: 0.5;
}

/* 游戏弹窗 */
.game-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background: linear-gradient(135deg, #0a0a1a 0%, #020617 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  z-index: 101;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.game-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.game-body {
  text-align: center;
  padding: 40rpx 0;
}

.game-result {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 8rpx;
}

.result-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #fbbf24;
  margin-bottom: 8rpx;
}

.result-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.play-tip {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32rpx;
}

.play-btn {
  display: inline-block;
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.4);
}
/* 钱包页面增强 */
.wallet-card {
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.wallet-card::before {
  content: "";
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 40%, rgba(147,112,219,0.1), transparent 60%);
  animation: walletShimmer 4s ease-in-out infinite;
}

@keyframes walletShimmer {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(5%, 5%); }
}

.wallet-balance {
  font-variant-numeric: tabular-nums;
  transition: all 0.3s;
}

/* 统计行 */
.stats-row .stat-item {
  transition: all 0.3s ease;
}

.stats-row .stat-item:active {
  transform: translateY(-4rpx);
}

.stat-value {
  font-variant-numeric: tabular-nums;
}

/* 赚币入口 */
.earn-item {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.earn-item:active {
  transform: translateY(-6rpx) scale(0.97);
}

.earn-icon-wrap {
  transition: all 0.3s ease;
}

.earn-item:active .earn-icon-wrap {
  box-shadow: 0 0 30rpx currentColor;
}

/* 交易记录 */
.record-item {
  transition: all 0.3s ease;
}

.record-item:active {
  transform: translateX(8rpx);
  background: rgba(147,112,219,0.03);
}

/* 游戏弹窗 */
.game-content {
  animation: modalSlideUp 0.4s ease-out;
}

@keyframes modalSlideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* 提现弹窗 */
.modal-content {
  animation: modalSlideUp 0.3s ease-out;
}
