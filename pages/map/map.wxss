.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 50% 50%, rgba(147, 112, 219, 0.1) 0%, transparent 70%);
  z-index: 0;
}

.header {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(26, 26, 46, 0.8);
  backdrop-filter: blur(10rpx);
  color: #fff;
  position: relative;
  z-index: 10;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 0 0 20rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
}

.header-left {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.header-left:active {
  transform: scale(0.95);
  background: rgba(147, 112, 219, 0.3);
}

.back-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.6);
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.6);
  background: linear-gradient(90deg, #fff 0%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: glow 2s ease-in-out infinite alternate;
}

@keyframes glow {
  from {
    text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.6);
  }
  to {
    text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.8), 0 0 30rpx rgba(147, 112, 219, 0.4);
  }
}

.header-right {
  width: 40rpx;
}

.map-container {
  flex: 1;
  position: relative;
  z-index: 1;
}

.map {
  width: 100%;
  height: 100%;
}

.bottom-panel {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  background: rgba(26, 26, 46, 0.8);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.3);
  padding: 32rpx;
  z-index: 5;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-id {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.4);
}

.order-fee {
  font-size: 32rpx;
  color: #c8a2ff;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.6);
}

.order-route {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.route-point {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.point-tag {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
  }
  50% {
    box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.8);
  }
  100% {
    box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
  }
}

.point-tag.to {
  background: linear-gradient(135deg, #c8a2ff 0%, #7c3aed 100%);
}

.point-text {
  font-size: 28rpx;
  color: #e0e0e0;
  flex: 1;
  line-height: 1.4;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.4);
}

.route-line {
  width: 2rpx;
  height: 40rpx;
  background: linear-gradient(to bottom, #7c3aed, #c8a2ff);
  margin-left: 19rpx;
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.4);
}

.order-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s;
}

.action-btn:hover::before {
  left: 100%;
}

.action-btn.call {
  background: rgba(255, 255, 255, 0.1);
  color: #c8a2ff;
  gap: 8rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.action-btn.call:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.98);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.action-btn.status {
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.6);
}

.action-btn.status:active {
  transform: scale(0.98);
  opacity: 0.9;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.8);
}

.btn-icon {
  font-size: 32rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.6);
}

.no-order {
  text-align: center;
  padding: 48rpx 0;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.6);
}

.no-order text {
  display: block;
  font-size: 32rpx;
  color: #c8a2ff;
  margin-bottom: 16rpx;
}

.no-order .hint {
  font-size: 24rpx;
  color: #a78bfa;
  margin-bottom: 0;
}

.location-info {
  position: absolute;
  top: 120rpx;
  left: 32rpx;
  right: 32rpx;
  background: rgba(26, 26, 46, 0.8);
  backdrop-filter: blur(10rpx);
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
  z-index: 5;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.location-text {
  display: block;
  font-size: 24rpx;
  color: #e0e0e0;
  margin-bottom: 8rpx;
  line-height: 1.3;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.4);
}

.update-time {
  font-size: 20rpx;
  color: #a78bfa;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.4);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .header {
    height: 88rpx;
    padding: 0 24rpx;
  }
  
  .header-title {
    font-size: 32rpx;
  }
  
  .bottom-panel {
    left: 24rpx;
    right: 24rpx;
    padding: 24rpx;
  }
  
  .order-id {
    font-size: 24rpx;
  }
  
  .order-fee {
    font-size: 28rpx;
  }
  
  .point-text {
    font-size: 24rpx;
  }
  
  .action-btn {
    height: 72rpx;
    font-size: 24rpx;
  }
  
  .location-info {
    top: 108rpx;
    left: 24rpx;
    right: 24rpx;
    padding: 16rpx;
  }
  
  .location-text {
    font-size: 20rpx;
  }
  
  .update-time {
    font-size: 18rpx;
  }
}