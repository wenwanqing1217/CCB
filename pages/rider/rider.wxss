/* 骑手页面 - 紫色霓虹灯风格 */

.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: #020208;
  position: relative;
  padding-bottom: 140rpx;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  position: relative;
  z-index: 1;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 状态卡片 */
.status-card {
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.status-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.status-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.rider-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid rgba(147, 112, 219, 0.8);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
}

.rider-info {
  flex: 1;
}

.rider-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.rider-level {
  display: block;
  font-size: 24rpx;
  color: #c4b5fd;
  margin-top: 4rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.rider-status {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid;
  transition: all 0.3s;
}

.rider-status.online {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(147, 112, 219, 0.2) 100%);
  color: #c4b5fd;
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.rider-status.offline {
  background: rgba(5, 5, 15, 0.6);
  color: rgba(255, 255, 255, 0.5);
  border-color: rgba(255, 255, 255, 0.2);
}

/* 统计数据 */
.stats-row {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

/* 申请区域 */
.apply-section {
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.apply-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.benefit-list {
  margin-bottom: 32rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.benefit-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 50%, #ba55d3 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.benefit-content {
  flex: 1;
}

.benefit-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.2);
}

.benefit-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

/* 表单样式 */
.form-section {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.required {
  color: #c4b5fd;
  margin-left: 4rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.form-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  background: rgba(10, 10, 26, 0.8);
  border-radius: 24rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #ffffff;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  outline: none;
}

.form-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 30rpx;
}

.phone-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.phone-input {
  flex: 1;
}

.code-btn {
  padding: 0 28rpx;
  height: 96rpx;
  min-height: 96rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border: none;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #ffffff;
  white-space: nowrap;
  font-weight: 600;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-btn.disabled {
  background: rgba(5, 5, 15, 0.6);
  border-color: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.5);
  box-shadow: none;
}

.code-input {
  margin-top: 0;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 身份证上�?*/
.id-card-upload {
  display: flex;
  gap: 16rpx;
}

.id-card-item {
  flex: 1;
  height: 200rpx;
  background: #0a0a1a;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx dashed rgba(147, 112, 219, 0.5);
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.15);
}

.id-image {
  width: 100%;
  height: 100%;
}

.id-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.placeholder-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  padding: 0 8rpx;
}

.id-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 50%, #ba55d3 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

/* Picker */
.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 96rpx;
  min-height: 96rpx;
  background: rgba(10, 10, 26, 0.8);
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #ffffff;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-sizing: border-box;
}

.picker-arrow {
  color: rgba(255, 255, 255, 0.5);
  font-size: 32rpx;
}

/* 申请按钮 */
.apply-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 24rpx;
  border: none;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 0 90rpx rgba(186, 85, 211, 0.25),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
}

.apply-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 42rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.apply-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 0 90rpx rgba(186, 85, 211, 0.25),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 0 120rpx rgba(186, 85, 211, 0.35),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.apply-btn.disabled {
  background: rgba(5, 5, 15, 0.6);
  color: rgba(255, 255, 255, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: none;
  animation: none;
}

.apply-btn.disabled::before,
.apply-btn.disabled::after {
  display: none;
}

/* 订单区域 */
.order-section {
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.order-count {
  font-size: 24rpx;
  color: #c4b5fd;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.section-more {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.order-list {
  margin-top: 16rpx;
}

/* 订单卡片 */
.order-card {
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.order-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.4) 20%,
    rgba(186, 85, 211, 0.4) 50%,
    rgba(200, 162, 255, 0.4) 80%,
    transparent 100%);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.order-fee {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.order-route {
  background: #0a0a1a;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
}

.route-point {
  display: flex;
  align-items: center;
}

.point-tag {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(124, 58, 237, 0.4);
}

.point-tag.to {
  background: linear-gradient(135deg, #22c55e 0%, #34d399 100%);
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.4);
}

.point-text {
  font-size: 28rpx;
  color: #ffffff;
}

.route-line {
  width: 2rpx;
  height: 24rpx;
  background-color: rgba(147, 112, 219, 0.3);
  margin-left: 19rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid;
}

.action-btn.reject {
  background: rgba(5, 5, 15, 0.6);
  color: rgba(255, 255, 255, 0.6);
  border-color: rgba(255, 255, 255, 0.2);
}

.action-btn.accept {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  color: #c4b5fd;
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.action-btn.pickup {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(147, 112, 219, 0.2) 100%);
  color: #c4b5fd;
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.action-btn.complete {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  color: #c4b5fd;
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

/* 订单状态 */
.order-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  border: 2rpx solid;
}

.order-status.picked {
  background: rgba(147, 112, 219, 0.2);
  color: #c4b5fd;
  border-color: rgba(147, 112, 219, 0.5);
}

.order-status.delivering {
  background: rgba(186, 85, 211, 0.2);
  color: #d8b4fe;
  border-color: rgba(186, 85, 211, 0.5);
}

/* 迷你路线 */
.order-route.mini {
  padding: 12rpx 16rpx;
}

.route-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 我的订单 */
.my-orders {
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}





