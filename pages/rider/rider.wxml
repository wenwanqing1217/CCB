<view class="container particle-bg">
  <view class="header" wx:if="{{!isRider}}">
    <text class="title">成为校园骑手</text>
    <text class="subtitle">赚取配送费，服务同学</text>
  </view>

  <view class="status-card" wx:if="{{isRider}}">
    <view class="status-header">
      <image class="rider-avatar" src="{{userInfo.avatar}}" />
      <view class="rider-info">
        <text class="rider-name">{{userInfo.name}}</text>
        <text class="rider-level">Lv.{{riderLevel}} 骑手</text>
      </view>
      <view class="rider-status {{isOnline ? 'online' : 'offline'}}" bindtap="toggleOnline">
        <text>{{isOnline ? '接单中' : '休息中'}}</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{todayOrders}}</text>
        <text class="stat-label">今日订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{todayEarnings}}</text>
        <text class="stat-label">今日收入</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{totalOrders}}</text>
        <text class="stat-label">累计订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{totalEarnings}}</text>
        <text class="stat-label">累计收入</text>
      </view>
    </view>
  </view>

  <view class="apply-section" wx:if="{{!isRider}}">
    <view class="benefit-list">
      <view class="benefit-item">
        <text class="benefit-icon">1</text>
        <view class="benefit-content">
          <text class="benefit-title">灵活接单</text>
          <text class="benefit-desc">自由安排时间，课余时间赚零花钱</text>
        </view>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">2</text>
        <view class="benefit-content">
          <text class="benefit-title">配送费高</text>
          <text class="benefit-desc">每单配送费 3-8 元，多劳多得</text>
        </view>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">3</text>
        <view class="benefit-content">
          <text class="benefit-title">校园配送</text>
          <text class="benefit-desc">只送校内，安全便捷</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{applyName}}" bindinput="onNameInput" />
    </view>
    <view class="form-section">
      <text class="form-label">手机号<text class="required">*</text></text>
      <view class="phone-row">
        <input class="form-input phone-input" type="number" placeholder="请输入手机号" value="{{applyPhone}}" bindinput="onPhoneInput" maxlength="11" />
        <view class="code-btn {{codeSent ? 'disabled' : ''}}" bindtap="sendCode">
          <text>{{codeSent ? countdown + 's' : '获取验证码'}}</text>
        </view>
      </view>
      <input class="form-input code-input" type="number" placeholder="请输入验证码" value="{{verifyCode}}" bindinput="onCodeInput" maxlength="6" />
    </view>
    <view class="form-section">
      <text class="form-label">宿舍楼<text class="required">*</text></text>
      <picker mode="selector" range="{{dormList}}" value="{{dormIndex}}" bindchange="onDormChange">
        <view class="form-picker">
          <text>{{dormIndex >= 0 ? dormList[dormIndex] : '请选择宿舍楼'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-section">
      <text class="form-label">详细住址<text class="required">*</text></text>
      <input class="form-input" placeholder="如: 中园公寓 302室" value="{{applyAddress}}" bindinput="onAddressInput" />
    </view>
    <view class="form-section">
      <text class="form-label">身份证照片<text class="required">*</text></text>
      <view class="id-card-upload">
        <view class="id-card-item" bindtap="uploadIdFront">
          <image wx:if="{{idFront}}" src="{{idFront}}" mode="aspectFill" class="id-image" />
          <view wx:else class="id-placeholder">
            <text class="placeholder-icon">📷</text>
            <text class="placeholder-text">上传身份证人像面</text>
          </view>
          <view class="id-badge" wx:if="{{idFront}}">✓</view>
        </view>
        <view class="id-card-item" bindtap="uploadIdBack">
          <image wx:if="{{idBack}}" src="{{idBack}}" mode="aspectFill" class="id-image" />
          <view wx:else class="id-placeholder">
            <text class="placeholder-icon">📷</text>
            <text class="placeholder-text">上传身份证国徽面</text>
          </view>
          <view class="id-badge" wx:if="{{idBack}}">✓</view>
        </view>
      </view>
      <text class="form-hint">请确保照片清晰，四角完整</text>
    </view>

    <button class="apply-btn {{canApply ? '' : 'disabled'}}" bindtap="applyRider">立即申请</button>
  </view>

  <view class="order-section" wx:if="{{isRider}}">
    <view class="section-header">
      <text class="section-title">待接订单</text>
      <text class="order-count">{{pendingOrders.length}} 单</text>
    </view>
    <view class="order-list" wx:if="{{pendingOrders.length > 0}}">
      <view class="order-card" wx:for="{{pendingOrders}}" wx:key="_id">
        <view class="order-header">
          <text class="order-id">订单号: {{item.orderId}}</text>
          <text class="order-fee">¥{{item.deliveryFee}}</text>
        </view>
        <view class="order-route">
          <view class="route-point">
            <view class="point-tag">取</view>
            <text class="point-text">{{item.fromDorm}} {{item.fromRoom}}</text>
          </view>
          <view class="route-line"></view>
          <view class="route-point">
            <view class="point-tag to">送</view>
            <text class="point-text">{{item.toDorm}} {{item.toRoom}}</text>
          </view>
        </view>
        <view class="order-footer">
          <text class="order-time">{{item.createTime}}</text>
          <view class="order-actions">
            <view class="action-btn reject" catchtap="rejectOrder" data-id="{{item._id}}">拒绝</view>
            <view class="action-btn accept" catchtap="acceptOrder" data-id="{{item._id}}">接单</view>
          </view>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text>暂无待接订单</text>
    </view>
  </view>

  <view class="my-orders" wx:if="{{isRider && myOrders.length > 0}}">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="section-more" bindtap="navigateToDelivery">查看全部</text>
    </view>
    <view class="order-list">
      <view class="order-card" wx:for="{{myOrders}}" wx:key="_id">
        <view class="order-header">
          <text class="order-id">{{item.orderId}}</text>
          <text class="order-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="order-route mini">
          <text class="route-text">{{item.fromDorm}} → {{item.toDorm}}</text>
        </view>
        <view class="order-footer">
          <text class="order-fee">¥{{item.deliveryFee}}</text>
          <view class="action-btn {{item.status === 'picked' ? 'complete' : 'pickup'}}" catchtap="updateOrderStatus" data-id="{{item._id}}" data-status="{{item.status}}">
            {{item.status === 'picked' ? '完成配送' : '已取货'}}
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
