.container {
  min-height: 100vh;
  background: #020208;
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.1),
              0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.search-input input {
  flex: 1;
  font-size: 24rpx;
  color: #f8fafc;
  background: transparent;
  border: none;
  outline: none;
  height: 40rpx;
  line-height: 40rpx;
}

.search-input input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

.search-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.8) 0%, rgba(5, 5, 15, 0.9) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.search-btn-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  padding-bottom: 8rpx;
}

.category-scroll::-webkit-scrollbar {
  display: none;
}

.category-row {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  padding: 16rpx 28rpx;
  background: rgba(5, 5, 15, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.3s;
  white-space: nowrap;
}

.category-item.active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.25) 100%);
  color: #ffffff;
  border: 2rpx solid rgba(186, 85, 211, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4),
              0 0 40rpx rgba(147, 112, 219, 0.2);
  font-weight: 600;
}

.category-item:active {
  transform: scale(0.95);
}

.sort-bar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.sort-item {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.55);
  padding: 10rpx 0;
  transition: all 0.3s;
  position: relative;
}

.sort-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 3rpx;
  background: linear-gradient(90deg, #9370db, #ba55d3);
  border-radius: 2rpx;
  transition: width 0.3s;
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.sort-item.active {
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.sort-item.active::after {
  width: 100%;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.product-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  border-radius: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  transition: all 0.3s;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.product-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.3),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  border-color: rgba(147, 112, 219, 0.5);
}

.product-img {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.15);
}

.product-info {
  padding: 20rpx;
}

.product-title {
  font-size: 28rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.product-location {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
}

.product-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.8;
  filter: drop-shadow(0 0 20rpx rgba(147, 112, 219, 0.5));
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
  line-height: 1.5;
  padding: 0 48rpx;
}

.loading-more {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

.loading-spinner {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(147, 112, 219, 0.2);
  border-top-color: rgba(147, 112, 219, 0.8);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
  vertical-align: middle;
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.no-more {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.45);
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}





