.container {
  min-height: 100vh;
  background: #020208;
  padding: 40rpx 24rpx;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  animation: backgroundMove 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
  position: relative;
  z-index: 1;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFA0B4 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 48rpx rgba(123, 104, 238, 0.3);
  animation: logoFloat 3s ease-in-out infinite;
  position: relative;
  overflow: hidden;
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.logo-wrap::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: logoShine 3s ease-in-out infinite;
}

@keyframes logoShine {
  0%, 100% { transform: rotate(0deg); }
  50% { transform: rotate(180deg); }
}

.logo-text {
  font-size: 56rpx;
  font-weight: 800;
  color: #020617;
  position: relative;
  z-index: 1;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;  

  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(147, 112, 219, 0.3);
  animation: fadeInDown 0.8s ease-out;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 16rpx;
  animation: fadeInDown 0.8s ease-out 0.2s both;
}

.version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.intro-section, .feature-section, .value-section, .contact-section {
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;  

  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #FFB6C1;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  left: 16rpx;
  bottom: -8rpx;
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, #FFB6C1 0%, transparent 100%);
}

.intro-content {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.intro-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.intro-content:hover::before {
  opacity: 1;
}

.intro-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.8;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.intro-text:last-child {
  margin-bottom: 0;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.feature-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(123, 104, 238, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.feature-item:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.feature-item:active::before {
  opacity: 1;
}

.feature-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.2) 0%, rgba(147, 112, 219, 0.15) 100%);
  border-radius: 20rpx;
  font-size: 36rpx;
  margin-right: 20rpx;
  border: 1rpx solid rgba(123, 104, 238, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(123, 104, 238, 0.2);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.feature-icon::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: iconShine 3s ease-in-out infinite;
}

@keyframes iconShine {
  0%, 100% { transform: rotate(0deg); }
  50% { transform: rotate(180deg); }
}

.feature-info {
  flex: 1;
  position: relative;
  z-index: 1;
}

.feature-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 4rpx;
  letter-spacing: 0.5rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

.value-list {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.value-item {
  flex: 1;
  min-width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.value-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.value-item:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.3);
}

.value-item:active::before {
  opacity: 1;
}

.value-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  color: #ffffff;  

  position: relative;
  z-index: 1;
}

.value-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 8rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.value-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.contact-list {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border-radius: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.contact-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.03) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.contact-item:active::before {
  opacity: 1;
}

.contact-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 1;
}

.contact-value {
  font-size: 28rpx;
  color: #c8a2ff;
  font-weight: 500;
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
}

.contact-item:active .contact-value {
  color: #60a5fa;
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
  position: relative;
  z-index: 1;
}

.copyright {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.rights {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 0.5rpx;
}

