.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
  padding-bottom: 120rpx;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
}

.target-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 182, 193, 0.15);
}

.target-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.target-info {
  flex: 1;
}

.target-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 4rpx;
}

.target-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 16rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 182, 193, 0.15);
  min-width: 140rpx;
}

.type-item.active {
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.3) 0%, rgba(255, 160, 180, 0.2) 100%);
  border-color: rgba(255, 182, 193, 0.5);
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 24rpx;
  color: #f8fafc;
}

.desc-input {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 182, 193, 0.15);
  color: #f8fafc;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.image-section {
  margin-bottom: 24rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(239, 68, 68, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.add-image-btn {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 12rpx;
  border: 1rpx dashed rgba(255, 182, 193, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
}

.add-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.4) 0%, rgba(255, 160, 180, 0.3) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 182, 193, 0.5);
  text-align: center;
}

.submit-btn.disabled {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

.submit-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.submit-btn.disabled text {
  color: rgba(255, 255, 255, 0.4);
}





