<view class="container particle-bg">
  <view class="search-header">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索盲盒、商品、用户..." value="{{keyword}}" bindinput="onInput" bindconfirm="doSearch" focus="{{true}}" />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="clearKeyword">×</text>
    </view>
    <text class="cancel-btn" bindtap="goBack">取消</text>
  </view>

  <view class="history-section" wx:if="{{!hasSearched && historyList.length > 0}}">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-history" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view class="history-item" wx:for="{{historyList}}" wx:key="index" bindtap="searchHistory" data-keyword="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="hot-section" wx:if="{{!hasSearched}}">
    <text class="section-title">热门搜索</text>
    <view class="hot-list">
      <view class="hot-item" wx:for="{{hotKeywords}}" wx:key="index" bindtap="searchHistory" data-keyword="{{item}}">
        <text class="hot-rank {{index < 3 ? 'top' : ''}}">{{index + 1}}</text>
        <text class="hot-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="search-tabs" wx:if="{{hasSearched}}">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="setTab" data-tab="all">全部</view>
    <view class="tab-item {{activeTab === 'box' ? 'active' : ''}}" bindtap="setTab" data-tab="box">盲盒</view>
    <view class="tab-item {{activeTab === 'product' ? 'active' : ''}}" bindtap="setTab" data-tab="product">商品</view>
    <view class="tab-item {{activeTab === 'user' ? 'active' : ''}}" bindtap="setTab" data-tab="user">用户</view>
  </view>

  <view class="result-list" wx:if="{{hasSearched && results.length > 0}}">
    <view class="result-card" wx:for="{{results}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}" data-type="{{item.type}}">
      <image class="result-img" src="{{item.images[0]}}" mode="aspectFill" />
      <view class="result-info">
        <text class="result-title">{{item.title}}</text>
        <text class="result-desc">{{item.school}} · {{item.typeName}}</text>
        <text class="result-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <view class="user-list" wx:if="{{hasSearched && activeTab === 'user' && users.length > 0}}">
    <view class="user-card" wx:for="{{users}}" wx:key="_id" bindtap="navigateToUser" data-id="{{item._id}}">
      <image class="user-avatar" src="{{item.avatar}}" mode="aspectFill" />
      <view class="user-info">
        <text class="user-name">{{item.nickName}}</text>
        <text class="user-school">{{item.school}}</text>
      </view>
      <view class="follow-btn">关注</view>
    </view>
  </view>

  <view class="empty" wx:if="{{hasSearched && results.length === 0 && users.length === 0}}">
    <text>未找到相关结果</text>
  </view>
</view>
