<view class="container particle-bg">
  <!-- AI助手信息 -->
  <view class="ai-header">
    <view class="ai-avatar">艾</view>
    <view class="ai-info">
      <text class="ai-name">艾米助手</text>
      <text class="ai-desc">你的校园智能助手</text>
    </view>
    <view class="ai-status">
      <view class="status-dot"></view>
      <text>在线</text>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view class="chat-container" scroll-y scroll-into-view="{{scrollToView}}">
    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="message-item {{item.type === 'user' ? 'user-message' : 'ai-message'}}">
      <view class="message-avatar ai-avatar-icon" wx:if="{{item.type === 'ai'}}">艾</view>
      <view class="message-avatar user-avatar" wx:if="{{item.type === 'user'}}">
        <image src="{{userInfo.avatarUrl || 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=user%20avatar%20icon%20simple%20style&image_size=square'}}" mode="aspectFill" />
      </view>
      <view class="message-content">
        <view class="message-bubble">
          {{item.content}}
          <view class="message-action" wx:if="{{item.showAction}}" bindtap="onMessageAction" data-index="{{index}}">
            <text class="action-text">{{item.actionText}}</text>
          </view>
        </view>
        <text class="message-time">{{item.time}}</text>
      </view>
    </view>
    
    <!-- 输入中提示 -->
    <view class="message-item ai-message" wx:if="{{loading}}">
      <view class="message-avatar ai-avatar-icon">艾</view>
      <view class="message-bubble typing">
        <view class="typing-indicator">
          <text class="dot">.</text>
          <text class="dot">.</text>
          <text class="dot">.</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷问题 -->
  <view class="quick-section" wx:if="{{!loading && showQuickSection && messages.length <= 3}}">
    <text class="quick-title">你可以问我：</text>
    <view class="quick-list">
      <view class="quick-item" bindtap="quickQuestion" data-question="如何发布盲盒？">如何发布盲盒？</view>
      <view class="quick-item" bindtap="quickQuestion" data-question="捐赠规则是什么？">捐赠规则是什么？</view>
      <view class="quick-item" bindtap="quickQuestion" data-question="配送费用怎么计算？">配送费用怎么计算？</view>
      <view class="quick-item" bindtap="quickQuestion" data-question="如何成为骑手？">如何成为骑手？</view>
      <view class="quick-item" bindtap="quickQuestion" data-question="怎么发布需求？">怎么发布需求？</view>
      <view class="quick-item" bindtap="quickQuestion" data-question="如何赚钱？">如何赚钱？</view>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-container">
    <input class="chat-input" placeholder="输入你的问题..." bindinput="onInputChange" value="{{inputValue}}" bindconfirm="sendMessage" confirm-type="send" />
    <view class="send-btn {{inputValue ? 'active' : ''}}" bindtap="sendMessage">发送</view>
  </view>
</view>
