.container {
  min-height: 100vh;
  background: #020208;
  display: flex;
  flex-direction: column;
  position: relative;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* AI头部信息 */
.ai-header {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 1;
  border-radius: 32rpx 32rpx 0 0;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.ai-header::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.ai-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.85) 100%);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(139, 92, 246, 0.4);
  position: relative;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.ai-avatar text {
  font-size: 52rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
  position: relative;
  z-index: 2;
}

@keyframes brandGlow {
  0%, 100% {
    text-shadow: 
      0 0 10rpx rgba(147, 112, 219, 0.8),
      0 0 20rpx rgba(147, 112, 219, 0.6),
      0 0 30rpx rgba(147, 112, 219, 0.4),
      0 0 40rpx rgba(186, 85, 211, 0.3);
  }
  50% {
    text-shadow: 
      0 0 15rpx rgba(147, 112, 219, 1),
      0 0 30rpx rgba(147, 112, 219, 0.8),
      0 0 45rpx rgba(147, 112, 219, 0.6),
      0 0 60rpx rgba(186, 85, 211, 0.4);
  }
}

.ai-avatar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.3);
  animation: pulse-ring 2.5s ease-out infinite;
  z-index: -1;
}

.ai-avatar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.2);
  animation: pulse-ring 2.5s ease-out infinite 0.5s;
  z-index: -1;
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
  }
  80%, 100% {
    opacity: 0;
    transform: scale(1.5);
  }
}

.ai-info {
  flex: 1;
}

.ai-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 8rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.ai-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.ai-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 28rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c8a2ff 0%, #f0abfc 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 1), 0 0 30rpx rgba(240, 171, 252, 0.8), inset 0 1rpx 3rpx rgba(255, 255, 255, 0.6);
  animation: livePulse 1.2s ease-in-out infinite;
  border: 3rpx solid rgba(255, 255, 255, 0.4);
}

.ai-status text {
  font-size: 24rpx;
  color: #c8a2ff;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

@keyframes livePulse {
  0%, 100% { 
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 0 20rpx rgba(200, 162, 255, 1), 0 0 30rpx rgba(240, 171, 252, 0.8);
  }
  50% { 
    opacity: 0.8;
    transform: scale(1.4);
    box-shadow: 0 0 25rpx rgba(200, 162, 255, 1), 0 0 40rpx rgba(240, 171, 252, 1);
  }
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}

/* 聊天区域 */
.chat-container {
  flex: 1;
  padding: 24rpx;
  position: relative;
  z-index: 1;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  animation: fadeIn 0.3s ease-out;
  width: 100%;
}

.user-message {
  align-items: flex-start;
  flex-direction: row-reverse;
  padding-right: 16rpx;
  box-sizing: border-box;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.ai-message {
  align-items: flex-start;
  padding-left: 16rpx;
  box-sizing: border-box;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.ai-message .message-avatar {
  margin-right: 24rpx;
}

.message-avatar.ai-avatar-icon {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.85) 100%);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(139, 92, 246, 0.4);
  position: relative;
  overflow: hidden;
}

.message-avatar.ai-avatar-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.3);
  animation: pulse-ring 2.5s ease-out infinite;
  z-index: -1;
}

.message-avatar.ai-avatar-icon::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.2);
  animation: pulse-ring 2.5s ease-out infinite 0.5s;
  z-index: -1;
}

.user-message .message-avatar {
  margin-left: 24rpx;
  margin-right: 8rpx;
}

.user-message .message-content {
  margin-right: 16rpx;
}

.ai-message .message-content {
  margin-left: 8rpx;
}

.user-avatar {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.85) 100%);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(139, 92, 246, 0.4);
  padding: 4rpx;
  position: relative;
  overflow: hidden;
}

.user-avatar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.3);
  animation: pulse-ring 2.5s ease-out infinite;
  z-index: -1;
}

.user-avatar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.2);
  animation: pulse-ring 2.5s ease-out infinite 0.5s;
  z-index: -1;
}

.user-avatar image {
  border-radius: 50%;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.message-content {
  max-width: 70%;
}

.message-bubble {
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-wrap: break-word;
  position: relative;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
  overflow: hidden;
}

.ai-message .message-bubble {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  color: rgba(255, 255, 255, 0.9);
  border-top-left-radius: 12rpx;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15);
}

.user-message .message-bubble {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  color: rgba(255, 255, 255, 0.9);
  border-top-right-radius: 12rpx;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15);
}

/* 消息中的操作按钮 */
.message-action {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.action-text {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0.1) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.action-text:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.2);
}

.message-time {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 12rpx;
  text-align: right;
}

.ai-message .message-time {
  text-align: left;
}

/* 输入中动画 */
.typing {
  padding: 24rpx 32rpx;
}

.typing-indicator {
  display: flex;
  gap: 12rpx;
}

.dot {
  font-size: 40rpx;
  color: rgba(147, 112, 219, 0.8);
  animation: typing 1.4s ease-in-out infinite;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
  30% { opacity: 1; transform: translateY(-10rpx); }
}

/* 快捷问题 */
.quick-section {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(15rpx);
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

@keyframes fadeInDown {
  from { 
    opacity: 0; 
    transform: translateY(-10rpx);
  }
  to { 
    opacity: 1; 
    transform: translateY(0);
  }
}

.quick-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.1);
}

.quick-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.25) 0%, rgba(186, 85, 211, 0.2) 100%);
  border-color: rgba(147, 112, 219, 0.45);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.3);
}

/* 输入区域 */
.input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-top: 2rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.input-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  animation: inputBorderGlow 3s ease-in-out infinite;
}

@keyframes inputBorderGlow {
  0%, 100% {
    box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  }
  50% {
    box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.8);
  }
}

.chat-input {
  flex: 1;
  height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.1);
  transition: all 0.3s ease;
}

.chat-input:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.2);
}

.chat-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.send-btn {
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 600;
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.15);
  position: relative;
  overflow: hidden;
}

.send-btn.active {
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  color: #fff;
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 0 90rpx rgba(186, 85, 211, 0.25);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
}

.send-btn.active::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 46rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.send-btn.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.send-btn:active {
  transform: scale(0.95);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .ai-avatar {
    width: 80rpx;
    height: 80rpx;
    font-size: 40rpx;
  }
  
  .message-avatar {
    width: 64rpx;
    height: 64rpx;
    font-size: 32rpx;
  }
  
  .message-content {
    max-width: 75%;
  }
  
  .message-bubble {
    padding: 20rpx 28rpx;
    font-size: 26rpx;
  }
}

@media (min-width: 414px) {
  .ai-avatar {
    width: 120rpx;
    height: 120rpx;
    font-size: 60rpx;
  }
  
  .message-avatar {
    width: 96rpx;
    height: 96rpx;
    font-size: 48rpx;
  }
  
  .message-content {
    max-width: 65%;
  }
  
  .message-bubble {
    padding: 28rpx 36rpx;
    font-size: 30rpx;
  }
}





