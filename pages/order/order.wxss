/* 订单页面 - 紫色霓虹灯风格*/

.container {
  min-height: 100vh;
  background: #020208;
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 页面标题 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
}

.page-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(147, 112, 219, 0.5) 50%, transparent 100%);
}

.stat-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.stat-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 筛选Tab */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.tab-item {
  flex: 1;
  padding: 20rpx 0;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  text-align: center;
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.tab-item.active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  border-color: rgba(186, 85, 211, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4),
              0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.tab-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #c8a2ff;
  font-weight: 600;
  text-shadow: 0 0 15rpx rgba(200, 162, 255, 0.5);
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.4);
}

/* 订单列表 */
.order-list {
  position: relative;
  z-index: 1;
}

.order-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(20rpx);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.5s ease-out;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.6),
              0 0 20rpx rgba(147, 112, 219, 0.15);
  position: relative;
}

.order-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
  z-index: 2;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.order-card:active {
  opacity: 0.9;
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.2);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.order-info-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 0.5rpx;
}

.order-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 状态标�?*/
.status-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.1); }
}

.status-badge.pending {
  background: rgba(245, 158, 11, 0.15);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.status-badge.pending .status-text {
  color: #fbbf24;
}

.status-badge.pending .status-dot {
  background: #fbbf24;
}

.status-badge.delivering {
  background: rgba(59, 130, 246, 0.15);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.status-badge.delivering .status-text {
  color: #60a5fa;
}

.status-badge.delivering .status-dot {
  background: #60a5fa;
}

.status-badge.completed {
  background: rgba(34, 197, 94, 0.15);
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.status-badge.completed .status-text {
  color: #4ade80;
}

.status-badge.completed .status-dot {
  background: #4ade80;
}

.status-badge.cancelled {
  background: rgba(239, 68, 68, 0.15);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.status-badge.cancelled .status-text {
  color: #f87171;
}

.status-badge.cancelled .status-dot {
  background: #f87171;
}

/* 订单内容 */
.order-body {
  padding: 24rpx;
}

/* 商品区域 */
.product-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.product-image-wrap {
  position: relative;
  flex-shrink: 0;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(236, 72, 153, 0.08) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.product-count {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(139, 92, 246, 0.4);
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 14rpx;
  background: rgba(139, 92, 246, 0.15);
  border: 1rpx solid rgba(139, 92, 246, 0.2);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #a78bfa;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.meta-icon {
  font-size: 24rpx;
}

/* 价格区域 */
.price-section {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.price-row:last-child {
  margin-bottom: 0;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.price-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.price-value {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.price-total {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 订单底部 */
.order-footer {
  padding: 20rpx 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.delivery-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 12rpx;
}

.rider-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.rider-name {
  font-size: 28rpx;
  color: #f8fafc;
  font-weight: 500;
}

.delivery-status {
  margin-left: auto;
  font-size: 24rpx;
  color: #60a5fa;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.btn-primary {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.btn-secondary {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #c8a2ff;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.1);
}

.btn-secondary:active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.3);
}

/* 加载状�?*/
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  position: relative;
  z-index: 1;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(139, 92, 246, 0.2);
  border-top-color: rgba(139, 92, 246, 0.8);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 空状�?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
  text-align: center;
}

.empty-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  border: none;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
}

.empty-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.empty-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

/* 底部安全区域 */
.safe-area {
  height: 40rpx;
}





