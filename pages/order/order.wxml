<view class="container particle-bg">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">我的订单</text>
    <text class="page-subtitle">共 {{orders.length}} 个订单</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.pending}}</text>
      <text class="stat-label">待发货</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.delivering}}</text>
      <text class="stat-label">配送中</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view class="tab-item {{activeStatus === 'all' ? 'active' : ''}}" bindtap="setStatus" data-status="all">
      <text class="tab-text">全部</text>
      <view class="tab-badge" wx:if="{{counts.all > 0}}">{{counts.all}}</view>
    </view>
    <view class="tab-item {{activeStatus === 'pending' ? 'active' : ''}}" bindtap="setStatus" data-status="pending">
      <text class="tab-text">待发货</text>
      <view class="tab-badge" wx:if="{{counts.pending > 0}}">{{counts.pending}}</view>
    </view>
    <view class="tab-item {{activeStatus === 'delivering' ? 'active' : ''}}" bindtap="setStatus" data-status="delivering">
      <text class="tab-text">配送中</text>
      <view class="tab-badge" wx:if="{{counts.delivering > 0}}">{{counts.delivering}}</view>
    </view>
    <view class="tab-item {{activeStatus === 'completed' ? 'active' : ''}}" bindtap="setStatus" data-status="completed">
      <text class="tab-text">已完成</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-info-row">
          <text class="order-id">订单号: {{item._id}}</text>
          <text class="order-time">{{item.createTime}}</text>
        </view>
        <view class="status-badge {{item.status}}">
          <view class="status-dot"></view>
          <text class="status-text">{{item.statusText}}</text>
        </view>
      </view>

      <!-- 订单内容 -->
      <view class="order-body">
        <view class="product-section">
          <view class="product-image-wrap">
            <image class="product-image" src="{{item.images[0]}}" mode="aspectFill" />
            <view class="product-count" wx:if="{{item.count > 1}}">x{{item.count}}</view>
          </view>
          <view class="product-info">
            <text class="product-title">{{item.title}}</text>
            <view class="product-tags">
              <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="product-meta">
              <text class="meta-item">
                <text class="meta-icon">📍</text>
                <text>{{item.from_dorm}} → {{item.to_dorm}}</text>
              </text>
            </view>
          </view>
        </view>

        <!-- 价格信息 -->
        <view class="price-section">
          <view class="price-row">
            <text class="price-label">商品金额</text>
            <text class="price-value">¥{{item.price}}</text>
          </view>
          <view class="price-row" wx:if="{{item.deliveryFee}}">
            <text class="price-label">配送费</text>
            <text class="price-value">¥{{item.deliveryFee}}</text>
          </view>
          <view class="price-row total">
            <text class="price-label">实付款</text>
            <text class="price-total">¥{{item.totalPrice || item.price}}</text>
          </view>
        </view>
      </view>

      <!-- 订单底部操作栏 -->
      <view class="order-footer">
        <view class="delivery-info" wx:if="{{item.status === 'delivering' && item.rider}}">
          <image class="rider-avatar" src="{{item.rider.avatar}}" />
          <text class="rider-name">{{item.rider.name}}</text>
          <text class="delivery-status">配送中</text>
        </view>
        <view class="action-buttons">
          <view class="btn-secondary" catchtap="contactSeller" data-id="{{item._id}}" wx:if="{{item.status !== 'completed' && item.status !== 'cancelled'}}">
            联系卖家
          </view>
          <view class="btn-secondary" catchtap="viewLogistics" data-id="{{item._id}}" wx:if="{{item.status === 'delivering'}}">
            查看物流
          </view>
          <view class="btn-primary" catchtap="confirmReceive" data-id="{{item._id}}" wx:if="{{item.status === 'delivering'}}">
            确认收货
          </view>
          <view class="btn-primary" catchtap="payOrder" data-id="{{item._id}}" wx:if="{{item.status === 'pending' && !item.paid}}">
            立即支付
          </view>
          <view class="btn-secondary" catchtap="cancelOrder" data-id="{{item._id}}" wx:if="{{item.status === 'pending'}}">
            取消订单
          </view>
          <view class="btn-secondary" catchtap="deleteOrder" data-id="{{item._id}}" wx:if="{{item.status === 'completed' || item.status === 'cancelled'}}">
            删除订单
          </view>
          <view class="btn-primary" catchtap="buyAgain" data-id="{{item._id}}" wx:if="{{item.status === 'completed'}}">
            再次购买
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <view class="empty-icon">📦</view>
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">还没有相关订单，快去逛逛吧</text>
    <view class="empty-btn" bindtap="goShopping">去逛逛</view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area"></view>
</view>
