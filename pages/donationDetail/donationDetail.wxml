<view class="container">
  <view class="image-section">
    <swiper class="image-swiper" indicator-dots="{{item.images.length > 1}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#FFB6C1">
      <swiper-item wx:for="{{item.images}}" wx:key="index">
        <image class="detail-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}" />
      </swiper-item>
    </swiper>
  </view>

  <view class="content-section">
    <view class="header">
      <text class="title">{{item.title}}</text>
      <view class="status-tag {{item.status}}">{{item.statusText}}</view>
    </view>

    <view class="user-card">
      <image class="user-avatar" src="{{item.userAvatar}}" />
      <view class="user-info">
        <text class="user-name">{{item.userName}}</text>
        <text class="user-time">{{item.createTime}}</text>
      </view>
      <view class="follow-btn" bindtap="followUser">
        <text>{{isFollowing ? '已关注' : '关注'}}</text>
      </view>
    </view>

    <view class="info-card">
      <view class="info-row">
        <text class="info-label">分类</text>
        <text class="info-value">{{item.category}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">成色</text>
        <text class="info-value">{{item.condition}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">位置</text>
        <text class="info-value">{{item.location}}</text>
      </view>
      <view class="info-row" wx:if="{{item.deliveryFee > 0}}">
        <text class="info-label">配送费</text>
        <text class="info-value fee">¥{{item.deliveryFee}}</text>
      </view>
    </view>

    <view class="desc-section">
      <text class="section-title">物品描述</text>
      <text class="desc-text">{{item.description}}</text>
    </view>

    <view class="tags-section" wx:if="{{item.tags && item.tags.length > 0}}">
      <view class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="action-bar">
    <view class="action-left">
      <view class="action-item" bindtap="toggleFavorite">
        <text class="action-icon">{{isFavorite ? '♥' : '♡'}}</text>
        <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="action-item" bindtap="navigateToChat">
        <text class="action-icon">✉</text>
        <text class="action-text">私信</text>
      </view>
    </view>
    <view class="action-right">
      <view class="claim-btn {{item.status !== 'pending' ? 'disabled' : ''}}" bindtap="claimDonation">
        <text>{{item.status === 'pending' ? '立即认领' : '已被认领'}}</text>
      </view>
    </view>
  </view>

  <view class="delivery-section" wx:if="{{item.status === 'claimed'}}">
    <view class="section-header">
      <text class="section-title">配送信息</text>
    </view>
    <view class="delivery-card">
      <view class="delivery-status">
        <text class="status-dot {{delivery.status}}"></text>
        <text class="status-text">{{delivery.statusText}}</text>
      </view>
      <view class="delivery-route">
        <view class="route-point">
          <text class="point-tag">取</text>
          <text class="point-text">{{delivery.fromDorm}} {{delivery.fromRoom}}</text>
        </view>
        <view class="route-arrow">→</view>
        <view class="route-point">
          <text class="point-tag to">送</text>
          <text class="point-text">{{delivery.toDorm}} {{delivery.toRoom}}</text>
        </view>
      </view>
      <view class="rider-info" wx:if="{{delivery.riderName}}">
        <image class="rider-avatar" src="{{delivery.riderAvatar}}" />
        <text class="rider-name">{{delivery.riderName}}</text>
        <text class="rider-level">Lv.{{delivery.riderLevel}}</text>
      </view>
    </view>
  </view>

  <view class="similar-section">
    <view class="section-header">
      <text class="section-title">相似捐赠</text>
      <text class="section-more" bindtap="navigateToDonation">查看更多</text>
    </view>
    <scroll-view class="similar-scroll" scroll-x>
      <view class="similar-list">
        <view class="similar-card" wx:for="{{similarItems}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}">
          <image class="similar-image" src="{{item.images[0]}}" mode="aspectFill" />
          <text class="similar-title">{{item.title}}</text>
          <text class="similar-location">{{item.location}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>