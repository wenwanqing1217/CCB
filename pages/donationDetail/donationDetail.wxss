.container {
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #020208 0%, #050510 100%);
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 30%, rgba(147, 112, 219, 0.08) 0%, transparent 50%),
              radial-gradient(circle at 70% 70%, rgba(186, 85, 211, 0.05) 0%, transparent 50%);
  animation: backgroundMove 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

.image-section {
  width: 100%;
  height: 600rpx;
  position: relative;
  z-index: 1;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.detail-image{
  width: 100%;
  height: 100%;
  border-radius: 0 0 24rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.content-section{
  padding: 24rpx;
  position: relative;
  z-index: 1;
}

.header{
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.title{
  flex: 1;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;  

  line-height: 1.4;
  margin-right: 16rpx;
}

.status-tag{
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid transparent;
  transition: all 0.3s ease;
}

.status-tag.pending{
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.2) 0%, rgba(147, 112, 219, 0.2) 100%);
  color: #FFB6C1;
  border-color: rgba(123, 104, 238, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(123, 104, 238, 0.2);
}

.status-tag.claimed{
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
  color: #3b82f6;
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
}

.status-tag.completed{
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(16, 185, 129, 0.2) 100%);
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

.user-card{
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 24rpx;
}

.user-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 0 40rpx rgba(147, 112, 219, 0.3);
}

.user-card:active::before {
  opacity: 1;
}

.user-avatar{
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #9370db;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
}

.user-info{
  flex: 1;
  position: relative;
  z-index: 1;
}

.user-name{
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

  margin-bottom: 4rpx;
}

.user-time{
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.follow-btn{
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  backdrop-filter: blur(10rpx);
  color: #f8fafc;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.follow-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.follow-btn:active::before {
  left: 100%;
}

.follow-btn:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 24rpx rgba(123, 104, 238, 0.3);
}

.info-card{
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.info-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 24rpx;
}

.info-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.info-card:active::before {
  opacity: 1;
}

.info-row{
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 1;
}

.info-row:last-child{
  border-bottom: none;
}

.info-label{
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.info-value{
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

}

.info-value.fee{
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  font-weight: 700;
}

.desc-section{
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.section-title{
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;  

  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.desc-text{
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  background: rgba(255, 255, 255, 0.03);
  padding: 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.tags-section{
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.tag{
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(10rpx);
  color: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  font-size: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.tag::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.tag:active::before {
  left: 100%;
}

.tag:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-color: rgba(147, 112, 219, 0.3);
  color: #f8fafc;
}

.action-bar{
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, rgba(10, 10, 26, 0.95) 0%, rgba(2, 6, 23, 0.95) 100%);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(147, 112, 219, 0.2);
  box-shadow: 0 -8rpx 32rpx rgba(147, 112, 219, 0.2);
  box-sizing: border-box;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.action-left{
  display: flex;
  gap: 40rpx;
}

.action-item{
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon{
  font-size: 40rpx;
  color: #ffffff;  

  margin-bottom: 4rpx;
}

.action-text{
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.action-right{
  flex: 1;
  margin-left: 40rpx;
}

.claim-btn{
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  backdrop-filter: blur(10rpx);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
}

.claim-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.claim-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

.claim-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

.claim-btn.disabled{
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  color: rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: none;
  animation: none;
}

.claim-btn.disabled::before,
.claim-btn.disabled::after {
  display: none;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.delivery-section{
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.section-header{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-more{
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  transition: color 0.3s ease;
}

.section-more:active {
  color: #f8fafc;
}

.delivery-card{
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.delivery-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 24rpx;
}

.delivery-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.delivery-card:active::before {
  opacity: 1;
}

.delivery-status{
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.status-dot{
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.status-dot.delivering{
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.5);
  }
  50% {
    transform: scale(1.2);
    box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.7);
  }
}

.status-dot.completed{
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  box-shadow: 0 0 12rpx rgba(34, 197, 94, 0.5);
}

.status-text{
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

}

.delivery-route{
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.delivery-route:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-color: rgba(147, 112, 219, 0.3);
}

.route-point{
  display: flex;
  align-items: center;
  flex: 1;
}

.point-tag{
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.5) 0%, rgba(147, 112, 219, 0.4) 100%);
  color: #f8fafc;
  border-radius: 10rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  font-weight: 600;
  border: 1rpx solid rgba(123, 104, 238, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(123, 104, 238, 0.2);
  transition: all 0.3s ease;
}

.point-tag.to{
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.5) 0%, rgba(16, 185, 129, 0.4) 100%);
  color: #f8fafc;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.2);
}

.point-text{
  font-size: 24rpx;
  font-weight: 500;
  color: #ffffff;  

  line-height: 1.4;
}

.route-arrow{
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  font-size: 24rpx;
  margin: 0 16rpx;
}

.rider-info{
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.rider-avatar{
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #c8a2ff;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
}

.rider-name{
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

  margin-right: 12rpx;
}

.rider-level{
  font-size: 24rpx;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  font-weight: 500;
}

.similar-section{
  padding: 0 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.similar-scroll{
  width: 100%;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}

.similar-scroll::-webkit-scrollbar {
  display: none;
}

.similar-list{
  display: flex;
  gap: 20rpx;
  padding: 0 4rpx;
}

.similar-card{
  width: 200rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.5s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.similar-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.similar-image{
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx 16rpx 0 0;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: transform 0.3s ease;
}

.similar-card:active .similar-image {
  transform: scale(1.05);
}

.similar-content {
  padding: 16rpx;
}

.similar-title{
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;  

  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.similar-location{
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}


