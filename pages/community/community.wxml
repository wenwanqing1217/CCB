<view class="container particle-bg">
  <!-- 顶部背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle circle-1"></view>
    <view class="bg-circle circle-2"></view>
    <view class="bg-circle circle-3"></view>
  </view>

  <!-- 功能入口卡片 -->
  <view class="feature-cards">
    <view class="feature-card donation" bindtap="navigateToDonationList">
      <view class="card-glow"></view>
      <view class="card-content">
        <view class="card-icon-wrap">
          <text class="card-icon">🎁</text>
        </view>
        <view class="card-info">
          <text class="card-title">免费送</text>
          <text class="card-desc">闲置好物免费赠</text>
        </view>
        <view class="card-arrow">›</view>
      </view>
      <view class="card-wave"></view>
    </view>

    <view class="feature-card exchange" bindtap="navigateToExchangeList">
      <view class="card-glow"></view>
      <view class="card-content">
        <view class="card-icon-wrap">
          <text class="card-icon">🔄</text>
        </view>
        <view class="card-info">
          <text class="card-title">以物换物</text>
          <text class="card-desc">物物交换不花钱</text>
        </view>
        <view class="card-arrow">›</view>
      </view>
      <view class="card-wave"></view>
    </view>
  </view>

  <!-- 最新动态 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="title-dot"></view>
        <text class="section-title">最新动态</text>
      </view>
      <view class="view-more-link" bindtap="navigateToExchangeList">
        <text>去以物换物</text>
        <text class="arrow">→</text>
      </view>
    </view>

    <!-- 免费送列表 -->
    <view class="content-list">
      <view class="donation-item" wx:for="{{donationItems}}" wx:key="_id" bindtap="navigateToDonationDetail" data-id="{{item._id}}">
        <view class="item-image-wrap">
          <image class="item-image" src="{{item.images[0]}}" mode="aspectFill" />
          <view class="item-badge" wx:if="{{item.isNew}}">NEW</view>
        </view>
        <view class="item-body">
          <text class="item-title">{{item.title}}</text>
          <view class="item-tags">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
          </view>
          <view class="item-footer">
            <view class="user-info">
              <image class="user-avatar" src="{{item.userAvatar}}" />
              <text class="user-name">{{item.userName}}</text>
            </view>
            <view class="item-meta">
              <text class="meta-item">📍 {{item.location}}</text>
              <text class="meta-item">⏱ {{item.createTime}}</text>
            </view>
          </view>
        </view>
        <view class="item-status {{item.status}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>

      <!-- 查看更多 -->
      <view class="view-more" bindtap="navigateToDonationList">
        <text>查看更多免费送</text>
        <text class="arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 爱心值统计 -->
  <view class="love-stats-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="title-dot pink"></view>
        <text class="section-title">爱心传递</text>
      </view>
      <text class="section-subtitle">每一次捐赠和交换，都是一份温暖</text>
    </view>

    <view class="love-stats">
      <view class="stat-card">
        <text class="stat-num">{{lovePoints}}</text>
        <text class="stat-label">我的爱心值</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{totalDonations}}</text>
        <text class="stat-label">累计捐赠</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{totalExchanges}}</text>
        <text class="stat-label">成功交换</text>
      </view>
    </view>
  </view>

  <!-- 爱心榜 -->
  <view class="section rank-section">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="title-dot gold"></view>
        <text class="section-title">爱心榜</text>
      </view>
      <text class="section-subtitle">本周贡献排行</text>
    </view>

    <view class="rank-list">
      <view class="rank-item {{index < 3 ? 'top' : ''}}" wx:for="{{loveRank}}" wx:key="_id">
        <view class="rank-num {{index < 3 ? 'top-' + (index + 1) : ''}}">
          <text wx:if="{{index < 3}}">{{['🥇','🥈','🥉'][index]}}</text>
          <text wx:else>{{index + 1}}</text>
        </view>
        <view class="rank-avatar-wrap">
          <image class="rank-avatar" src="{{item.avatar}}" />
          <view class="rank-crown" wx:if="{{index === 0}}">👑</view>
        </view>
        <view class="rank-info">
          <text class="rank-name">{{item.name}}</text>
          <view class="rank-stats">
            <text class="rank-stat">{{item.points}}爱心</text>
          </view>
        </view>
        <view class="rank-score">
          <text class="score-num">{{item.points}}</text>
          <text class="score-label">爱心值</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 社区公告 -->
  <view class="notice-bar">
    <view class="notice-icon">📢</view>
    <swiper class="notice-swiper" vertical autoplay circular interval="3000">
      <swiper-item wx:for="{{notices}}" wx:key="*this">
        <text class="notice-text">{{item}}</text>
      </swiper-item>
    </swiper>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area"></view>

  <!-- 发布按钮 - 可拖动 -->
  <view class="publish-btn" 
        style="left: {{publishBtnPosition.x}}px; top: {{publishBtnPosition.y}}px;"
        bindtouchstart="onPublishBtnTouchStart"
        bindtouchmove="onPublishBtnTouchMove"
        bindtouchend="onPublishBtnTouchEnd">
    <text class="btn-icon">+</text>
  </view>

  <!-- 发布菜单弹窗 -->
  <view class="publish-modal {{showPublishMenu ? 'show' : ''}}" bindtap="hidePublishMenu">
    <view class="modal-mask"></view>
    <view class="modal-content" catchtap="preventHide">
      <view class="modal-title">选择发布类型</view>
      <view class="menu-grid">
        <view class="menu-item donation" bindtap="navigateToPublishDonation">
          <view class="menu-icon">🎁</view>
          <text class="menu-name">免费送</text>
          <text class="menu-desc">闲置物品免费赠送</text>
        </view>
        <view class="menu-item exchange" bindtap="navigateToPublishExchange">
          <view class="menu-icon">🔄</view>
          <text class="menu-name">以物换物</text>
          <text class="menu-desc">发布交换需求</text>
        </view>
      </view>
      <view class="modal-close" bindtap="hidePublishMenu">
        <text>取消</text>
      </view>
    </view>
  </view>
</view>
