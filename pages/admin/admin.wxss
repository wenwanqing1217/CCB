.container {
  padding: 32rpx 24rpx;
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  animation: backgroundMove 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

.page-header {
  padding: 32rpx 0 24rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;  

  letter-spacing: 1rpx;
  text-shadow: 0 4rpx 12rpx rgba(147, 112, 219, 0.3);
  animation: fadeInDown 0.8s ease-out;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.nav {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  overflow-x: auto;
  padding: 8rpx 0;
  position: relative;
  z-index: 1;
}

.nav::-webkit-scrollbar {
  display: none;
}

.nav-item {
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.nav-item.active {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: #ffffff;
  border-color: transparent;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.user-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.user-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.user-card:active::before {
  opacity: 1;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  margin-right: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  color: #c8a2ff;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.2);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.user-avatar::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: avatarShine 3s ease-in-out infinite;
}

@keyframes avatarShine {
  0%, 100% { transform: rotate(0deg); }
  50% { transform: rotate(180deg); }
}

.user-info {
  flex: 1;
  position: relative;
  z-index: 1;
}

.user-nickname {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 8rpx;
  letter-spacing: 0.3rpx;
}

.user-role {
  display: block;
  font-size: 24rpx;
  color: #c8a2ff;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.user-dorm {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.user-actions {
  margin-left: 20rpx;
  position: relative;
  z-index: 1;
}

.box-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.box-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.box-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(123, 104, 238, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.box-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.box-card:active::before {
  opacity: 1;
}

.box-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 10rpx;
  letter-spacing: 0.3rpx;
  position: relative;
  z-index: 1;
}

.box-price {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  margin-bottom: 10rpx;
  letter-spacing: -0.5rpx;
  position: relative;
  z-index: 1;
}

.box-status {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.box-actions {
  display: flex;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.merchant-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.merchant-card {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.merchant-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(123, 104, 238, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.merchant-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.merchant-card:active::before {
  opacity: 1;
}

.merchant-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.merchant-info {
  flex: 1;
}

.merchant-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.merchant-category {
  display: block;
  font-size: 24rpx;
  color: #c8a2ff;
  font-weight: 500;
}

.merchant-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid transparent;
  transition: all 0.3s ease;
}

.merchant-status.pending {
  background: rgba(251, 191, 36, 0.2);
  color: #fbbf24;
  border-color: rgba(251, 191, 36, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.2);
}

.merchant-status.approved {
  background: rgba(34, 197, 94, 0.2);
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

.merchant-status.rejected {
  background: rgba(239, 68, 68, 0.2);
  color: #ef4444;
  border-color: rgba(239, 68, 68, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.2);
}

.merchant-detail {
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.detail-item {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.merchant-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 1;
}

.reject-reason {
  font-size: 28rpx;
  color: #ef4444;
  position: relative;
  z-index: 1;
}

.donation-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.donation-card {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.donation-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.donation-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.donation-card:active::before {
  opacity: 1;
}

.donation-box {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 10rpx;
  letter-spacing: 0.3rpx;
  position: relative;
  z-index: 1;
}

.donation-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
}

.donation-status {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  color: #c8a2ff;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(147, 112, 219, 0.2);
  position: relative;
  z-index: 1;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.stats-item {
  padding: 32rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.stats-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.stats-item:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.stats-item:active::before {
  opacity: 1;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.stats-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  letter-spacing: -0.5rpx;
  position: relative;
  z-index: 1;
  font-variant-numeric: tabular-nums;
}

.action-btn {
  padding: 14rpx 28rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
}

.action-btn.primary {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.2);
}

.action-btn.danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.2);
}

.action-btn.secondary {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  color: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.action-btn.info {
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.2);
}

.action-btn:active {
  transform: scale(0.95);
}

.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 160rpx 0;
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 100;
  backdrop-filter: blur(10rpx);
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.9) 0%, rgba(22, 33, 62, 0.8) 50%, rgba(15, 52, 96, 0.7) 100%);
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.5);
  animation: modalFadeIn 0.3s ease;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;  

}

.modal-body {
  padding: 32rpx;
}

.reject-input {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 20rpx;
  color: #f8fafc;
  font-size: 28rpx;
  box-sizing: border-box;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
  resize: none;
}

.reject-input:focus {
  border-color: rgba(239, 68, 68, 0.5);
  box-shadow: 0 0 16rpx rgba(239, 68, 68, 0.2);
}

.reject-input::placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  background: transparent;
  border: none;
  border-radius: 0;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.modal-btn.cancel {
  color: rgba(255, 255, 255, 0.6);
  border-right: 1rpx solid rgba(255, 255, 255, 0.05);
}

.modal-btn.confirm {
  color: #c8a2ff;
  font-weight: 600;
}

.modal-btn:active {
  background: rgba(255, 255, 255, 0.03);
}

