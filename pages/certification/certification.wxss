/* 认证页面 - 紫色霓虹灯风格 */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #020208;
  box-sizing: border-box;
}

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 权益区域 */
.benefit-section {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
}

.benefit-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(147, 112, 219, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
}

.benefit-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 12rpx;
}

.benefit-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.required {
  color: #f87171;
  margin-left: 4rpx;
}

/* 输入框 - 统一高度和样式 */
.form-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  color: #fff;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  outline: none;
}

.form-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 30rpx;
}

/* 学校显示 - 与输入框完全统一 */
.school-display {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.school-name {
  font-size: 30rpx;
  color: #fff;
}

/* 手机号行 */
.phone-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.phone-input {
  flex: 1;
}

.code-btn {
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #fff;
  white-space: nowrap;
  text-align: center;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-btn.disabled {
  background: rgba(147, 112, 219, 0.3);
  color: rgba(255, 255, 255, 0.5);
}

.code-input {
  width: 100%;
}

/* 上传区域 */
.upload-area {
  margin-top: 12rpx;
}

.upload-box {
  width: 100%;
  height: 200rpx;
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx dashed rgba(147, 112, 219, 0.4);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  color: #c8a2ff;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.upload-preview {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(239, 68, 68, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

/* 提交按钮 */
.submit-btn {
  width: calc(100% - 48rpx);
  padding: 24rpx;
  margin: 32rpx 24rpx 0;
  background: rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  box-sizing: border-box;
}

.submit-btn.active {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.4);
}

/* 状态区域 */
.status-section {
  margin-top: 24rpx;
}

.status-card {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
}

.status-card.pending {
  border-color: rgba(251, 191, 36, 0.5);
}

.status-card.approved {
  border-color: rgba(52, 211, 153, 0.5);
}

.status-card.rejected {
  border-color: rgba(239, 68, 68, 0.5);
}

.status-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.status-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
