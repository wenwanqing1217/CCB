<view class="container particle-bg">
  <!-- 骨架屏 -->
  <view class="skeleton" wx:if="{{isLoading}}">
    <view class="skeleton-hero">
      <view class="skeleton-brand"></view>
      <view class="skeleton-slogan"></view>
      <view class="skeleton-stats">
        <view class="skeleton-stat"></view>
        <view class="skeleton-stat"></view>
        <view class="skeleton-stat"></view>
      </view>
    </view>
    <view class="skeleton-search"></view>
    <view class="skeleton-grab"></view>
    <view class="skeleton-actions">
      <view class="skeleton-action"></view>
      <view class="skeleton-action"></view>
      <view class="skeleton-action"></view>
      <view class="skeleton-action"></view>
    </view>
    <view class="skeleton-dorm"></view>
    <view class="skeleton-hot">
      <view class="skeleton-hot-item" wx:for="[1,2,3,4]" wx:key="index"></view>
    </view>
    <view class="skeleton-community">
      <view class="skeleton-feed-item" wx:for="[1,2,3]" wx:key="index"></view>
    </view>
    <view class="skeleton-rider"></view>
  </view>

  <!-- 实际内容 -->
  <view wx:else>
    <view class="hero-section">
      <view class="hero-content">
          <view class="hero-brand">
            <text class="brand-name">CBB</text>
          </view>
          <text class="hero-slogan">让闲置物品流动起来，创造更多价值</text>
          <view class="hero-stats">
            <view class="stat-item">
              <text class="stat-number">{{stats.users}}</text>
              <text class="stat-label">活跃用户</text>
            </view>
            <view class="stat-item">
              <text class="stat-number">{{stats.boxes}}</text>
              <text class="stat-label">盲盒数量</text>
            </view>
            <view class="stat-item">
              <text class="stat-number">{{stats.deliveries}}</text>
              <text class="stat-label">成功配送</text>
            </view>
          </view>
        </view>
    </view>

    <view class="search-bar">
      <view class="search-input">
        <input placeholder="搜索商品、盲盒" bindinput="onSearchInput" bindconfirm="onSearchConfirm" />
        <view class="search-btn" bindtap="onSearchConfirm">
          <text class="search-btn-text">搜索</text>
        </view>
      </view>
    </view>

    <view class="rider-grab-section interactive-card interactive-btn" bindtap="navigateToOrderGrab">
      <view class="grab-content">
        <div class="grab-header">
          <div class="grab-title-section">
            <span class="grab-badge">HOT</span>
            <h3 class="grab-title">校园配送</h3>
          </div>
          <div class="grab-count">
            <span class="count-num">{{pendingOrders}}</span>
            <span class="count-text">单待抢</span>
          </div>
        </div>
        <div class="grab-body">
          <div class="grab-slogan">
            <p class="slogan-text">校园内配送统一1元</p>
            <p class="slogan-sub">随时随地，一键送达</p>
          </div>
          <div class="grab-icon">
            <span class="icon">🛵</span>
          </div>
        </div>
        <div class="grab-action">
          <span class="grab-btn-text">立即抢单赚钱</span>
          <span class="grab-btn-arrow">›</span>
        </div>
      </view>
    </view>

    <view class="quick-actions stagger-enter visible">
      <view class="action-item action-blindbox interactive-card interactive-btn" bindtap="navigateToBlindBox">
        <text class="action-main-title">神秘盲盒</text>
        <text class="action-sub-title">开启惊喜</text>
      </view>
      <view class="action-item action-community interactive-card interactive-btn" bindtap="navigateToCommunity">
        <text class="action-main-title">校园社区</text>
        <text class="action-sub-title">发现精彩</text>
      </view>
      <view class="action-item action-publish interactive-card interactive-btn" bindtap="navigateToPublish">
        <text class="action-main-title">发布物品</text>
        <text class="action-sub-title">轻松变现</text>
      </view>
      <view class="action-item action-rider interactive-card interactive-btn" bindtap="navigateToRider">
        <text class="action-main-title">成为骑手</text>
        <text class="action-sub-title">赚钱收益</text>
      </view>
    </view>

    <view class="dorm-heat-section">
      <view class="section-header">
        <view class="section-title-wrap">
          <text class="section-title">宿舍楼热度</text>
          <view class="live-badge">
            <view class="live-dot"></view>
            <text>实时</text>
          </view>
        </view>
        <text class="section-desc">{{dormHeatLabel}}</text>
      </view>
      <view class="dorm-heat-grid">
        <view class="dorm-item {{item.level}}" wx:for="{{dormHeat}}" wx:key="dorm">
          <view class="dorm-rank {{index === 0 ? 'top1' : index === 1 ? 'top2' : index === 2 ? 'top3' : ''}}">{{index + 1}}</view>
          <text class="dorm-name">{{item.dorm}}</text>
          <view class="dorm-bar-wrap">
            <view class="dorm-bar">
              <view class="dorm-bar-fill {{item.level}}" style="width: {{item.percent}}%"></view>
            </view>
            <view class="dorm-sparks" wx:if="{{item.level === 'hot'}}">
              <text class="spark">★</text>
              <text class="spark delay1">★</text>
              <text class="spark delay2">★</text>
            </view>
          </view>
          <view class="dorm-count-wrap">
            <text class="dorm-count">{{item.count}}</text>
            <text class="dorm-unit">单</text>
          </view>
          <text class="dorm-fire" wx:if="{{item.level === 'hot'}}">◆</text>
          <text class="dorm-warm-icon" wx:elif="{{item.level === 'warm'}}">◇</text>
        </view>
      </view>
      <view class="heat-legend">
        <view class="legend-item">
          <view class="legend-dot hot"></view>
          <text>火爆</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot warm"></view>
          <text>活跃</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot normal"></view>
          <text>平稳</text>
        </view>
      </view>
    </view>

    <view class="hot-section">
      <view class="section-header">
        <text class="section-title">热门盲盒</text>
        <text class="section-more" bindtap="navigateToBlindBox">全部 ›</text>
      </view>
      <scroll-view class="scroll-box" scroll-x>
        <view class="scroll-content">
          <view class="box-card interactive-card interactive-btn" wx:for="{{hotBoxes}}" wx:key="_id" bindtap="navigateToBoxDetail" data-id="{{item._id}}">
            <view class="card-image-wrap">
              <image class="card-image lazy-image-{{index}}" src="{{item.lazyLoaded ? item.images[0] : defaultImage}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
              <view class="card-price">¥{{item.price}}</view>
            </view>
            <view class="card-info">
              <text class="card-title">{{item.title}}</text>
              <view class="card-meta">
                <text class="card-dorm">{{item.fromDorm}}</text>
                <text class="card-sales">{{item.sales}}人开过</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="community-section">
      <view class="section-header">
        <text class="section-title">社区动态</text>
        <text class="section-more" bindtap="navigateToCommunity">全部 ›</text>
      </view>
      <view class="community-feed">
        <view class="feed-card interactive-card interactive-btn" wx:for="{{communityFeed}}" wx:key="_id" bindtap="navigateToFeedDetail" data-type="{{item.type}}" data-id="{{item._id}}">
          <view class="feed-card-header">
            <image class="feed-avatar lazy-avatar-{{index}}" src="{{item.avatarLoaded ? item.userAvatar : defaultAvatar}}" binderror="onAvatarError" data-index="{{index}}" />
            <view class="feed-user-info">
              <text class="feed-name">{{item.userName}}</text>
              <text class="feed-time">{{item.time}}</text>
            </view>
            <view class="feed-type-tag {{item.type}}">
              <text>{{item.type === 'donation' ? '捐赠' : item.type === 'exchange' ? '交换' : '售出'}}</text>
            </view>
          </view>
          <view class="feed-card-body">
            <view class="feed-content-wrap">
              <text class="feed-action">{{item.action}}</text>
              <text class="feed-desc">{{item.description}}</text>
            </view>
            <image class="feed-image lazy-feed-{{index}}" src="{{item.imageLoaded ? item.image : defaultImage}}" mode="aspectFill" binderror="onFeedImageError" data-index="{{index}}" />
          </view>
        </view>
      </view>
    </view>

    <view class="rider-banner interactive-card interactive-btn" bindtap="navigateToRider">
      <view class="rider-content">
        <text class="rider-title">加入校园骑手</text>
        <text class="rider-desc">课余时间接单配送，每单3-8元</text>
      </view>
      <view class="rider-stats">
        <text class="rider-num">{{riderCount}}</text>
        <text class="rider-label">位骑手在线</text>
      </view>
    </view>

    <!-- AI悬浮按钮 - 可拖动 -->
    <view class="ai-float-btn {{isDragging ? 'dragging' : ''}}" 
          style="left: {{aiBtnPosition.x}}px; top: {{aiBtnPosition.y}}px;"
          bindtouchstart="onAiBtnTouchStart"
          bindtouchmove="onAiBtnTouchMove"
          bindtouchend="onAiBtnTouchEnd"
          bindtap="navigateToAI">
      <view class="ai-float-avatar">
        <text class="ai-text">艾</text>
      </view>
      <view class="ai-float-badge" wx:if="{{unreadMessageCount > 0}}">{{unreadMessageCount > 9 ? '9+' : unreadMessageCount}}</view>
      <view class="ai-float-pulse"></view>
      <view class="ai-float-pulse delay"></view>
    </view>

    <view class="ai-float-tip" wx:if="{{showAITip && unreadMessageCount === 0}}">
      <text>有问题？问问艾米吧~</text>
      <view class="tip-close" bindtap="closeAITip">×</view>
    </view>
  </view>
</view>
