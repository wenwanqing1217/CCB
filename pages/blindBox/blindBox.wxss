.container {
  padding: 0;
  padding-bottom: 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0a0a1a 0%, #020617 50%, #0f0f23 100%);
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* 顶部固定导航区 */
.header-section {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 30rpx rgba(147, 112, 219, 0.15);
  padding: 16rpx 0;
  backdrop-filter: blur(20rpx);
  overflow: visible;
  height: auto;
  min-height: 180rpx;
}

/* 分类标签区域 */
.tabs-section {
  position: fixed;
  top: 180rpx;
  left: 0;
  right: 0;
  z-index: 1000;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 50%, rgba(12, 12, 28, 0.98) 100%);
  padding: 16rpx 0;
  backdrop-filter: blur(20rpx);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 30rpx rgba(147, 112, 219, 0.15);
}

/* 内容区域 */
.content-section {
  padding: 0 24rpx 120rpx;
  padding-top: 280rpx;
  margin-top: 0;
}

/* 搜索框样式 */
.search-bar {
  padding: 8rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-input {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.1),
              0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

.search-input input {
  flex: 1;
  font-size: 24rpx;
  color: #f8fafc;
  background: transparent;
  border: none;
  outline: none;
  height: 40rpx;
  line-height: 40rpx;
}

.search-input input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

.search-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.8) 0%, rgba(5, 5, 15, 0.9) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.search-btn-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 20%, rgba(139, 92, 246, 0.08) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(236, 72, 153, 0.06) 0%, transparent 40%),
              radial-gradient(circle at 50% 80%, rgba(59, 130, 246, 0.05) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

.blindbox-header {
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 50%, #cbd5e1 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 20rpx rgba(139, 92, 246, 0.3);
  animation: titleGlow 3s ease-in-out infinite;
}

@keyframes titleGlow {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.1); }
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

.lucky-section {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.lucky-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(236, 72, 153, 0.1) 50%, rgba(59, 130, 246, 0.1) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 24rpx;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.15),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.lucky-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

.lucky-info {
  flex: 1;
}

.lucky-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.lucky-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.lucky-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 24rpx;
}

.box-wrap {
  width: 130rpx;
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
              0 0 40rpx rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
  margin-bottom: 12rpx;
  border: none;
  transition: all 0.3s;
  position: relative;
  z-index: 3;
  overflow: hidden;
}

.box-wrap:active {
  transform: scale(0.95);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}



.box-wrap.shaking {
  animation: shake 0.5s ease-in-out, pulse 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  20% { transform: rotate(-15deg) scale(1.05); }
  40% { transform: rotate(12deg) scale(1.08); }
  60% { transform: rotate(-8deg) scale(1.05); }
  80% { transform: rotate(5deg) scale(1.02); }
}

@keyframes pulse {
  0% { box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.2); }
  50% { box-shadow: 0 8rpx 40rpx rgba(139, 92, 246, 0.4); }
  100% { box-shadow: 0 8rpx 24rpx rgba(139, 92, 246, 0.2); }
}

.box-icon {
  font-size: 60rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.lucky-price {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.lucky-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  text-decoration: line-through;
}

.lucky-count {
  text-align: center;
}

.lucky-count text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.lucky-coins {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(251, 191, 36, 0.15);
  border-radius: 20rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.3);
}

.coins-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.coins-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #fbbf24;
  text-shadow: 0 0 15rpx rgba(251, 191, 36, 0.6);
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin: 0;
  overflow-x: auto;
  padding: 0 24rpx 8rpx;
  position: relative;
  z-index: 1000;
  background: transparent;
  width: 100%;
  box-sizing: border-box;
}

.tabs::-webkit-scrollbar {
  display: none;
}

.tab-item {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.9) 0%, rgba(20, 20, 45, 0.95) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  white-space: nowrap;
  flex-shrink: 0;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: visible;
  z-index: 1001;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 30%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.6) 70%,
    transparent 100%);
  opacity: 0.7;
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.4);
  z-index: 2;
}

.tab-item.active {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(12, 12, 28, 0.9) 100%);
  border-color: rgba(124, 58, 237, 0.6);
  color: #ffffff;
  font-weight: 800;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.5),
    0 0 30rpx rgba(147, 112, 219, 0.3);
  box-shadow: 
    0 8rpx 40rpx rgba(147, 112, 219, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  animation: mainTitleGlow 3s ease-in-out infinite;
}

.tab-item:active {
  transform: translateY(-6rpx) scale(0.98);
  box-shadow: 
    0 8rpx 40rpx rgba(147, 112, 219, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.tab-item text {
  position: relative;
  z-index: 3;
}

@keyframes mainTitleGlow {
  0%, 100% { 
    text-shadow: 
      0 0 10rpx rgba(147, 112, 219, 0.8),
      0 0 20rpx rgba(147, 112, 219, 0.5);
    filter: brightness(1);
  }
  50% { 
    text-shadow: 
      0 0 15rpx rgba(147, 112, 219, 1),
      0 0 30rpx rgba(147, 112, 219, 0.8),
      0 0 45rpx rgba(186, 85, 211, 0.5);
    filter: brightness(1.2);
  }
}

.filter-bar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 10;
  padding: 0 24rpx;
}

.filter-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx 0;
  position: relative;
  transition: all 0.3s;
}

.filter-item::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #8b5cf6, #ec4899);
  border-radius: 2rpx;
  transition: all 0.3s;
  transform: translateX(-50%);
}

.filter-item.active {
  color: #f8fafc;
  font-weight: 600;
}

.filter-item.active::after {
  width: 100%;
}

.blind-box-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
}

.blind-box-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  backdrop-filter: blur(20rpx);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.5s ease-out;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.6),
              0 0 20rpx rgba(147, 112, 219, 0.15);
  position: relative;
}

.blind-box-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
  z-index: 2;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.blind-box-card:active {
  transform: translateY(-8rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(139, 92, 246, 0.3),
              0 0 30rpx rgba(147, 112, 219, 0.25);
}

.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.blind-box-card:active .card-image {
  transform: scale(1.05);
}

.card-type {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.card-type.secondhand {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.8) 0%, rgba(16, 185, 129, 0.8) 100%);
  color: #fff;
}

.card-type.creative {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.8) 0%, rgba(124, 58, 237, 0.8) 100%);
  color: #fff;
}

.card-type.donation {
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.8) 0%, rgba(219, 39, 119, 0.8) 100%);
  color: #fff;
}

.card-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  animation: tagPulse 2s ease-in-out infinite;
}

@keyframes tagPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes brandGlow {
  0%, 100% { 
    text-shadow: 
      0 0 10rpx rgba(147, 112, 219, 0.8),
      0 0 20rpx rgba(147, 112, 219, 0.6),
      0 0 30rpx rgba(147, 112, 219, 0.4);
    filter: brightness(1);
  }
  50% { 
    text-shadow: 
      0 0 15rpx rgba(147, 112, 219, 1),
      0 0 30rpx rgba(147, 112, 219, 0.8),
      0 0 45rpx rgba(147, 112, 219, 0.6),
      0 0 60rpx rgba(186, 85, 211, 0.4);
    filter: brightness(1.2);
  }
}

@keyframes priceGlow {
  0%, 100% { 
    text-shadow: 
      0 0 10rpx rgba(251, 191, 36, 0.6),
      0 0 20rpx rgba(245, 158, 11, 0.4);
    filter: brightness(1);
  }
  50% { 
    text-shadow: 
      0 0 15rpx rgba(251, 191, 36, 0.8),
      0 0 30rpx rgba(245, 158, 11, 0.6),
      0 0 45rpx rgba(245, 158, 11, 0.4);
    filter: brightness(1.1);
  }
}

.card-tag.hot {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.4);
}

.card-tag.new {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.card-info {
  padding: 18rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.3) 100%);
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.card-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.card-school, .card-dorm {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-price {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(251, 191, 36, 0.4);
  animation: priceGlow 2s ease-in-out infinite;
}

.card-love {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.card-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.card-probability {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
}

.hidden-tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.6) 0%, rgba(124, 58, 237, 0.6) 100%);
  color: #fff;
  border-radius: 8rpx;
  font-weight: 600;
}

.hidden-rate {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.loading-more, .no-more {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.demand-section, .supply-section {
  position: relative;
  z-index: 1;
}

.section-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.demand-card, .supply-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
}

.demand-header, .supply-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.demand-avatar, .supply-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.3);
}

.demand-user, .supply-user {
  flex: 1;
}

.demand-name, .supply-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.demand-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.supply-badge {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.3) 0%, rgba(16, 185, 129, 0.3) 100%);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #22c55e;
  margin-left: 12rpx;
}

.demand-reward {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.reward-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.reward-price {
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.demand-content, .supply-content {
  margin-bottom: 16rpx;
}

.demand-title, .supply-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 8rpx;
}

.demand-desc, .supply-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.demand-tags, .supply-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.demand-tag, .supply-tag {
  padding: 6rpx 14rpx;
  background: rgba(139, 92, 246, 0.2);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(139, 92, 246, 0.3);
}

.demand-footer, .supply-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.demand-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.demand-action, .supply-action {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.4) 0%, rgba(124, 58, 237, 0.4) 100%);
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #f8fafc;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  transition: all 0.3s;
}

.demand-action:active, .supply-action:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.3);
}

.supply-price-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.supply-price {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.supply-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.publish-demand-btn, .publish-supply-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(236, 72, 153, 0.2) 100%);
  border-radius: 24rpx;
  border: 2rpx dashed rgba(139, 92, 246, 0.4);
  margin-top: 20rpx;
  transition: all 0.3s;
}

.publish-demand-btn:active, .publish-supply-btn:active {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.3) 0%, rgba(236, 72, 153, 0.3) 100%);
  border-color: rgba(139, 92, 246, 0.6);
}

.publish-icon {
  font-size: 36rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.8);
}

.publish-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
}

.empty-btn {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.4) 0%, rgba(124, 58, 237, 0.4) 100%);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
}

.open-result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(20rpx);
}

.result-content {
  width: 600rpx;
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.2) 0%, rgba(30, 27, 75, 0.95) 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  box-shadow: 0 20rpx 60rpx rgba(139, 92, 246, 0.3);
  animation: modalIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.8) translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.result-header {
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.result-box {
  width: 280rpx;
  height: 280rpx;
  margin: 0 auto 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 3rpx solid rgba(139, 92, 246, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.3);
}

.result-image {
  width: 100%;
  height: 100%;
}

.result-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 8rpx;
}

.result-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.result-score {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.score-icon {
  font-size: 28rpx;
}

.score-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fbbf24;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.result-btn.share {
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.4) 0%, rgba(219, 39, 119, 0.4) 100%);
  color: #f8fafc;
  border: 1rpx solid rgba(236, 72, 153, 0.3);
}

.result-btn.confirm {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.5) 0%, rgba(124, 58, 237, 0.5) 100%);
  color: #f8fafc;
  border: 1rpx solid rgba(139, 92, 246, 0.4);
}

.result-btn:active {
  transform: scale(0.95);
}





