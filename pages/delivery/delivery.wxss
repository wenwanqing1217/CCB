.container {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  animation: backgroundMove 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

.tab-bar {
  display: flex;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  position: relative;
  z-index: 1;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.tab-item:active::before {
  left: 100%;
}

.tab-item.active {
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  color: #f8fafc;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
}

.order-list {
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.order-card {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.order-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, transparent 0%, rgba(147, 112, 219, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.order-card:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.order-card:active::before {
  opacity: 1;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.order-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.order-type {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid transparent;
  transition: all 0.3s ease;
}

.order-type.donation {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(16, 185, 129, 0.2) 100%);
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

.order-type.exchange {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
  color: #3b82f6;
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
}

.order-type.blindbox {
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.2) 0%, rgba(147, 112, 219, 0.2) 100%);
  color: #c8a2ff;
  border-color: rgba(123, 104, 238, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(123, 104, 238, 0.2);
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
}

.order-status.pending {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2) 0%, rgba(245, 158, 11, 0.2) 100%);
  color: #fbbf24;
  border: 1rpx solid rgba(251, 191, 36, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.2);
}

.order-status.delivering {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
}

.order-status.completed {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(16, 185, 129, 0.2) 100%);
  color: #22c55e;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.2);
}

.order-content {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.item-info {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
}

.item-info:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-color: rgba(147, 112, 219, 0.3);
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: transform 0.3s ease;
}

.item-info:active .item-image {
  transform: scale(1.05);
}

.item-detail {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

  margin-bottom: 8rpx;
  line-height: 1.4;
}

.item-price {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  font-variant-numeric: tabular-nums;
}

.route-info {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
}

.route-info:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-color: rgba(147, 112, 219, 0.3);
}

.route-point {
  display: flex;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

.point-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.point-icon.from {
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  color: #f8fafc;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
}

.point-icon.to {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: #f8fafc;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.3);
}

.point-content {
  flex: 1;
}

.point-location {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

  margin-bottom: 4rpx;
  line-height: 1.4;
}

.point-person {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.route-line {
  width: 2rpx;
  height: 24rpx;
  background: linear-gradient(180deg, rgba(147, 112, 219, 0.5), rgba(34, 197, 94, 0.5));
  margin-left: 23rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 1;
}

.fee-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.fee-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.fee-value {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  font-variant-numeric: tabular-nums;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transition: left 0.6s;
}

.action-btn:active::before {
  left: 100%;
}

.action-btn.contact {
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  color: rgba(255, 255, 255, 0.7);
  border-color: rgba(255, 255, 255, 0.05);
}

.action-btn.track {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #f8fafc;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.action-btn.confirm {
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  color: #f8fafc;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
}

.action-btn:active {
  transform: scale(0.95);
}

.rider-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.8) 0%, rgba(22, 33, 62, 0.6) 50%, rgba(15, 52, 96, 0.4) 100%);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.rider-info:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-color: rgba(147, 112, 219, 0.3);
}

.rider-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #c8a2ff;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
}

.rider-detail {
  flex: 1;
}

.rider-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;  

  margin-bottom: 4rpx;
}

.rider-level {
  display: block;
  font-size: 24rpx;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);

  font-weight: 500;
}

.rider-status {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.2) 100%);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.2);
  font-weight: 500;
}

.timeline {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 1;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  animation: fadeInUp 0.5s ease-out;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #64748b 0%, #475569 100%);
  margin-right: 16rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.timeline-dot.active {
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.5);
  }
  50% {
    transform: scale(1.2);
    box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.7);
  }
}

.timeline-content {
  flex: 1;
}

.timeline-text {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;  

  line-height: 1.4;
}

.timeline-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 6rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  position: relative;
  z-index: 1;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.empty-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 100%);
  color: #f8fafc;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 24rpx rgba(147, 112, 219, 0.4);
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

