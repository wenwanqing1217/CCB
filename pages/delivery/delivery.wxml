<view class="container particle-bg">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="setTab" data-tab="all">全部</view>
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="setTab" data-tab="pending">待配送</view>
    <view class="tab-item {{activeTab === 'delivering' ? 'active' : ''}}" bindtap="setTab" data-tab="delivering">配送中</view>
    <view class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" bindtap="setTab" data-tab="completed">已完成</view>
  </view>

  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="_id">
      <view class="order-header">
        <view class="order-info">
          <text class="order-id">{{item.orderId}}</text>
          <text class="order-type {{item.type}}">{{item.typeText}}</text>
        </view>
        <text class="order-status {{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="order-content">
        <view class="item-info" wx:if="{{item.itemTitle}}">
          <image class="item-image" src="{{item.itemImage}}" mode="aspectFill" />
          <view class="item-detail">
            <text class="item-title">{{item.itemTitle}}</text>
            <text class="item-price">¥{{item.itemPrice}}</text>
          </view>
        </view>

        <view class="route-info">
          <view class="route-point">
            <view class="point-icon from">
              <text>取</text>
            </view>
            <view class="point-content">
              <text class="point-location">{{item.fromDorm}} {{item.fromRoom}}</text>
              <text class="point-person">{{item.fromPerson}} {{item.fromPhone}}</text>
            </view>
          </view>
          <view class="route-line"></view>
          <view class="route-point">
            <view class="point-icon to">
              <text>送</text>
            </view>
            <view class="point-content">
              <text class="point-location">{{item.toDorm}} {{item.toRoom}}</text>
              <text class="point-person">{{item.toPerson}} {{item.toPhone}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <view class="fee-info">
          <text class="fee-label">配送费</text>
          <text class="fee-value">¥{{item.deliveryFee}}</text>
        </view>
        <view class="order-actions">
          <view class="action-btn contact" catchtap="contactRider" wx:if="{{item.riderName && item.status !== 'completed'}}">
            <text>联系骑手</text>
          </view>
          <view class="action-btn track" catchtap="trackOrder" wx:if="{{item.status === 'delivering'}}">
            <text>追踪订单</text>
          </view>
          <view class="action-btn confirm" catchtap="confirmReceive" wx:if="{{item.status === 'delivering'}}">
            <text>确认收货</text>
          </view>
        </view>
      </view>

      <view class="rider-info" wx:if="{{item.riderName}}">
        <image class="rider-avatar" src="{{item.riderAvatar}}" />
        <view class="rider-detail">
          <text class="rider-name">{{item.riderName}}</text>
          <text class="rider-level">Lv.{{item.riderLevel}} 骑手</text>
        </view>
        <view class="rider-status" wx:if="{{item.status === 'delivering'}}">
          <text>配送中</text>
        </view>
      </view>

      <view class="timeline" wx:if="{{item.timeline && item.timeline.length > 0}}">
        <view class="timeline-item" wx:for="{{item.timeline}}" wx:for-item="log" wx:key="time">
          <view class="timeline-dot {{log.active ? 'active' : ''}}"></view>
          <view class="timeline-content">
            <text class="timeline-text">{{log.text}}</text>
            <text class="timeline-time">{{log.time}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-text">暂无配送订单</text>
    <view class="empty-btn" bindtap="navigateToDonation">去捐赠</view>
  </view>
</view>
