}

.not-rider-benefit {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 50%, #9370db 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 32rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.not-rider-btn {
  display: inline-block;
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.5);
  border: 1rpx solid rgba(147, 112, 219, 0.5);
  transition: all 0.3s ease;
}

.not-rider-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 12rpx rgba(147, 112, 219, 0.6);
}

.not-rider-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}





