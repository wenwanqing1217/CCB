.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  backdrop-filter: blur(10rpx);
}

.header-info {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 50%, #9370db 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.header-count {
  text-align: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.count-num {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 50%, #9370db 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.count-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  overflow-x: auto;
  padding-bottom: 12rpx;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.filter-tabs::-webkit-scrollbar {
  display: none;
}

.filter-tab {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 28rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(15rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.7);
  transition: all 0.3s ease;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
  white-space: nowrap;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.filter-tab::before {
  content: '';
  position: absolute;
  left: -100%;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(147, 112, 219, 0.1) 50%, transparent 100%);
  transition: left 0.5s ease;
}

.filter-tab:hover::before {
  left: 100%;
}

.filter-tab:hover {
  transform: translateY(-2rpx);
  border-color: rgba(147, 112, 219, 0.5);
  box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.3),
              0 20rpx 80rpx rgba(0, 0, 0, 0.8);
  color: #c4b5fd;
}

.filter-tab.active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.4) 0%, rgba(186, 85, 211, 0.3) 100%);
  color: #f8fafc;
  font-weight: 600;
  border: 2rpx solid rgba(147, 112, 219, 0.6);
  box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.4),
              0 20rpx 80rpx rgba(0, 0, 0, 0.8);
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.7);
  transform: translateY(-2rpx);
}

.filter-tab.active::before {
  left: 100%;
  animation: tabShine 1s ease-out;
}

@keyframes tabShine {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.map-container {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  backdrop-filter: blur(15rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.7);
  position: relative;
  z-index: 1;
}

.order-map {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
}

.map-tip {
  padding: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-top: 1rpx solid rgba(147, 112, 219, 0.15);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.update-info {
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  text-align: right;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  z-index: 1;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  position: relative;
  z-index: 1;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  position: relative;
  z-index: 1;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  backdrop-filter: blur(15rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.7);
  margin-bottom: 20rpx;
}

.empty-container .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 20rpx rgba(56, 189, 248, 0.4);
}

.empty-container .empty-text {
  font-size: 30rpx;
  color: #f8fafc;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(56, 189, 248, 0.2);
}

.empty-container .empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 1rpx 4rpx rgba(56, 189, 248, 0.1);
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.order-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  backdrop-filter: blur(15rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.7);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.order-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.6) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(147, 112, 219, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.order-card:hover {
  transform: translateY(-5rpx);
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.3),
              0 20rpx 80rpx rgba(0, 0, 0, 0.8);
}

.order-card:active {
  transform: translateY(-2rpx) scale(0.99);
  box-shadow: 0 8rpx 24rpx rgba(147, 112, 219, 0.4),
              0 12rpx 40rpx rgba(0, 0, 0, 0.8);
}

.order-card.new {
  border-color: rgba(147, 112, 219, 0.6);
  animation: glow 2s ease-in-out infinite;
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.3),
              0 16rpx 64rpx rgba(0, 0, 0, 0.7);
}

.order-card.new::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(147, 112, 219, 0.1) 50%, transparent 100%);
  animation: newOrderShine 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.3),
                0 16rpx 64rpx rgba(0, 0, 0, 0.7);
  }
  50% {
    box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.4),
                0 20rpx 80rpx rgba(0, 0, 0, 0.8),
                0 0 40rpx rgba(186, 85, 211, 0.3);
  }
}

@keyframes newOrderShine {
  0% {
    left: -100%;
  }
  100% {
    left: 100%;
  }
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-type {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.order-type.blindbox {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  color: #c8a2ff;
  font-weight: 500;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.5);
}

.order-type.donation {
  background: rgba(34, 197, 94, 0.2);
  color: #22c55e;
  text-shadow: 0 0 5rpx rgba(34, 197, 94, 0.5);
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.order-type.exchange {
  background: rgba(59, 130, 246, 0.2);
  color: #3b82f6;
  text-shadow: 0 0 5rpx rgba(59, 130, 246, 0.5);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.order-fee {
  flex: 1;
  text-align: right;
}

.fee-num {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #c8a2ff 0%, #ba55d3 50%, #9370db 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.new-badge {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  color: #c8a2ff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 8rpx;
  margin-left: 12rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.5);
}

.card-route {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.route-point {
  flex: 1;
  display: flex;
  align-items: center;
}

.point-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.point-icon.from {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.point-icon.from text {
  color: #c8a2ff;
  font-size: 24rpx;
  font-weight: 600;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.5);
}

.point-icon.to {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.point-icon.to text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  text-shadow: 0 0 5rpx rgba(34, 197, 94, 0.5);
}

.point-info {
  flex: 1;
}

.point-dorm {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #f8fafc;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.point-room {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

.route-line {
  width: 80rpx;
  text-align: center;
}

.line-arrow {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.card-info {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  flex: 1;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 4rpx;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #f8fafc;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.info-value.remark {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.15);
}

.order-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.2);
}

.grab-btn {
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.5),
              0 16rpx 64rpx rgba(186, 85, 211, 0.3);
  border: 2rpx solid rgba(147, 112, 219, 0.5);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  animation: btnPulse 2s ease-in-out infinite;
}

.grab-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  transform: rotate(45deg);
  animation: btnShine 3s ease-in-out infinite;
}

.grab-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.6),
              0 20rpx 80rpx rgba(186, 85, 211, 0.4);
  border-color: rgba(147, 112, 219, 0.8);
}

.grab-btn:active {
  transform: scale(0.95) translateY(0);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.7),
              0 8rpx 32rpx rgba(186, 85, 211, 0.5);
}

.grab-btn text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.7);
  position: relative;
  z-index: 1;
}

@keyframes btnPulse {
  0%, 100% {
    box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.5),
                0 16rpx 64rpx rgba(186, 85, 211, 0.3);
  }
  50% {
    box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.6),
                0 20rpx 80rpx rgba(186, 85, 211, 0.4),
                0 0 40rpx rgba(196, 181, 253, 0.3);
  }
}

@keyframes btnShine {
  0% {
    transform: rotate(45deg) translateX(-100%);
  }
  100% {
    transform: rotate(45deg) translateX(100%);
  }
}

