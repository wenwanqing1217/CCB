<view class="container">
  <view class="order-section">
    <view class="section-title">{{isShakeOrder ? '🎁 盲盒信息' : '盲盒信息'}}</view>
    <view class="box-info">
      <image class="box-image" src="{{boxInfo.images[0]}}" mode="aspectFill" />
      <view class="box-details">
        <text class="box-title">{{boxInfo.title}}</text>
        <text class="box-desc">{{boxInfo.desc}}</text>
        <view class="box-meta">
          <text class="box-category" wx:if="{{boxInfo.category}}">{{boxInfo.category}}</text>
          <text class="box-location">📍 {{boxInfo.campus || '校园'}}</text>
        </view>
        <view class="box-price-row">
          <text class="box-price">¥{{boxInfo.price}}</text>
          <text class="box-hint">盲盒价格 · 不支持退货</text>
        </view>
      </view>
    </view>
  </view>

  <view class="address-section">
    <view class="section-title">收货信息</view>
    <view class="address-card" bindtap="chooseAddress">
      <view class="address-icon">📦</view>
      <view class="address-info">
        <view class="address-header">
          <text class="address-name">{{address.name || '请选择收货地址'}}</text>
          <text class="address-phone">{{address.phone || ''}}</text>
        </view>
        <text class="address-detail">{{address.detail || ''}}</text>
      </view>
      <view class="address-arrow">›</view>
    </view>
  </view>

  <view class="payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-options">
      <view class="payment-item {{paymentMethod === 'offline' ? 'active' : ''}}" bindtap="selectPayment" data-method="offline">
        <text class="payment-icon">💵</text>
        <text class="payment-name">线下支付</text>
        <text class="payment-desc">当面交易</text>
        <view class="payment-check {{paymentMethod === 'offline' ? 'active' : ''}}">
          <text wx:if="{{paymentMethod === 'offline'}}">✓</text>
        </view>
      </view>
      <view class="payment-item {{paymentMethod === 'wechat' ? 'active' : ''}}" bindtap="selectPayment" data-method="wechat">
        <text class="payment-icon">💳</text>
        <text class="payment-name">微信支付</text>
        <text class="payment-desc">在线支付</text>
        <view class="payment-check {{paymentMethod === 'wechat' ? 'active' : ''}}">
          <text wx:if="{{paymentMethod === 'wechat'}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <view class="remark-section">
    <view class="section-title">备注</view>
    <input class="remark-input" placeholder="添加备注信息..." value="{{remark}}" bindinput="onRemarkInput" />
  </view>

  <view class="price-section">
    <view class="price-row">
      <text class="price-label">盲盒价格</text>
      <text class="price-value">¥{{boxInfo.price}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">配送费</text>
      <text class="price-value">免配送费</text>
    </view>
    <view class="price-row total">
      <text class="price-label total">总计</text>
      <text class="price-value total">¥{{totalPrice}}</text>
    </view>
  </view>

  <view class="submit-bar">
    <view class="submit-price">
      <text class="price-label">合计：</text>
      <text class="price-value">¥{{totalPrice}}</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">
      <text>{{isShakeOrder ? '立即购买' : '提交订单'}}</text>
    </view>
  </view>
</view>