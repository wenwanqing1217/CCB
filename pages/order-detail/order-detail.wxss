/* 订单详情页面 - 紫色霓虹灯风格 */

page {
  background-color: #020208;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #020208 0%, #050510 100%);
  padding: 0;
  padding-bottom: 160rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光效 */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 20%, rgba(147, 112, 219, 0.08) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(186, 85, 211, 0.06) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* 信息卡片通用样式 */
.info-card {
  margin: 24rpx;
  background: linear-gradient(135deg, rgba(20, 20, 40, 0.95) 0%, rgba(10, 10, 25, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.4);
  position: relative;
  z-index: 1;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(147, 112, 219, 0.3), transparent);
  margin: 24rpx 0;
}

/* 主信息卡片 - 优化布局 */
.main-card {
  background: linear-gradient(135deg, rgba(25, 25, 50, 0.95) 0%, rgba(15, 15, 30, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

/* 状态头部 */
.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 状态徽章 */
.status-badge {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  color: #c8a2ff;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.status-badge.pending {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2) 0%, rgba(245, 158, 11, 0.15) 100%);
  border-color: rgba(251, 191, 36, 0.4);
  color: #fbbf24;
}

.status-badge.delivering {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.15) 100%);
  border-color: rgba(59, 130, 246, 0.4);
  color: #60a5fa;
}

.status-badge.completed {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(22, 163, 74, 0.15) 100%);
  border-color: rgba(34, 197, 94, 0.4);
  color: #22c55e;
}

/* 盲盒部分 */
.box-section {
  margin-top: 24rpx;
}

.box-info-main {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.box-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  object-fit: cover;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.box-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.box-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.box-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.box-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #c8a2ff;
  margin-top: 8rpx;
}

/* 配送信息部分 */
.delivery-info-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 12rpx 0;
}

.info-row {
  display: flex;
  gap: 16rpx;
}

.info-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(147, 112, 219, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
}

.info-item.full {
  flex: 1;
}

.info-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  width: 80rpx;
}

.info-value {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 联系操作按钮 */
.contact-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.contact-actions .btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.contact-actions .btn::after {
  border: none;
}

.contact-actions .btn-icon {
  font-size: 28rpx;
}

/* 骑手信息 */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.rider-info {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.rider-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
}

.rider-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rider-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.rider-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.rating-icon {
  font-size: 28rpx;
}

.rating-value {
  font-weight: 600;
  color: #fbbf24;
}

.rider-phone {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.phone-icon {
  font-size: 28rpx;
}

.phone-number {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 物流卡片 */
.logistics-card {
  background: linear-gradient(135deg, rgba(25, 25, 50, 0.9) 0%, rgba(15, 15, 30, 0.95) 100%);
}

.delivery-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pulse-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #22c55e;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7);
  }
  50% {
    box-shadow: 0 0 0 15rpx rgba(34, 197, 94, 0);
  }
}

.status-text {
  font-size: 24rpx;
  color: #22c55e;
  font-weight: 600;
}

/* 配送进度条 */
.delivery-progress {
  margin-bottom: 32rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7c3aed 0%, #ba55d3 50%, #c8a2ff 100%);
  border-radius: 4rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.progress-steps {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  opacity: 0.4;
  transition: all 0.3s ease;
}

.progress-step.active,
.progress-step.completed {
  opacity: 1;
}

.progress-step .step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 2rpx solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.6);
  transition: all 0.3s ease;
}

.progress-step.active .step-dot {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-color: #c8a2ff;
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.6);
  animation: stepPulse 2s ease-in-out infinite;
}

@keyframes stepPulse {
  0%, 100% {
    box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.6);
  }
  50% {
    box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.8);
  }
}

.progress-step.completed .step-dot {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-color: #c8a2ff;
  color: #fff;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.step-name {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 500;
}

.progress-step.active .step-name,
.progress-step.completed .step-name {
  color: #c8a2ff;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

/* 预计送达时间 */
.eta-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(147, 112, 219, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  margin-bottom: 24rpx;
}

.eta-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.eta-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.eta-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.eta-time {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.eta-countdown {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  text-align: right;
}

.countdown-num {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.countdown-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 地图组件 */
.map-section {
  margin-bottom: 24rpx;
}

.map-container {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  margin-bottom: 16rpx;
}

.map-overlay {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  right: 16rpx;
  background: rgba(15, 15, 30, 0.9);
  backdrop-filter: blur(10rpx);
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.map-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.map-distance {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.map-rider {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 路线信息 */
.route-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: rgba(147, 112, 219, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
}

.route-info .route-point {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.route-info .route-point:first-child {
  justify-content: flex-start;
}

.route-info .route-point:last-child {
  justify-content: flex-end;
}

.route-info .point-marker {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.route-info .point-marker.start {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
}

.route-info .point-marker.end {
  background: linear-gradient(135deg, #c8a2ff 0%, #9370db 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
}

.route-info .point-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  flex-shrink: 0;
}

.route-info .route-line {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg, #7c3aed 0%, #ba55d3 50%, #c8a2ff 100%);
  border-radius: 2rpx;
  position: relative;
  margin: 0 8rpx;
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.route-info .route-line::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 100%;
  transform: translateY(-50%);
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 8rpx,
    rgba(255, 255, 255, 0.3) 8rpx,
    rgba(255, 255, 255, 0.3) 16rpx
  );
  animation: dashMove 1s linear infinite;
}

@keyframes dashMove {
  0% {
    transform: translateY(-50%) translateX(0);
  }
  100% {
    transform: translateY(-50%) translateX(16rpx);
  }
}

/* 物流时间轴 */
.logistics-timeline {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 8rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  position: relative;
  padding-left: 8rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 40rpx;
  bottom: -24rpx;
  width: 2rpx;
  background: linear-gradient(180deg, rgba(147, 112, 219, 0.5) 0%, rgba(147, 112, 219, 0.1) 100%);
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  border: 3rpx solid rgba(147, 112, 219, 0.3);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.timeline-dot.active {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-color: #c8a2ff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.6);
}

.timeline-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timeline-status {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.timeline-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.timeline-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.timeline-item.latest .timeline-status {
  background: linear-gradient(135deg, #c8a2ff 0%, #9370db 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

/* 通知信息 */
.notice-info {
  padding: 20rpx;
  background: rgba(59, 130, 246, 0.08);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notice-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.notice-hint {
  font-size: 22rpx;
  color: rgba(96, 165, 250, 0.8);
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, transparent, rgba(2, 2, 8, 0.95) 30%);
  padding: 24rpx 24rpx 40rpx;
  z-index: 100;
  backdrop-filter: blur(10rpx);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

/* 按钮样式 */
.btn {
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  flex: 2;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(147, 112, 219, 0.4);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 20rpx rgba(147, 112, 219, 0.3);
}

.btn-secondary {
  flex: 1;
  background: rgba(147, 112, 219, 0.15);
  color: #c8a2ff;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.btn-secondary:active {
  background: rgba(147, 112, 219, 0.25);
  transform: scale(0.98);
}

.btn-icon {
  font-size: 32rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(147, 112, 219, 0.2);
  border-top-color: #c8a2ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}
