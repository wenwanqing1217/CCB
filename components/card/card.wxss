.card {
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  background-clip: padding-box;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2), 0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  animation: cardGlow 2.5s ease-in-out infinite;
}

.card::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, 
    rgba(186, 85, 211, 0.9) 0%,
    rgba(147, 112, 219, 0.8) 50%,
    rgba(186, 85, 211, 0.9) 100%);
  border-radius: 22rpx;
  z-index: -1;
  animation: borderGlow 1.8s ease-in-out infinite;
}

.card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 1) 20%,
    rgba(186, 85, 211, 0.95) 50%,
    rgba(200, 162, 255, 1) 80%,
    transparent 100%);
  box-shadow: 0 0 25rpx rgba(200, 162, 255, 0.9),
              0 0 50rpx rgba(186, 85, 211, 0.5);
  animation: topGlow 2s ease-in-out infinite;
}

.card-hover {
  background: rgba(30, 30, 55, 0.9);
  transform: translateY(-4rpx);
  box-shadow: 0 0 35rpx rgba(147, 112, 219, 0.3), 0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.card.small {
  padding: 16rpx;
  border-radius: 16rpx;
}

.card.large {
  padding: 32rpx;
  border-radius: 24rpx;
}

@keyframes cardGlow {
  0%, 100% { 
    box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2), 0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  }
  50% { 
    box-shadow: 0 0 35rpx rgba(147, 112, 219, 0.3), 0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  }
}

@keyframes borderGlow {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

@keyframes topGlow {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}
