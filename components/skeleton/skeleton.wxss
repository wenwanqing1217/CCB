.skeleton-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 100%);
}

.skeleton-container {
  padding: 20rpx;
  min-height: 100vh;
}

.skeleton-theme-dark {
  background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 100%);
}

.skeleton-theme-light {
  background: #f5f5f5;
}

.skeleton-theme-light .skeleton-animate {
  background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%) !important;
}

.skeleton-animate {
  background: linear-gradient(90deg, #1a1a2e 25%, #2d2d44 50%, #1a1a2e 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

.skeleton-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.skeleton-info {
  flex: 1;
  margin-left: 20rpx;
}

.skeleton-name {
  width: 200rpx;
  height: 32rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-desc {
  width: 150rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.skeleton-coins {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.skeleton-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.skeleton-stat-value {
  width: 80rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-stat-label {
  width: 60rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.skeleton-grab {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-grab-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.skeleton-grab-content {
  flex: 1;
  margin-left: 20rpx;
}

.skeleton-grab-title {
  width: 250rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-grab-desc {
  width: 180rpx;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
}

.skeleton-grab-btn {
  width: 120rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.skeleton-section {
  margin-bottom: 20rpx;
}

.skeleton-section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.skeleton-section-title {
  width: 160rpx;
  height: 32rpx;
  border-radius: 8rpx;
}

.skeleton-section-more {
  width: 60rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.skeleton-scroll {
  white-space: nowrap;
}

.skeleton-box-list {
  display: inline-flex;
  gap: 20rpx;
}

.skeleton-box-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
}

.skeleton-box-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
}

.skeleton-box-info {
  padding: 0 10rpx;
}

.skeleton-box-title {
  width: 160rpx;
  height: 28rpx;
  border-radius: 6rpx;
  margin-bottom: 8rpx;
}

.skeleton-box-price {
  width: 100rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.skeleton-feed-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-feed-item {
  display: flex;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.skeleton-feed-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-feed-content {
  flex: 1;
  margin-left: 20rpx;
}

.skeleton-feed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.skeleton-feed-name {
  width: 120rpx;
  height: 28rpx;
  border-radius: 6rpx;
}

.skeleton-feed-time {
  width: 100rpx;
  height: 22rpx;
  border-radius: 4rpx;
}

.skeleton-feed-text {
  width: 100%;
  height: 80rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.skeleton-feed-image {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.skeleton-feed-actions {
  display: flex;
  gap: 40rpx;
}

.skeleton-feed-action {
  width: 60rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

/* 列表页骨架样式 */
.skeleton-list-header {
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-list-title {
  width: 200rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-list-sub {
  width: 300rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.skeleton-search {
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}

.skeleton-filters {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-filter {
  flex: 1;
  height: 60rpx;
  border-radius: 30rpx;
}

.skeleton-list-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.skeleton-list-item {
  display: flex;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.skeleton-list-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.skeleton-list-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.skeleton-list-item-title {
  height: 32rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-list-item-desc {
  height: 24rpx;
  border-radius: 6rpx;
  margin-bottom: 15rpx;
}

.skeleton-list-item-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.skeleton-list-item-tag {
  width: 80rpx;
  height: 32rpx;
  border-radius: 16rpx;
}

.skeleton-list-item-footer {
  flex: 1;
  display: flex;
  align-items: flex-end;
}

.skeleton-list-item-stats {
  display: flex;
  gap: 30rpx;
}

.skeleton-list-item-stat {
  width: 40rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

/* 详情页骨架样式 */
.skeleton-detail-image {
  width: 100%;
  height: 600rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-detail-info {
  padding: 20rpx;
}

.skeleton-detail-title {
  height: 48rpx;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.skeleton-detail-price {
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-detail-desc {
  height: 80rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-detail-tags {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.skeleton-detail-tag {
  width: 100rpx;
  height: 40rpx;
  border-radius: 20rpx;
}

.skeleton-detail-section {
  margin-bottom: 20rpx;
}

.skeleton-detail-section-title {
  height: 32rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.skeleton-detail-section-content {
  height: 200rpx;
  border-radius: 12rpx;
}

/* 个人中心骨架样式 */
.skeleton-profile-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.skeleton-profile-info {
  flex: 1;
  margin-left: 20rpx;
}

.skeleton-profile-name {
  width: 200rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.skeleton-profile-desc {
  width: 180rpx;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
}

.skeleton-profile-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.skeleton-profile-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.skeleton-profile-stat-value {
  width: 80rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.skeleton-profile-stat-label {
  width: 60rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.skeleton-profile-menu {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  overflow: hidden;
}

.skeleton-profile-menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.skeleton-profile-menu-item:last-child {
  border-bottom: none;
}

.skeleton-profile-menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.skeleton-profile-menu-text {
  flex: 1;
  height: 32rpx;
  border-radius: 8rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}