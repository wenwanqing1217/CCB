/* ================================
   盲盒开启动画组件样式
   ================================ */

/* 遮罩层 */
.box-open-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9998;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  display: none;
  align-items: center;
  justify-content: center;
}

.box-open-mask.visible {
  display: flex;
}

.box-open-container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* === 盒子阶段 === */
.box-stage {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.box-stage.active {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

/* 光晕 */
.glow-ring {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  opacity: 0.3;
  animation: glowPulse 2s ease-in-out infinite;
}

.glow-ring.common { background: radial-gradient(circle, rgba(156,163,175,0.4), transparent); }
.glow-ring.uncommon { background: radial-gradient(circle, rgba(52,211,153,0.4), transparent); }
.glow-ring.rare { background: radial-gradient(circle, rgba(96,165,250,0.4), transparent); }
.glow-ring.epic { background: radial-gradient(circle, rgba(167,139,250,0.5), transparent); }
.glow-ring.legendary { background: radial-gradient(circle, rgba(251,191,36,0.5), transparent); }

.glow-ring-outer {
  width: 450rpx;
  height: 450rpx;
  animation: glowPulse 3s ease-in-out infinite reverse;
}

/* 盒子 */
.box-wrapper {
  position: relative;
  z-index: 2;
  transition: transform 0.3s;
}

.box-wrapper.shaking {
  animation: boxShake 0.1s ease-in-out infinite;
}

.box-wrapper.gathering {
  animation: boxFloat 0.5s ease-in-out infinite alternate;
}

.box-body {
  position: relative;
  width: 240rpx;
  height: 240rpx;
}

.box-lid {
  position: absolute;
  top: -40rpx;
  left: -10rpx;
  right: -10rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4C1D95, #6D28D9);
  border-radius: 20rpx 20rpx 0 0;
  border: 3rpx solid rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.3);
  z-index: 3;
  transform-origin: bottom center;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.lid-opening {
  transform: rotateX(-120deg) translateY(-60rpx);
}

.box-lid.common { background: linear-gradient(135deg, #4B5563, #6B7280); border-color: rgba(156,163,175,0.6); }
.box-lid.uncommon { background: linear-gradient(135deg, #065F46, #059669); border-color: rgba(52,211,153,0.6); }
.box-lid.rare { background: linear-gradient(135deg, #1E3A5F, #2563EB); border-color: rgba(96,165,250,0.6); }
.box-lid.epic { background: linear-gradient(135deg, #4C1D95, #7C3AED); border-color: rgba(167,139,250,0.8); }
.box-lid.legendary { background: linear-gradient(135deg, #92400E, #F59E0B); border-color: rgba(251,191,36,0.8); }

.box-ribbon {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120%;
  height: 16rpx;
  transform: translate(-50%, -50%) rotate(-25deg);
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
}

.box-bow {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  box-shadow: 0 0 20rpx currentColor;
}

.box-bow.common { background: #9CA3AF; color: rgba(156,163,175,0.6); }
.box-bow.uncommon { background: #34D399; color: rgba(52,211,153,0.6); }
.box-bow.rare { background: #60A5FA; color: rgba(96,165,250,0.6); }
.box-bow.epic { background: #A78BFA; color: rgba(167,139,250,0.8); }
.box-bow.legendary { background: #FBBF24; color: rgba(251,191,36,0.8); }

.box-base {
  position: absolute;
  top: 40rpx;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(30,30,50,0.95), rgba(20,20,40,0.98));
  border-radius: 0 0 20rpx 20rpx;
  border: 3rpx solid rgba(147, 112, 219, 0.4);
  border-top: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.box-question {
  font-size: 100rpx;
  font-weight: 800;
  color: rgba(147, 112, 219, 0.6);
  text-shadow: 0 0 40rpx rgba(147, 112, 219, 0.4);
  animation: questionPulse 1.5s ease-in-out infinite;
}

.box-glow {
  position: absolute;
  inset: -10rpx;
  border-radius: 24rpx;
  opacity: 0.5;
  filter: blur(15rpx);
  z-index: -1;
  animation: boxGlowPulse 2s ease-in-out infinite;
}

.box-glow.common { background: rgba(156,163,175,0.3); }
.box-glow.uncommon { background: rgba(52,211,153,0.3); }
.box-glow.rare { background: rgba(96,165,250,0.3); }
.box-glow.epic { background: rgba(167,139,250,0.4); }
.box-glow.legendary { background: rgba(251,191,36,0.5); }

/* 提示文字 */
.box-hint {
  margin-top: 60rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 4rpx;
  transition: all 0.3s;
}

.box-hint.hidden { opacity: 0; transform: translateY(20rpx); }

.shake-hint {
  opacity: 0;
  transform: translateY(20rpx);
  color: rgba(147, 112, 219, 0.8);
  animation: hintBlink 0.5s ease-in-out infinite alternate;
}

.shake-hint.visible { opacity: 1; }

/* === 聚光阶段 === */
.light-stage {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.light-stage.active {
  opacity: 1;
}

.light-ray {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 300rpx;
  transform-origin: center bottom;
  opacity: 0;
}

.light-stage.active .light-ray {
  animation: rayAppear 1s ease-out forwards;
}

.ray-inner {
  width: 100%;
  height: 100%;
  border-radius: 2rpx;
  opacity: 0.6;
}

.ray-inner.common { background: linear-gradient(to top, rgba(156,163,175,0.6), transparent); }
.ray-inner.uncommon { background: linear-gradient(to top, rgba(52,211,153,0.6), transparent); }
.ray-inner.rare { background: linear-gradient(to top, rgba(96,165,250,0.6), transparent); }
.ray-inner.epic { background: linear-gradient(to top, rgba(167,139,250,0.8), transparent); }
.ray-inner.legendary { background: linear-gradient(to top, rgba(251,191,36,0.8), transparent); }

.light-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60rpx;
  height: 60rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  animation: corePulse 0.5s ease-in-out infinite alternate;
}

.light-core.common { background: radial-gradient(circle, rgba(156,163,175,0.8), transparent); }
.light-core.uncommon { background: radial-gradient(circle, rgba(52,211,153,0.8), transparent); }
.light-core.rare { background: radial-gradient(circle, rgba(96,165,250,0.8), transparent); }
.light-core.epic { background: radial-gradient(circle, rgba(167,139,250,0.9), transparent); }
.light-core.legendary { background: radial-gradient(circle, rgba(251,191,36,0.9), transparent); }

/* === 爆发阶段 === */
.explosion-stage {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.explosion-stage.active {
  opacity: 1;
}

.particle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: var(--size, 8rpx);
  height: var(--size, 8rpx);
  margin: calc(var(--size, 8rpx) / -2);
  border-radius: 50%;
  background: var(--color, #9370DB);
  opacity: 0;
  box-shadow: 0 0 10rpx var(--color, #9370DB);
}

.explosion-stage.active .particle {
  animation: particleFly var(--duration, 500ms) var(--delay, 0ms) ease-out forwards;
}

.flash-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0;
  pointer-events: none;
}

.explosion-stage.active .flash-overlay {
  animation: flashEffect 0.3s ease-out forwards;
}

.flash-overlay.common { background: radial-gradient(circle, rgba(156,163,175,0.3), transparent); }
.flash-overlay.uncommon { background: radial-gradient(circle, rgba(52,211,153,0.3), transparent); }
.flash-overlay.rare { background: radial-gradient(circle, rgba(96,165,250,0.3), transparent); }
.flash-overlay.epic { background: radial-gradient(circle, rgba(167,139,250,0.4), transparent); }
.flash-overlay.legendary { background: radial-gradient(circle, rgba(251,191,36,0.5), transparent); }

/* === 揭晓阶段 === */
.reveal-stage {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.reveal-stage.active {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.reveal-glow {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  opacity: 0.3;
  animation: glowPulse 2s ease-in-out infinite;
}

.reveal-glow.common { background: radial-gradient(circle, rgba(156,163,175,0.3), transparent); }
.reveal-glow.uncommon { background: radial-gradient(circle, rgba(52,211,153,0.3), transparent); }
.reveal-glow.rare { background: radial-gradient(circle, rgba(96,165,250,0.3), transparent); }
.reveal-glow.epic { background: radial-gradient(circle, rgba(167,139,250,0.4), transparent); }
.reveal-glow.legendary { background: radial-gradient(circle, rgba(251,191,36,0.5), transparent); }

.reveal-card {
  position: relative;
  z-index: 2;
  width: 400rpx;
  background: linear-gradient(135deg, rgba(20,20,40,0.95), rgba(10,10,25,0.98));
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid;
  box-shadow: 0 0 60rpx;
}

.reveal-card.common { border-color: rgba(156,163,175,0.4); box-shadow: 0 0 40rpx rgba(156,163,175,0.3); }
.reveal-card.uncommon { border-color: rgba(52,211,153,0.4); box-shadow: 0 0 40rpx rgba(52,211,153,0.3); }
.reveal-card.rare { border-color: rgba(96,165,250,0.4); box-shadow: 0 0 40rpx rgba(96,165,250,0.3); }
.reveal-card.epic { border-color: rgba(167,139,250,0.5); box-shadow: 0 0 50rpx rgba(167,139,250,0.4); }
.reveal-card.legendary { border-color: rgba(251,191,36,0.6); box-shadow: 0 0 60rpx rgba(251,191,36,0.5); }

.reveal-badge {
  position: absolute;
  top: -24rpx;
  padding: 8rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 0 30rpx;
}

.reveal-badge.common { background: linear-gradient(135deg, #4B5563, #6B7280); color: #fff; box-shadow: 0 0 20rpx rgba(156,163,175,0.4); }
.reveal-badge.uncommon { background: linear-gradient(135deg, #065F46, #059669); color: #fff; box-shadow: 0 0 20rpx rgba(52,211,153,0.4); }
.reveal-badge.rare { background: linear-gradient(135deg, #1E3A5F, #2563EB); color: #fff; box-shadow: 0 0 20rpx rgba(96,165,250,0.4); }
.reveal-badge.epic { background: linear-gradient(135deg, #4C1D95, #7C3AED); color: #fff; box-shadow: 0 0 30rpx rgba(167,139,250,0.5); }
.reveal-badge.legendary { background: linear-gradient(135deg, #92400E, #F59E0B); color: #fff; box-shadow: 0 0 40rpx rgba(251,191,36,0.6); animation: legendaryShine 1s ease-in-out infinite; }

.badge-text { color: #fff; }

.reveal-image-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 20rpx 0;
  border: 2rpx solid rgba(255,255,255,0.1);
}

.reveal-image {
  width: 100%;
  height: 100%;
}

.image-glow {
  position: absolute;
  inset: 0;
  opacity: 0.3;
}

.image-glow.common { background: radial-gradient(circle, rgba(156,163,175,0.4), transparent); }
.image-glow.uncommon { background: radial-gradient(circle, rgba(52,211,153,0.4), transparent); }
.image-glow.rare { background: radial-gradient(circle, rgba(96,165,250,0.4), transparent); }
.image-glow.epic { background: radial-gradient(circle, rgba(167,139,250,0.5), transparent); }
.image-glow.legendary { background: radial-gradient(circle, rgba(251,191,36,0.6), transparent); }

.reveal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin: 16rpx 0 24rpx;
  text-shadow: 0 0 20rpx;
}

.reveal-card.common .reveal-title { text-shadow: 0 0 10rpx rgba(156,163,175,0.5); }
.reveal-card.uncommon .reveal-title { text-shadow: 0 0 10rpx rgba(52,211,153,0.5); }
.reveal-card.rare .reveal-title { text-shadow: 0 0 10rpx rgba(96,165,250,0.5); }
.reveal-card.epic .reveal-title { text-shadow: 0 0 20rpx rgba(167,139,250,0.6); }
.reveal-card.legendary .reveal-title { text-shadow: 0 0 30rpx rgba(251,191,36,0.7); animation: legendaryShine 1.5s ease-in-out infinite; }

.reveal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.btn-glow.small {
  padding: 12rpx 36rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-glow.small:active { transform: scale(0.95); }

.btn-glow.small:first-child {
  background: linear-gradient(135deg, #7c3aed, #9370db);
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147,112,219,0.4);
}

.btn-glow.small.secondary {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.8);
}

/* === 传说级金色雨 === */
.legendary-rain {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
}

.rain-particle.gold {
  position: absolute;
  top: -20rpx;
  width: 6rpx;
  height: 20rpx;
  background: linear-gradient(to bottom, transparent, rgba(251,191,36,0.8), rgba(251,191,36,0.6));
  border-radius: 2rpx;
  animation: goldRain 2s linear infinite;
  box-shadow: 0 0 10rpx rgba(251,191,36,0.4);
}

/* === Keyframes === */
@keyframes boxShake {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  25% { transform: translate(-8rpx, 4rpx) rotate(-3deg); }
  50% { transform: translate(8rpx, -4rpx) rotate(3deg); }
  75% { transform: translate(-4rpx, 8rpx) rotate(-2deg); }
}

@keyframes boxFloat {
  0% { transform: translateY(0) scale(1); }
  100% { transform: translateY(-20rpx) scale(1.05); }
}

@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.5; }
}

@keyframes boxGlowPulse {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.05); }
}

@keyframes questionPulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.1); }
}

@keyframes hintBlink {
  0% { opacity: 0.4; }
  100% { opacity: 1; }
}

@keyframes rayAppear {
  0% { opacity: 0; height: 0; }
  50% { opacity: 0.8; }
  100% { opacity: 0; height: 400rpx; }
}

@keyframes corePulse {
  0% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
  100% { transform: translate(-50%, -50%) scale(1.5); opacity: 1; }
}

@keyframes particleFly {
  0% { opacity: 1; transform: translate(0, 0) scale(1); }
  100% { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(0); }
}

@keyframes flashEffect {
  0% { opacity: 0; }
  50% { opacity: 0.8; }
  100% { opacity: 0; }
}

@keyframes legendaryShine {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.3); }
}

@keyframes goldRain {
  0% { transform: translateY(0) rotate(15deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(15deg); opacity: 0; }
}
