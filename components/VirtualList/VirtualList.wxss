.virtual-list-container {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.virtual-scroll {
  width: 100%;
  height: 100%;
  -webkit-overflow-scrolling: touch;
}

.virtual-scroll-content {
  position: relative;
}

.virtual-item-spacer {
  width: 100%;
  pointer-events: none;
}

.virtual-item {
  width: 100%;
  box-sizing: border-box;
}
