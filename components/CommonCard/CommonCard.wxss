.common-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.card-bordered {
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.card-shadow {
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.5);
}

.card-glow {
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.3),
              0 8rpx 32rpx rgba(147, 112, 219, 0.2),
              0 16rpx 64rpx rgba(0, 0, 0, 0.5);
}

.card-hoverable {
  cursor: pointer;
}

.card-hoverable.card-hovered {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 48rpx rgba(147, 112, 219, 0.3),
              0 20rpx 80rpx rgba(0, 0, 0, 0.6);
}

.card-glow-effect {
  position: absolute;
  top: -100%;
  left: -100%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(147, 112, 219, 0.05) 50%,
    transparent 70%
  );
  transition: all 0.6s ease;
  pointer-events: none;
}

.card-hoverable.card-hovered .card-glow-effect {
  animation: cardGlowMove 2s ease-in-out infinite;
}

@keyframes cardGlowMove {
  0% {
    transform: translateX(0) rotate(45deg);
  }
  100% {
    transform: translateX(100%) rotate(45deg);
  }
}
