# ============================================
# Campus BlindBox - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# WARNING: Never commit the actual .env file to version control.
# ============================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=campus_blindbox
MYSQL_USER=blindbox
MYSQL_PASSWORD=blindbox123456
MYSQL_PORT=3306

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MongoDB ---
MONGO_USER=root
MONGO_PASSWORD=root123456
MONGO_DATABASE=campus_blindbox
MONGO_PORT=27017

# --- RocketMQ ---
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_PROXY_PORT=8081

# --- MinIO (Object Storage) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- WeChat Mini Program ---
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here

# --- Object Storage Service ---
OSS_ENDPOINT=localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin123
OSS_BUCKET=campus-blindbox
