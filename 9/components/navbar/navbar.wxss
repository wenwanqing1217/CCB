.navbar {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(26, 26, 46, 0.8);
  backdrop-filter: blur(10rpx);
  color: #fff;
  position: relative;
  z-index: 10;
  border-bottom: 1rpx solid rgba(124, 58, 237, 0.3);
  border-radius: 0 0 20rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 58, 237, 0.3);
}

.navbar-left {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.navbar-center {
  width: 80rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #ffffff;
  text-shadow: 0 0 12rpx rgba(196, 181, 253, 0.8);
  transition: transform 0.2s ease;
}

.back-icon:active {
  transform: translateX(-4rpx);
}

.navbar-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(216, 180, 254, 0.8);
  letter-spacing: 2rpx;
}

.navbar-right {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
