.lazy-image-container {
  position: relative;
  overflow: hidden;
  background: rgba(12, 12, 28, 0.5);
  border-radius: var(--border-radius-sm);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.lazy-image {
  transition: opacity 0.3s ease;
}

.lazy-image-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(12, 12, 28, 0.8);
  backdrop-filter: blur(10rpx);
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top: 3rpx solid var(--primary-light);
  border-right: 3rpx solid var(--secondary-color);
  border-bottom: 3rpx solid #9370db;
  border-left: 3rpx solid var(--secondary-light);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-shadow: 0 0 16rpx var(--primary-light);
}

.lazy-image-error {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(12, 12, 28, 0.8);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.error-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.error-text {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
  text-shadow: 0 0 12rpx var(--primary-light);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
