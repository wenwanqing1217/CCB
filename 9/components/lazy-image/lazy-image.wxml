<view class="lazy-image-container" style="width: {{width}}; height: {{height}};" bindload="onImageLoad" binderror="onImageError">
  <image 
    class="lazy-image" 
    src="{{loading ? loadingSrc : (loaded ? src : placeholderSrc)}}" 
    mode="{{mode}}" 
    style="width: 100%; height: 100%; object-fit: {{mode === 'aspectFill' ? 'cover' : 'contain'}};" 
    bindload="onImageLoad" 
    binderror="onImageError"
  />
  <view class="lazy-image-loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
  </view>
  <view class="lazy-image-error" wx:if="{{error}}">
    <text class="error-icon">📷</text>
    <text class="error-text">加载失败</text>
  </view>
</view>
