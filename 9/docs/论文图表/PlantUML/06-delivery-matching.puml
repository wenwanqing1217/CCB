@startuml 06-delivery-matching
!theme plain
title 顺路匹配算法时序图

skinparam backgroundColor #FFFFFF
skinparam sequenceFontSize 10

actor "订单系统" as Order
participant "deliveryService\n云函数" as DS
participant "MongoDB\nriders集合" as DB
participant "匹配引擎" as Engine

title 顺路匹配算法执行流程

Order -> DS : 触发配送请求\n(订单位置、买家位置)
activate DS

DS -> DS : 获取当前时间\n判断高峰期
note right: 高峰期(8-9, 11-13, 17-19)\n路线质量系数: 0.7\n其他时间: 0.9

DS -> DB : 查询可用骑手\n(status: "available")
activate DB

loop 遍历每个可用骑手
  DB --> DS : 返回骑手信息\n(openid, location, currentOrders)
  
  DS -> Engine : 计算综合得分\nScore = α×D_buyer + β×D_seller + γ×D_route
  activate Engine
  
  note right of Engine
    α = 0.5 (买家距离权重)
    β = 0.3 (卖家距离权重)
    γ = 0.2 (路线质量权重)
    
    D_buyer: 骑手到买家曼哈顿距离
    D_seller: 骑手到卖家曼哈顿距离
    D_route: 路线顺路程度
  end note
  
  Engine --> DS : 返回Score_i
  
  DS -> DS : 更新最优骑手\nif Score_i < BestScore
  
end

Engine --> DS : 最优骑手确定
deactivate Engine

DS -> DS : 计算预计配送时间
note right
  Time = Distance × 2min/km
  最大配送时间: 30分钟
end note

DS -> DB : 更新骑手状态\ncurrentOrders += orderId
DB --> DS : 更新成功

DS -> DB : 更新订单状态\nstatus = "grabbed"
DB --> DS : 更新成功

DS --> Order : 返回匹配结果\n(骑手信息、预计时间)

deactivate DB
deactivate DS

@enduml
