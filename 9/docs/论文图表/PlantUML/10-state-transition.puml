@startuml 10-state-transition
!theme plain
title 订单与配送状态转换图

skinparam backgroundColor #FFFFFF
skinparam stateFontSize 12

state "订单状态" as OrderState {
  
  [*] --> pending : 创建订单
  
  pending --> grabbed : 骑手抢单
  pending --> cancelled : 超时未抢单/用户取消
  
  grabbed --> delivering : 骑手取货完成
  grabbed --> cancelled : 骑手取消/超时
  
  delivering --> completed : 配送完成\n买家确认收货
  delivering --> cancelled : 异常取消
  
  completed --> [*]
  cancelled --> [*]
}

state "配送状态" as DeliveryState {
  
  [*] --> pending : 创建配送记录
  
  pending --> picking : 骑手开始取货
  pending --> cancelled : 取消配送
  
  picking --> delivering : 骑手已取货
  picking --> cancelled : 骑手取消
  
  delivering --> completed : 送达买家
  delivering --> cancelled : 异常
  
  completed --> [*]
  cancelled --> [*]
}

state "盲盒状态" as BoxState {
  
  [*] --> available : 发布盲盒
  
  available --> sold : 订单完成
  available --> donated_pending : 15天未售出\n自动转捐赠
  available --> unavailable : 卖家下架
  
  sold --> [*]
  donated_pending --> donated : 捐赠成功
  unavailable --> available : 重新上架
  
  donated --> [*]
  unavailable --> [*]
}

note "状态说明" as N1
  Order: pending-待抢单, grabbed-已抢单, delivering-配送中, completed-已完成, cancelled-已取消
  Delivery: pending-待取货, picking-取货中, delivering-配送中, completed-已完成
  Box: available-可售, sold-已售, donated_pending-待捐赠, unavailable-已下架
end note

@enduml
