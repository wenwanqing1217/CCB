@startuml 04-box-publish-flow
!theme plain
title 盲盒发布流程图

skinparam backgroundColor #FFFFFF
skinparam activityFontSize 12
skinparam noteFontSize 10

start

:填写盲盒信息\n(标题、类型、价格等)];

:上传盲盒图片;

:设置盲盒分类\n和描述];

:确认发布信息;

if (信息完整且有效?) then (否)
  :提示用户补充信息];
  detach
else (是)
endif

:调用boxService云函数\npublishBox action];

if (发布成功?) then (失败)
  :显示错误信息];
  :提示用户重试];
  detach
else (成功)
endif

:生成盲盒记录\n写入boxes集合];

:更新卖家积分\n(首次发布+5积分)];

:显示发布成功提示];

stop

@enduml
