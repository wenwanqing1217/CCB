.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(135deg, rgba(5, 5, 16, 0.98) 0%, rgba(8, 8, 25, 0.99) 100%);
  border-top: 1rpx solid rgba(147, 112, 219, 0.2);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 30rpx rgba(147, 112, 219, 0.1);
  border-radius: 24rpx 24rpx 0 0;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  letter-spacing: 2rpx;
  transition: all 0.3s ease;
}

.tab-bar-item.active .tab-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #c8a2ff;
  text-shadow:
    0 0 10rpx rgba(200, 162, 255, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: tabGlow 3s ease-in-out infinite;
}

@keyframes tabGlow {
  0%, 100% {
    text-shadow:
      0 0 10rpx rgba(200, 162, 255, 0.8),
      0 0 20rpx rgba(147, 112, 219, 0.6),
      0 0 30rpx rgba(147, 112, 219, 0.4),
      0 0 40rpx rgba(186, 85, 211, 0.3);
    filter: brightness(1);
  }
  50% {
    text-shadow:
      0 0 15rpx rgba(200, 162, 255, 1),
      0 0 30rpx rgba(147, 112, 219, 0.8),
      0 0 45rpx rgba(186, 85, 211, 0.6),
      0 0 60rpx rgba(200, 162, 255, 0.4);
    filter: brightness(1.3);
  }
}
