.container {
  padding: 32rpx 24rpx;
  min-height: 100vh;
  background-color: #020208;
}

.page-header {
  padding: 32rpx 0 24rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.dashboard {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.dashboard-item {
  padding: 28rpx 16rpx;
  text-align: center;
  background: linear-gradient(145deg, #111827 0%, #0f172a 100%);
  border: 1rpx solid rgba(255, 182, 193, 0.08);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
}

.dashboard-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.dashboard-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #38BDF8;
  letter-spacing: -0.5rpx;
}

.my-boxes {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
}

.box-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.box-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #111827 0%, #0f172a 100%);
  border: 1rpx solid rgba(255, 182, 193, 0.08);
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.box-card:active {
  transform: scale(0.98);
}

.box-image {
  width: 100%;
  height: 220rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(145deg, #1f2937 0%, #111827 100%);
  border: 1rpx solid rgba(255, 182, 193, 0.06);
}

.box-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 10rpx;
  letter-spacing: 0.3rpx;
}

.box-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #38BDF8;
  margin-bottom: 10rpx;
  letter-spacing: -0.5rpx;
}

.box-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 160rpx 0;
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 24rpx;
  color: #38BDF8;
  font-weight: 500;
}





