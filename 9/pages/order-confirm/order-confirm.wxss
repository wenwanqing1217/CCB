.container {
  background-color: #020208;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.header {
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  text-align: center;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #c8a2ff;
  margin-bottom: 20rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.order-section,
.address-section,
.payment-section,
.remark-section,
.price-section {
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.15);
}

.box-info {
  display: flex;
  gap: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.2);
}

.box-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.box-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.box-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f8fafc;
  line-height: 1.3;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.box-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

.box-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: auto;
}

.box-category {
  font-size: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #7c3aed 0%, #9333ea 100%);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.box-location {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.box-price-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.box-price {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(244, 63, 94, 0.5);
}

.box-hint {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.1);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.address-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, rgba(10, 10, 20, 0.8) 0%, rgba(15, 15, 30, 0.6) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.15);
  cursor: pointer;
  transition: all 0.3s ease;
}

.address-card:active {
  transform: scale(0.98);
}

.address-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.address-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.address-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.address-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.address-detail {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

.address-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.payment-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, rgba(10, 10, 20, 0.8) 0%, rgba(15, 15, 30, 0.6) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 20rpx;
  padding: 20rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.payment-item.active {
  border-color: #7c3aed;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.payment-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.payment-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  flex: 1;
}

.payment-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
}

.payment-check {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.payment-check.active {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 100%);
  border-color: #7c3aed;
  color: white;
  font-size: 20rpx;
  font-weight: 600;
}

.remark-input {
  background: rgba(10, 10, 26, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #ffffff;
  box-shadow: 0 0 10rpx rgba(147, 112, 219, 0.1);
  width: 100%;
  box-sizing: border-box;
  transition: all 0.2s ease;
  min-height: 80rpx;
}

.remark-input:focus {
  border-color: rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.2);
  outline: none;
  transform: none;
}

.remark-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

.price-section {
  background: linear-gradient(135deg, rgba(10, 10, 20, 0.8) 0%, rgba(15, 15, 30, 0.6) 100%);
  border-radius: 24rpx;
  margin: 30rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.15);
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-row.total {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.15);
}

.price-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.price-label.total {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.price-value {
  font-size: 24rpx;
  color: #f8fafc;
}

.price-value.total {
  font-size: 32rpx;
  font-weight: 700;
  color: #f43f5e;
  text-shadow: 0 0 10rpx rgba(244, 63, 94, 0.5);
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.98) 0%, rgba(20, 20, 40, 0.98) 100%);
  border-top: 1rpx solid rgba(147, 112, 219, 0.3);
  z-index: 100;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 -10rpx 40rpx rgba(147, 112, 219, 0.3);
}

.submit-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #ffffff;
  border-radius: 999rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(200, 162, 255, 0.5);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.5);
  transition: all 0.3s ease;
  cursor: pointer;
}

.submit-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 40rpx rgba(147, 112, 219, 0.7);
}





