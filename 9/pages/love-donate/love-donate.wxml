<view class="container">
  <view class="header">
    <text class="header-title">爱心捐赠</text>
  </view>

  <view class="filter-bar">
    <view class="filter-item {{activeFilter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-filter="all">全部</view>
    <view class="filter-item {{activeFilter === 'book' ? 'active' : ''}}" bindtap="setFilter" data-filter="book">图书</view>
    <view class="filter-item {{activeFilter === 'daily' ? 'active' : ''}}" bindtap="setFilter" data-filter="daily">日用品</view>
    <view class="filter-item {{activeFilter === 'electronics' ? 'active' : ''}}" bindtap="setFilter" data-filter="electronics">数码</view>
    <view class="filter-item {{activeFilter === 'other' ? 'active' : ''}}" bindtap="setFilter" data-filter="other">其他</view>
  </view>

  <scroll-view class="content-scroll" scroll-y bindscrolltolower="loadMore">
    <view class="donation-list">
      <view class="donation-card" wx:for="{{donationItems}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}">
        <view class="card-image-wrap">
          <image class="card-image" src="{{item.images[0]}}" mode="aspectFill" />
          <view class="love-badge">
            <text class="love-icon">❤️</text>
            <text class="love-text">+{{item.lovePoints}}</text>
          </view>
          <view class="status-badge {{item.status}}">{{item.statusText}}</view>
        </view>
        <view class="card-content">
          <text class="card-title">{{item.title}}</text>
          <text class="card-desc">{{item.description}}</text>
          <view class="card-footer">
            <view class="user-info">
              <image class="user-avatar" src="{{item.userAvatar}}" mode="aspectFill" />
              <text class="user-name">{{item.userName}}</text>
            </view>
            <view class="location-info">
              <text class="location-icon">📍</text>
              <text class="location-text">{{item.location}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && donationItems.length > 0}}">
      <text>没有更多了</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && donationItems.length === 0}}">
      <text class="empty-icon">🎁</text>
      <text class="empty-text">暂无捐赠物品</text>
      <text class="empty-hint">成为第一个捐赠者吧</text>
      <view class="empty-btn" bindtap="navigateToPublish">去捐赠</view>
    </view>
  </scroll-view>

  <view class="publish-btn" bindtap="navigateToPublish">
    <text class="publish-icon">+</text>
    <text class="publish-text">发布捐赠</text>
  </view>
</view>
