/* 爱心捐赠列表页面样式 */

page {
  background-color: #020208;
}

.container {
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
}

/* 背景光效 */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 20%, rgba(147, 112, 219, 0.08) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(186, 85, 211, 0.06) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* 头部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 24rpx 20rpx;
  background: linear-gradient(180deg, rgba(10,10,26,0.98) 0%, transparent 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 10;
}

.header-left,
.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.header-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  margin: 0 8rpx;
  background: rgba(147, 112, 219, 0.12);
  border: 1rpx solid rgba(147, 112, 219, 0.35);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  white-space: nowrap;
  transition: all 0.2s ease;
  position: relative;
  z-index: 1;
}

.filter-item:first-child {
  margin-left: 0;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item:active {
  opacity: 0.7;
}

.filter-item.active {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-color: rgba(200, 162, 255, 0.6);
  color: #fff;
  box-shadow: 0 0 24rpx rgba(147, 112, 219, 0.45);
}

/* 内容滚动�?*/
.content-scroll {
  padding: 20rpx 0;
  min-height: 600rpx;
  position: relative;
  z-index: 1;
}

/* 捐赠列表 */
.donation-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  z-index: 1;
}

/* 捐赠卡片 */
.donation-card {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  overflow: hidden;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(147, 112, 219, 0.15);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

.donation-card:active {
  opacity: 0.85;
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.3);
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
}

.love-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(244, 63, 94, 0.4);
  z-index: 2;
}

.love-icon {
  font-size: 20rpx;
}

.love-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.status-badge {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  z-index: 2;
}

.status-badge.claimed {
  background: rgba(100, 100, 100, 0.6);
  color: rgba(255, 255, 255, 0.6);
}

.card-content {
  padding: 24rpx;
}

.card-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.2);
}

.card-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.user-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(147, 112, 219, 0.35);
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.25);
}

.user-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.25);
}

.location-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.location-icon {
  font-size: 20rpx;
}

.location-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
}

/* 加载更多 */
.loading-more,
.no-more {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 1;
}

/* 空状�?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
  filter: drop-shadow(0 0 20rpx rgba(147, 112, 219, 0.4));
}

.empty-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.4);
  transition: all 0.3s ease;
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.6);
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  right: 30rpx;
  bottom: 60rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.85) 100%);
  backdrop-filter: blur(20rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(139, 92, 246, 0.4);
  z-index: 100;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.publish-btn:active {
  opacity: 0.85;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.6);
  border-color: rgba(139, 92, 246, 0.6);
}

.publish-icon {
  font-size: 40rpx;
  color: #c8a2ff;
  font-weight: 300;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4);
}

.publish-text {
  font-size: 18rpx;
  color: #c8a2ff;
  font-weight: 500;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6);
}





