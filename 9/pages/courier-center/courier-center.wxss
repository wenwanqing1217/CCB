.page {
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
  padding: 24rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

.card {
  position: relative;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  z-index: 1;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.7;
  white-space: pre-wrap;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.tab {
  flex: 1;
  background: rgba(5, 5, 15, 0.8);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  backdrop-filter: blur(12rpx);
  transition: all 0.3s;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.tab.active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.25) 100%);
  border: 2rpx solid rgba(186, 85, 211, 0.6);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4),
              0 0 40rpx rgba(147, 112, 219, 0.2);
  color: #ffffff;
  font-weight: 600;
}

.tab:active {
  transform: scale(0.95);
}

.item {
  animation: cardFloat 4s ease-in-out infinite;
  animation-delay: 0.4s;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.2);
}

.order-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.4;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
  margin-right: 20rpx;
}

.order-price {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
  flex-shrink: 0;
}

.order-info {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.1);
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  flex-shrink: 0;
  min-width: 120rpx;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
  color: #ffffff;
  text-align: right;
  margin-left: 20rpx;
}

.status-pending {
  color: #fbbf24;
  text-shadow: 0 0 10rpx rgba(251, 191, 36, 0.3);
}

.status-delivering {
  color: #3b82f6;
  text-shadow: 0 0 10rpx rgba(59, 130, 246, 0.3);
}

.status-completed {
  color: #10b981;
  text-shadow: 0 0 10rpx rgba(16, 185, 129, 0.3);
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.2);
}

.btn {
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
              0 0 40rpx rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.btn-grab {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
              0 0 40rpx rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: none;
  transition: all 0.3s;
}

.btn-grab:active {
  transform: scale(0.95);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.empty-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  margin-top: 12rpx;
}

.divider-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 32rpx 0 24rpx;
  position: relative;
  z-index: 1;
}

.divider-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #9370db 0%, #ba55d3 100%);
  border-radius: 3rpx;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.divider-title text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #9370db 0%, #ba55d3 50%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.8;
  filter: drop-shadow(0 0 20rpx rgba(147, 112, 219, 0.5));
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
  line-height: 1.5;
  padding: 0 48rpx;
}

@keyframes cardFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
}





