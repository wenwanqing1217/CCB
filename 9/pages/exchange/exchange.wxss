/* 交换页面 - 重新设计 */

page {
  background-color: #020208;
}

.container {
  min-height: 100vh;
  background: #020208;
  padding: 20rpx;
  padding-bottom: 40rpx;
  position: relative;
  overflow-x: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 顶部区域 */
.top-section {
  margin-bottom: 24rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 8rpx 0 8rpx;
  margin-bottom: 16rpx;
}

.search-input {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.2),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  animation: heroBorderGlow 3s ease-in-out infinite;
}

.search-input input {
  flex: 1;
  font-size: 24rpx;
  color: #f8fafc;
  background: transparent;
  border: none;
  outline: none;
  height: 40rpx;
  line-height: 40rpx;
}

.search-input input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

.search-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.8) 0%, rgba(5, 5, 15, 0.9) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.search-btn-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 16rpx;
  gap: 8rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.3s ease;
}

.tab-bar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  animation: headerGlow 3s ease-in-out infinite;
  z-index: 3;
}

.tab-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 30%, rgba(147, 112, 219, 0.25) 0%, transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(186, 85, 211, 0.2) 0%, transparent 40%),
              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.15) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
  animation: heroGlow 8s ease-in-out infinite;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5),
              0 0 20rpx rgba(147, 112, 219, 0.3),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.tab-item.active {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.5),
              0 4rpx 16rpx rgba(0, 0, 0, 0.5);
  transform: translateY(-2rpx);
  border-color: rgba(200, 162, 255, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.7),
               0 0 30rpx rgba(255, 255, 255, 0.5);
  animation: brandGlow 3s ease-in-out infinite;
}

/* 提示区域 */
.hint-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.3s ease;
}

.hint-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  animation: headerGlow 3s ease-in-out infinite;
  z-index: 3;
}

.hint-section::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 30%, rgba(147, 112, 219, 0.25) 0%, transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(186, 85, 211, 0.2) 0%, transparent 40%),
              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.15) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
  animation: heroGlow 8s ease-in-out infinite;
}

.hint-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.hint-icon {
  font-size: 40rpx;
  animation: iconFloat 2s ease-in-out infinite;
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.7);
}

.hint-icon.left {
  animation-delay: 0s;
}

.hint-icon.right {
  animation-delay: 0.3s;
}

.hint-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

.hint-divider {
  width: 2rpx;
  height: 48rpx;
  background: linear-gradient(180deg, transparent, rgba(147, 112, 219, 0.5), transparent);
}

/* 卡片区域 */
.card-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 滑动容器 */
.swipe-container {
  position: relative;
  height: 60vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 20rpx;
}

.card-wrapper {
  position: absolute;
  width: 100%;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 卡片样式 */
.swipe-card {
  background: linear-gradient(135deg, 
    rgba(12, 12, 28, 0.98) 0%, 
    rgba(5, 5, 15, 0.99) 50%, 
    rgba(12, 12, 28, 0.98) 100%
  );
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  will-change: transform;
  transition: all 0.3s ease;
  z-index: 1;
}

.swipe-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.5) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.5) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
  animation: headerGlow 3s ease-in-out infinite;
}

/* 顶部发光边框 */
.swipe-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  animation: headerGlow 3s ease-in-out infinite;
  z-index: 3;
}

/* 背景光晕效果 */
.swipe-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 30%, rgba(147, 112, 219, 0.25) 0%, transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(186, 85, 211, 0.2) 0%, transparent 40%),
              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.15) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
  animation: heroGlow 8s ease-in-out infinite;
}

@keyframes headerGlow {
  0%, 100% {
    opacity: 0.7;
    box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  }
  50% {
    opacity: 1;
    box-shadow: 0 0 30rpx rgba(200, 162, 255, 0.9),
                0 0 40rpx rgba(186, 85, 211, 0.7);
  }
}



@keyframes heroGlow {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}

@keyframes blingBling {
  0%, 100% {
    text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5),
                 0 0 20rpx rgba(255, 255, 255, 0.3),
                 0 0 30rpx rgba(255, 255, 255, 0.2);
    opacity: 1;
  }
  50% {
    text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8),
                 0 0 30rpx rgba(255, 255, 255, 0.6),
                 0 0 50rpx rgba(255, 255, 255, 0.4),
                 0 0 70rpx rgba(255, 255, 255, 0.2);
    opacity: 0.9;
  }
}

@keyframes grabBodyGlow {
  0%, 100% {
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.3),
      0 0 60rpx rgba(147, 112, 219, 0.15),
      0 4rpx 16rpx rgba(0, 0, 0, 0.3);
    border-color: rgba(147, 112, 219, 0.5);
  }
  50% {
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.4),
      0 0 80rpx rgba(147, 112, 219, 0.25),
      0 4rpx 16rpx rgba(0, 0, 0, 0.3);
    border-color: rgba(147, 112, 219, 0.8);
  }
}

@keyframes iconFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-4rpx) rotate(2deg); }
  50% { transform: translateY(0) rotate(0deg); }
  75% { transform: translateY(4rpx) rotate(-2deg); }
}

@keyframes brandGlow {
  0%, 100% {
    text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.8),
                 0 0 20rpx rgba(147, 112, 219, 0.6),
                 0 0 30rpx rgba(147, 112, 219, 0.4),
                 0 0 40rpx rgba(186, 85, 211, 0.3);
  }
  50% {
    text-shadow: 0 0 15rpx rgba(147, 112, 219, 1),
                 0 0 30rpx rgba(147, 112, 219, 0.8),
                 0 0 45rpx rgba(147, 112, 219, 0.6),
                 0 0 60rpx rgba(186, 85, 211, 0.4);
  }
}

/* 滑动指示器 */
.like-indicator,
.nope-indicator {
  position: absolute;
  top: 48rpx;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  font-size: 36rpx;
  font-weight: 800;
  z-index: 10;
  transform: rotate(-15deg);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4),
              0 0 30rpx rgba(255, 255, 255, 0.3);
  animation: blingBling 2s ease-in-out infinite;
}

.like-indicator {
  right: 48rpx;
  background: linear-gradient(135deg, #10b981, #34d399);
  color: white;
  border: 3rpx solid #10b981;
  text-shadow: 0 0 15rpx rgba(52, 211, 153, 0.8),
               0 0 30rpx rgba(16, 185, 129, 0.6);
}

.nope-indicator {
  left: 48rpx;
  background: linear-gradient(135deg, #ef4444, #f87171);
  color: white;
  border: 3rpx solid #ef4444;
  text-shadow: 0 0 15rpx rgba(248, 113, 113, 0.8),
               0 0 30rpx rgba(239, 68, 68, 0.6);
}

/* 卡片顶部 */
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 3rpx solid rgba(147, 112, 219, 0.6);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.4);
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 16rpx rgba(255, 255, 255, 0.2);
}

.user-school {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.card-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 500;
}

/* 交换信息 */
.exchange-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
  animation: grabBodyGlow 3s ease-in-out infinite;
}

.item-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.item-box.want {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.25), rgba(251, 191, 36, 0.15));
  border: 1rpx solid rgba(251, 191, 36, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.2);
}

.item-box.have {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.25), rgba(52, 211, 153, 0.15));
  border: 1rpx solid rgba(52, 211, 153, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.box-tag {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3),
              0 0 20rpx rgba(255, 255, 255, 0.3);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.7);
  animation: blingBling 2s ease-in-out infinite;
}

.item-box.want .box-tag {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.5),
              0 0 20rpx rgba(251, 191, 36, 0.4);
}

.item-box.have .box-tag {
  background: linear-gradient(135deg, #10b981, #34d399);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.5),
              0 0 20rpx rgba(52, 211, 153, 0.4);
}

.item-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

.exchange-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 800;
  text-shadow: 0 0 16rpx rgba(147, 112, 219, 0.4);
  animation: iconFloat 2s ease-in-out infinite;
}

/* 描述 */
.card-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

/* 图片 */
.card-imgs {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.card-img {
  flex: 1;
  height: 260rpx;
  max-width: none;
  border-radius: 16rpx;
  object-fit: cover;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.card-img:hover {
  transform: scale(1.02);
  box-shadow: 0 6rpx 24rpx rgba(147, 112, 219, 0.4);
}

/* 卡片底部按钮 - 小部件样式 */
.card-bottom {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  padding-top: 20rpx;
  padding-bottom: 8rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.3);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.5);
  border-radius: 28rpx;
  padding: 16rpx 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  z-index: 3;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    0 0 40rpx rgba(147, 112, 219, 0.4),
    0 0 60rpx rgba(147, 112, 219, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  min-width: 120rpx;
  justify-content: center;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 28rpx;
  z-index: -1;
}

.action-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  animation: btnShine 3s ease-in-out infinite;
  z-index: -1;
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

@keyframes heroBorderGlow {
  0%, 100% {
    box-shadow: 
      0 4rpx 30rpx rgba(147, 112, 219, 0.2),
      0 0 60rpx rgba(147, 112, 219, 0.15),
      0 0 100rpx rgba(147, 112, 219, 0.1);
    border-color: rgba(147, 112, 219, 0.5);
  }
  50% {
    box-shadow: 
      0 4rpx 40rpx rgba(147, 112, 219, 0.3),
      0 0 80rpx rgba(147, 112, 219, 0.25),
      0 0 120rpx rgba(147, 112, 219, 0.2);
    border-color: rgba(147, 112, 219, 0.8);
  }
}

.btn-icon {
  font-size: 28rpx;
  transition: all 0.3s ease;
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.7);
}

.btn-text {
  font-size: 24rpx;
  font-weight: 700;
  transition: all 0.3s ease;
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.7);
}

/* 不换按钮 */
.action-btn.skip {
  border-color: rgba(239, 68, 68, 0.6);
  background: rgba(239, 68, 68, 0.1);
}

.action-btn.skip .btn-icon {
  color: #f87171;
}

.action-btn.skip .btn-text {
  color: #f87171;
}

.action-btn.skip:hover {
  background: rgba(239, 68, 68, 0.2);
  box-shadow: 0 6rpx 20rpx rgba(239, 68, 68, 0.3);
  transform: translateY(-2rpx);
}

.action-btn.skip:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 50rpx rgba(239, 68, 68, 0.5),
    0 0 70rpx rgba(239, 68, 68, 0.3);
  border-color: rgba(239, 68, 68, 0.7);
}

/* 私信按钮 */
.action-btn.chat {
  border-color: rgba(124, 58, 237, 0.6);
}

.action-btn.chat .btn-icon {
  color: #c8a2ff;
  text-shadow: 
    0 0 15rpx rgba(147, 112, 219, 0.9),
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 45rpx rgba(186, 85, 211, 0.5);
}

.action-btn.chat .btn-text {
  color: #c8a2ff;
  text-shadow: 
    0 0 15rpx rgba(147, 112, 219, 0.9),
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 45rpx rgba(186, 85, 211, 0.5);
}

.action-btn.chat:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 50rpx rgba(124, 58, 237, 0.5),
    0 0 70rpx rgba(124, 58, 237, 0.3);
  border-color: rgba(124, 58, 237, 0.7);
}

/* 交换按钮 */
.action-btn.like {
  border-color: rgba(16, 185, 129, 0.6);
}

.action-btn.like .btn-icon {
  color: #34d399;
  text-shadow: 
    0 0 15rpx rgba(16, 185, 129, 0.9),
    0 0 30rpx rgba(16, 185, 129, 0.7),
    0 0 45rpx rgba(52, 211, 153, 0.5);
}

.action-btn.like .btn-text {
  color: #34d399;
  text-shadow: 
    0 0 15rpx rgba(16, 185, 129, 0.9),
    0 0 30rpx rgba(16, 185, 129, 0.7),
    0 0 45rpx rgba(52, 211, 153, 0.5);
}

.action-btn.like:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 50rpx rgba(16, 185, 129, 0.5),
    0 0 70rpx rgba(16, 185, 129, 0.3);
  border-color: rgba(16, 185, 129, 0.7);
}

/* 操作区域 */
.action-section {
  margin-top: 24rpx;
  margin-bottom: 24rpx;
  z-index: 10;
  position: relative;
}

/* 发布按钮 */
.publish-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border: 2rpx solid rgba(200, 162, 255, 0.8);
  border-radius: 28rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  z-index: 3;
  box-shadow: 
    0 16rpx 48rpx rgba(124, 58, 237, 0.5),
    0 0 64rpx rgba(124, 58, 237, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  margin: 0 auto;
  width: 80%;
  max-width: 500rpx;
  animation: heroBorderGlow 3s ease-in-out infinite;
}

.publish-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 28rpx;
  z-index: -1;
}

.publish-button::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  animation: btnShine 3s ease-in-out infinite;
  z-index: -1;
}

.button-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 
    0 0 20rpx rgba(255, 255, 255, 0.9),
    0 0 40rpx rgba(255, 255, 255, 0.7),
    0 0 60rpx rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
  animation: blingBling 2s ease-in-out infinite;
}

.publish-button:active {
  transform: translateY(4rpx) scale(0.96);
  box-shadow: 
    0 8rpx 32rpx rgba(124, 58, 237, 0.4),
    0 0 40rpx rgba(124, 58, 237, 0.3);
  border-color: rgba(200, 162, 255, 1);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 24rpx;
  gap: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
  text-align: center;
}

/* 刷新按钮 */
.refresh-btn {
  padding: 18rpx 32rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 6rpx 24rpx rgba(124, 58, 237, 0.4);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(200, 162, 255, 0.4);
}

.refresh-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(124, 58, 237, 0.5);
}

.refresh-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 20rpx rgba(124, 58, 237, 0.4);
}

/* 响应式调整 */
@media (max-height: 600px) {
  .swipe-container {
    height: 60vh;
  }
  
  .card-section {
    gap: 12rpx;
  }
}

@media (min-height: 800px) {
  .swipe-container {
    height: 70vh;
  }
}
