<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="nav-title">我的订单</text>
    <view class="nav-right"></view>
  </view>

  <!-- 标签切换 -->
  <view class="tabs">
    <view class="tab {{tab === 'buy' ? 'active' : ''}}" data-tab="buy" bindtap="switchTab">
      <text>我买到的</text>
      <view class="tab-line"></view>
    </view>
    <view class="tab {{tab === 'sell' ? 'active' : ''}}" data-tab="sell" bindtap="switchTab">
      <text>我卖出的</text>
      <view class="tab-line"></view>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-list" scroll-y>
    <block wx:if="{{list.length === 0 && !loading}}">
      <view class="empty-state">
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无订单</text>
        <text class="empty-hint">去逛逛，发现更多好物</text>
        <view class="empty-btn" bindtap="goToMarket">
          <text>去购物</text>
          <text class="btn-arrow">→</text>
        </view>
      </view>
    </block>

    <block wx:for="{{list}}" wx:key="_id">
      <view class="order-card" bindtap="goDetail" data-id="{{item._id}}">
        <view class="order-header">
          <text class="order-title">{{item.boxInfo.title}}</text>
          <view class="order-status {{item.status}}">
            {{item.status === 'pending' ? '待取件' : item.status === 'delivering' ? '配送中' : '已完成'}}
          </view>
        </view>
        
        <view class="order-body">
          <view class="order-info">
            <view class="info-item">
              <text class="info-label">下单时间</text>
              <text class="info-value">{{item.createdAt ? (item.createdAt | date) : '—'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">配送状态</text>
              <text class="info-value">{{item.status === 'pending' ? '待取件' : item.status === 'delivering' ? '配送中' : '已完成'}}</text>
            </view>
          </view>
          
          <view class="order-price">
            <view class="price-item">
              <text class="price-label">盲盒价格</text>
              <text class="price-value">{{item.price}} 元</text>
            </view>
            <view class="price-item">
              <text class="price-label">配送费</text>
              <text class="price-value">1 元</text>
            </view>
            <view class="price-item total">
              <text class="price-label">合计</text>
              <text class="price-value total">{{item.price + 1}} 元</text>
            </view>
          </view>
        </view>
        
        <view class="order-footer">
          <view class="order-actions">
            <button class="btn-secondary" bindtap="contactSeller" data-id="{{item._id}}">联系卖家</button>
            <button class="btn-primary" bindtap="goDetail" data-id="{{item._id}}">查看详情</button>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{loading}}" class="loading">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
    <view wx:if="{{finished && list.length > 0}}" class="loading">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
