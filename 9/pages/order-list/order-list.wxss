/* и®ўеҚ•еҲ—иЎЁйЎөйқў - зҙ«иүІйң“иҷ№зҒҜйЈҺж ?*/

page {
  background-color: #020208;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #020208 0%, #050510 100%);
  position: relative;
  overflow: hidden;
}

/* иғҢжҷҜе…үж•Ҳ */
.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 20%, rgba(147, 112, 219, 0.08) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(186, 85, 211, 0.06) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* йЎ¶йғЁеҜјиҲӘ */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 20rpx;
  background: linear-gradient(180deg, rgba(10,10,26,0.98) 0%, transparent 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 10;
}

.nav-left,
.nav-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

/* ж ҮзӯҫеҲҮжҚў */
.tabs {
  display: flex;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 1;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
}

.tab text {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.3s ease;
}

.tab.active text {
  color: #f8fafc;
  font-weight: 600;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 2rpx;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
  transform: scaleX(0);
  transition: all 0.3s ease;
}

.tab.active .tab-line {
  transform: scaleX(1);
  animation: tabLineGrow 0.3s ease;
}

@keyframes tabLineGrow {
  0% { transform: scaleX(0); }
  100% { transform: scaleX(1); }
}

/* и®ўеҚ•еҲ—иЎЁ */
.order-list {
  flex: 1;
  padding: 20rpx;
  position: relative;
  z-index: 1;
  height: calc(100vh - 200rpx);
}

/* и®ўеҚ•еҚЎзүҮ */
.order-card {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  position: relative;
  z-index: 1;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.order-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 0 40rpx rgba(147, 112, 219, 0.3);
}

/* и®ўеҚ•еӨҙйғЁ */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.15);
}

.order-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.2);
}

.order-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-shadow: 0 0 10rpx currentColor;
}

.order-status.pending {
  background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(251, 191, 36, 0.4);
}

.order-status.delivering {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.order-status.completed {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.4);
}

/* и®ўеҚ•еҶ…е®№ */
.order-body {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.15);
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.info-value {
  font-size: 24rpx;
  color: #f8fafc;
  font-weight: 500;
}

.order-price {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.price-item.total {
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.2);
}

.price-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.price-value {
  font-size: 28rpx;
  color: #f8fafc;
  font-weight: 500;
}

.price-value.total {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 2rpx 8rpx rgba(251, 191, 36, 0.3);
}

/* и®ўеҚ•еә•йғЁ */
.order-footer {
  padding-top: 16rpx;
}

.order-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  align-items: center;
}

.btn-secondary {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #c8a2ff;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.1);
  transition: all 0.3s ease;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.3);
}

.btn-primary {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(200, 162, 255, 0.5);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.5);
  transition: all 0.3s ease;
  min-width: 140rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 0 35rpx rgba(147, 112, 219, 0.6);
}

/* з©әзҠ¶жҖ?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #f8fafc;
  font-weight: 600;
  margin-bottom: 16rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.empty-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border: 1rpx solid rgba(200, 162, 255, 0.5);
  border-radius: 999rpx;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.5);
  transition: all 0.3s ease;
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 35rpx rgba(147, 112, 219, 0.6);
}

.empty-btn text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.btn-arrow {
  font-size: 32rpx;
  font-weight: 300;
}

/* еҠ иҪҪзҠ¶жҖ?*/
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
  gap: 20rpx;
}

.loading-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 3rpx solid rgba(147, 112, 219, 0.3);
  border-top: 3rpx solid #7c3aed;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}





