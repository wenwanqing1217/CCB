/* зі»з»џйЂљзџҐйЎµйќў - зґ«и‰Ійњ“и™№зЃЇйЈЋж ?*/

.page {
  min-height: 100vh;
  background: #020208;
  padding: 24rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
  position: relative;
}

.page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* йЎ¶йѓЁз»џи®Ў */
.header-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.stat-card.unread {
  border-color: rgba(255, 107, 107, 0.4);
  box-shadow: 0 0 20rpx rgba(255, 107, 107, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.stat-card.unread::before {
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 107, 107, 0.6) 20%,
    rgba(255, 142, 83, 0.6) 50%,
    rgba(255, 107, 107, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(255, 107, 107, 0.4);
}

.stat-num {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
  animation: statNumGlow 2s ease-in-out infinite;
}

@keyframes statNumGlow {
  0%, 100% {
    filter: drop-shadow(0 0 8rpx rgba(147, 112, 219, 0.6));
  }
  50% {
    filter: drop-shadow(0 0 16rpx rgba(186, 85, 211, 0.9));
  }
}

.stat-card.unread .stat-num {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: statNumGlowUnread 2s ease-in-out infinite;
}

@keyframes statNumGlowUnread {
  0%, 100% {
    filter: drop-shadow(0 0 8rpx rgba(255, 107, 107, 0.6));
  }
  50% {
    filter: drop-shadow(0 0 16rpx rgba(255, 142, 83, 0.9));
  }
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* йЂљзџҐе€—иЎЁ */
.notice-list {
  position: relative;
  z-index: 1;
}

.notice-item {
  display: flex;
  gap: 20rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.2);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.1),
              0 8rpx 32rpx rgba(0, 0, 0, 0.5);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.notice-item.unread {
  border-color: rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.5);
}

.notice-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.4) 20%,
    rgba(186, 85, 211, 0.4) 50%,
    rgba(200, 162, 255, 0.4) 80%,
    transparent 100%);
  opacity: 0.5;
}

.notice-item.unread::before {
  opacity: 1;
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.notice-item:active {
  transform: scale(0.98);
}

/* е›ѕж ‡еЊєеџџ */
.notice-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  flex-shrink: 0;
}

.notice-icon-wrap.system {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(147, 51, 234, 0.15) 100%);
  border-color: rgba(59, 130, 246, 0.4);
}

.notice-icon-wrap.activity {
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.2) 0%, rgba(251, 146, 60, 0.15) 100%);
  border-color: rgba(236, 72, 153, 0.4);
}

.notice-icon-wrap.warning {
  background: linear-gradient(135deg, rgba(234, 179, 8, 0.2) 0%, rgba(249, 115, 22, 0.15) 100%);
  border-color: rgba(234, 179, 8, 0.4);
}

.notice-icon-wrap.success {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(16, 185, 129, 0.15) 100%);
  border-color: rgba(34, 197, 94, 0.4);
}

.notice-icon {
  font-size: 40rpx;
}

.unread-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  border-radius: 50%;
  border: 2rpx solid #020208;
  box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.6);
  animation: dotPulse 2s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.6);
  }
  50% {
    transform: scale(1.2);
    box-shadow: 0 0 15rpx rgba(255, 107, 107, 0.9);
  }
}

/* е†…е®№еЊєеџџ */
.notice-content {
  flex: 1;
  min-width: 0;
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.notice-item.unread .notice-title {
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(200, 162, 255, 0.3);
}

.notice-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.notice-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ж“ЌдЅњжЊ‰й’® */
.notice-actions {
  margin-top: 16rpx;
}

.action-btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #c8a2ff;
  transition: all 0.3s ease;
}

.action-btn:active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.25) 100%);
  transform: scale(0.98);
}

/* з©єзЉ¶жЂ?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 24rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* еє•йѓЁж“ЌдЅњж ?*/
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(2, 2, 8, 0) 0%, rgba(5, 5, 15, 0.98) 20%, rgba(5, 5, 15, 1) 100%);
  display: flex;
  justify-content: center;
  gap: 40rpx;
  z-index: 999;
  border-top: 2rpx solid rgba(147, 112, 219, 0.2);
  backdrop-filter: blur(10rpx);
}

.bottom-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.bottom-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.25) 100%);
}

.bottom-btn.clear {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.15) 0%, rgba(220, 38, 38, 0.1) 100%);
  border-color: rgba(239, 68, 68, 0.3);
}

.bottom-btn.clear:active {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.25) 0%, rgba(220, 38, 38, 0.2) 100%);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}





