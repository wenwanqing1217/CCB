<view class="container">
  <view class="benefit-section">
    <text class="section-title">认证权益</text>
    <view class="benefit-list">
      <view class="benefit-item">
        <text class="benefit-icon">✓</text>
        <text class="benefit-text">发布盲盒商品</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✓</text>
        <text class="benefit-text">参与物品交换</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✓</text>
        <text class="benefit-text">成为校园骑手</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">✓</text>
        <text class="benefit-text">捐赠闲置物品</text>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="form-label">真实姓名<text class="required">*</text></text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <text class="form-label">学校</text>
      <view class="school-display">
        <text class="school-name">{{school}}</text>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">学号<text class="required">*</text></text>
      <input class="form-input" placeholder="请输入学号" value="{{studentId}}" bindinput="onStudentIdInput" />
    </view>

    <view class="form-item">
      <text class="form-label">手机号<text class="required">*</text></text>
      <view class="phone-row">
        <input class="form-input phone-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
        <view class="code-btn {{codeSent ? 'disabled' : ''}}" bindtap="sendCode">
          <text>{{codeSent ? countdown + 's' : '获取验证码'}}</text>
        </view>
      </view>
      <input class="form-input code-input" type="number" placeholder="请输入验证码" value="{{verifyCode}}" bindinput="onCodeInput" maxlength="6" />
    </view>

    <view class="form-item">
      <text class="form-label">上传学生证<text class="required">*</text></text>
      <view class="upload-area">
        <view class="upload-box" wx:if="{{!studentCard}}" bindtap="uploadStudentCard">
          <text class="upload-icon">+</text>
          <text class="upload-text">上传学生证照片</text>
        </view>
        <view class="upload-preview" wx:else>
          <image class="preview-image" src="{{studentCard}}" mode="aspectFill" />
          <view class="preview-remove" bindtap="removeStudentCard">×</view>
        </view>
      </view>
      <text class="form-hint">请上传清晰的学生证照片，确保信息完整可见</text>
    </view>

    <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="submitCertification">提交认证</view>
  </view>

  <view class="status-section" wx:if="{{status}}">
    <view class="status-card {{status}}">
      <text class="status-icon">{{status === 'pending' ? '⏳' : status === 'approved' ? '✓' : '×'}}</text>
      <text class="status-title">{{status === 'pending' ? '审核中' : status === 'approved' ? '认证通过' : '认证失败'}}</text>
      <text class="status-desc" wx:if="{{status === 'pending'}}">请耐心等待审核结果</text>
      <text class="status-desc" wx:if="{{status === 'rejected'}}">{{rejectReason}}</text>
    </view>
  </view>
</view>