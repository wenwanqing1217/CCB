.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0c0c1c 0%, #1a1a2e 100%);
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 32rpx 24rpx;
  background: rgba(0, 0, 0, 0.3);
}

.header-left {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.back-icon {
  font-size: 32rpx;
  color: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 64rpx;
}

.stats-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.stats-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stats-icon {
  font-size: 56rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fbbf24;
  text-shadow: 0 0 20rpx rgba(251, 191, 36, 0.5);
}

.log-list {
  padding: 0 24rpx;
}

.list-header {
  padding: 24rpx 0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.log-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.log-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.log-icon text {
  font-size: 36rpx;
}

.log-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.log-desc {
  font-size: 28rpx;
  color: #fff;
}

.log-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.log-amount {
  font-size: 30rpx;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.loading-more {
  text-align: center;
  padding: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
}