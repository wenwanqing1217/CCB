.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

.header {
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 50%, #cbd5e1 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  letter-spacing: 2rpx;
  animation: titleGlow 3s ease-in-out infinite;
}

@keyframes titleGlow {
  0%, 100% { 
    filter: brightness(1);
    text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  }
  50% { 
    filter: brightness(1.1);
    text-shadow: 0 0 25rpx rgba(147, 112, 219, 0.8);
  }
}

.subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* Tab 样式使用 app.wxss 中的 .tab-container �?.tab-item */

.box-card {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  z-index: 1;
}

.box-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 20%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.4);
}

.box-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.box-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.box-status {
  font-size: 24rpx;
  color: #c8a2ff;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.box-content {
  display: flex;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.box-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.box-info {
  flex: 1;
}

.box-price {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 15rpx rgba(251, 191, 36, 0.5);
}

.box-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.box-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(147, 112, 219, 0.2);
  position: relative;
  z-index: 1;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.action-btn.primary {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #ffffff;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
}

.action-btn.secondary {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.9) 0%, rgba(20, 20, 45, 0.95) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  color: rgba(255, 255, 255, 0.8);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.15);
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.3);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: rgba(255, 255, 255, 0.4);
  position: relative;
  z-index: 1;
}

.publish-btn {
  margin-top: 24rpx;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
  border: 1rpx solid rgba(200, 162, 255, 0.5);
}

.publish-btn::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.publish-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 0 90rpx rgba(186, 85, 211, 0.25),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 0 120rpx rgba(186, 85, 211, 0.35),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}





