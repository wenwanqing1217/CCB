/* 物流详情页面 - 紫色霓虹灯风格 */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #020208;
  box-sizing: border-box;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 30rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.2);
  box-shadow: 0 4rpx 30rpx rgba(147, 112, 219, 0.15);
  position: relative;
  margin: -24rpx -24rpx 30rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.6) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 18rpx rgba(147, 112, 219, 0.5);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(147, 112, 219, 0.2);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.95);
  background: rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
}

.back-icon {
  font-size: 32rpx;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #c8a2ff;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.4);
  background: rgba(147, 112, 219, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.header-placeholder {
  width: 60rpx;
}

/* 物流状态卡片 */
.status-card {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.status-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.status-info {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tracking-info {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.2);
}

.tracking-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.tracking-no {
  font-size: 24rpx;
  color: #fff;
  margin-left: 8rpx;
}

.copy-btn {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: rgba(147, 112, 219, 0.3);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #c8a2ff;
}

/* 骑手信息卡片 */
.rider-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.rider-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  margin-right: 20rpx;
}

.rider-info {
  flex: 1;
}

.rider-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.rider-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(147, 112, 219, 0.2);
  border-radius: 16rpx;
}

.contact-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.contact-text {
  font-size: 20rpx;
  color: #c8a2ff;
}

/* 物流时间线 */
.timeline-section {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  padding-bottom: 32rpx;
  position: relative;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 108rpx;
  top: 24rpx;
  bottom: 0;
  width: 2rpx;
  background: rgba(147, 112, 219, 0.2);
}

.timeline-left {
  width: 100rpx;
  text-align: right;
  padding-right: 20rpx;
}

.timeline-time {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.4);
}

.timeline-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
}

.timeline-item.active .timeline-time {
  color: #c8a2ff;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: rgba(147, 112, 219, 0.3);
  border-radius: 50%;
  margin: 8rpx 20rpx 0;
  position: relative;
  z-index: 1;
}

.timeline-dot.active {
  background: linear-gradient(135deg, #7c3aed 0%, #ba55d3 100%);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5);
}

.timeline-content {
  flex: 1;
}

.timeline-status {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.5;
}

.timeline-item.active .timeline-status {
  color: #fff;
}

.timeline-item.active .timeline-desc {
  color: rgba(255, 255, 255, 0.6);
}

/* 订单信息 */
.order-section {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 24rpx;
}

.order-card {
  display: flex;
  align-items: center;
}

.order-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: rgba(147, 112, 219, 0.2);
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
}

.order-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.order-price {
  display: block;
  font-size: 26rpx;
  color: #c8a2ff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.order-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 300;
}

/* 底部安全区域 */
.safe-area {
  height: 40rpx;
}