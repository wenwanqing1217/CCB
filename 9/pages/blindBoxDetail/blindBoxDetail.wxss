.notice-list {
  margin-top: 16rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-dot {
  font-size: 24rpx;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
  margin-top: 4rpx;
  flex-shrink: 0;
}

.notice-item text:not(.notice-dot) {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.2);
}

/* 底部占位 */
.detail-bottom-placeholder {
  height: 160rpx;
}

/* 购买按钮 - 固定在底部 */
.buy-button-fixed {
  position: fixed;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 36rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 40rpx;
  box-shadow: 
    0 4rpx 30rpx rgba(147, 112, 219, 0.6),
    0 8rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.buy-button-fixed:active {
  transform: scale(0.95);
  box-shadow: 
    0 2rpx 20rpx rgba(147, 112, 219, 0.4),
    0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.buy-button-fixed text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
}

.buy-price {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx !important;
}
