.container {
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 20%, rgba(147, 112, 219, 0.1) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(186, 85, 211, 0.08) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* 自定义顶部导航栏 */
.detail-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 100%);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
}

.detail-header::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.detail-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.9) 0%, rgba(5, 5, 15, 0.95) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 50%;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.15);
  transition: all 0.3s;
}

.detail-back:active {
  transform: scale(0.9);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.3);
}

.back-icon {
  font-size: 32rpx;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.detail-title-bar {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.detail-empty {
  width: 88rpx;
}

/* 商品大图轮播 */
.detail-hero-section {
  width: 100%;
  height: 560rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  overflow: hidden;
  margin-top: 104rpx;
}

.detail-hero-section::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.detail-swiper {
  width: 100%;
  height: 100%;
}

.detail-hero-image {
  width: 100%;
  height: 100%;
  border-radius: 0;
}

/* 商品信息区域 */
.detail-content {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 价格卡片 */
.price-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(15rpx);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
}

.price-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.price-main {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.3);
}

.price-number {
  font-size: 64rpx;
  font-weight: 900;
  color: #c8a2ff;
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.6);
  letter-spacing: 2rpx;
}

.price-tag {
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
}

.price-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(147, 112, 219, 0.2);
}

.price-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 600;
}

.price-stock {
  font-size: 24rpx;
  color: #ef4444;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(239, 68, 68, 0.5);
}

