  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  border-radius: 24rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
  transition: all 0.3s;
}

.seller-action:active {
  transform: scale(0.95);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.5);
}

/* 购买须知卡片 */
.notice-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(15rpx);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
}

.notice-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
