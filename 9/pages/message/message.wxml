<view class="container">
  <!-- 消息分类入口 -->
  <view class="category-section">
    <view class="category-grid">
      <view class="category-item" bindtap="goToSystemMessage">
        <view class="category-box system">
          <text class="category-text">系统</text>
          <view class="badge" wx:if="{{systemUnread > 0}}">{{systemUnread}}</view>
        </view>
        <text class="category-name">系统通知</text>
      </view>
      <view class="category-item" bindtap="goToOrderMessage">
        <view class="category-box order">
          <text class="category-text">订单</text>
          <view class="badge" wx:if="{{orderUnread > 0}}">{{orderUnread}}</view>
        </view>
        <text class="category-name">订单与物流</text>
      </view>
      <view class="category-item" bindtap="goToInteractMessage">
        <view class="category-box interact">
          <text class="category-text">互动</text>
          <view class="badge" wx:if="{{interactUnread > 0}}">{{interactUnread}}</view>
        </view>
        <text class="category-name">互动消息</text>
      </view>
      <view class="category-item" bindtap="goToLove">
        <view class="category-box love">
          <text class="category-text">爱心</text>
          <view class="badge" wx:if="{{loveUnread > 0}}">{{loveUnread}}</view>
        </view>
        <text class="category-name">爱心动态</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <view class="message-section">
    <view class="section-title">最近消息</view>
    
    <view class="message-list">
      <view class="message-item {{item.unread ? 'unread' : ''}} {{item.type === 'order' ? 'order-type' : ''}} {{item.type === 'logistics' ? 'logistics-type' : ''}}" 
            wx:for="{{recentMessages}}" 
            wx:key="id"
            bindtap="handleMessageTap" 
            data-item="{{item}}">
        <view class="message-avatar-wrap">
          <view class="message-avatar" wx:if="{{!item.avatar}}">{{item.name[0]}}</view>
          <image class="message-avatar" wx:else src="{{item.avatar}}" />
          <view class="unread-dot" wx:if="{{item.unread}}"></view>
        </view>
        <view class="message-content">
          <view class="message-header">
            <text class="message-name">{{item.name}}</text>
            <text class="message-time">{{item.time}}</text>
          </view>
          <text class="message-text">{{item.message}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{recentMessages.length === 0}}">
      <text class="empty-text">暂无消息</text>
      <text class="empty-hint">有新消息时会在这里显示</text>
    </view>
  </view>

  <!-- 艾米助手入口 -->
  <view class="ai-entry" bindtap="goToAI">
    <view class="ai-avatar">艾</view>
    <view class="ai-info">
      <text class="ai-name">艾米助手</text>
      <text class="ai-desc">智能问答，快速解决问题</text>
    </view>
    <view class="ai-arrow"></view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area"></view>
</view>
