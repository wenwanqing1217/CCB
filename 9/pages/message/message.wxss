.container {
  min-height: 100vh;
  background: #020208;
  padding-bottom: 40rpx;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 顶部标题�?*/
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 24rpx 30rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.6) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 18rpx rgba(147, 112, 219, 0.5);
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.header-action {
  padding: 12rpx 24rpx;
  background: rgba(147, 112, 219, 0.15);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 28rpx;
}

.action-text {
  font-size: 28rpx;
  color: #c8a2ff;
}

/* 消息分类入口 */
.category-section {
  padding: 24rpx 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  justify-items: center;
  max-width: 100%;
  box-sizing: border-box;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.category-box {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
}

.category-box.system {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
}

.category-box.order {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-color: rgba(245, 158, 11, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(245, 158, 11, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
}

.category-box.interact {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-color: rgba(16, 185, 129, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(16, 185, 129, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
}

.category-box.love {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-color: rgba(239, 68, 68, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(239, 68, 68, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
}

.category-text {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  width: 100%;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #020208;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8),
              0 0 25rpx rgba(255, 255, 255, 0.4);
}

.category-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  width: 100%;
}

/* 艾米助手入口 */
.ai-entry {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 24rpx 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
}

.ai-entry:active {
  transform: scale(0.98);
  box-shadow: 0 0 35rpx rgba(147, 112, 219, 0.35),
              0 12rpx 40rpx rgba(0, 0, 0, 0.7);
  border-color: rgba(147, 112, 219, 0.6);
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(5, 5, 15, 0.98) 100%);
}

.ai-entry::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
}

.ai-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.5);
}

.ai-info {
  flex: 1;
}

.ai-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 8rpx;
}

.ai-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 消息列表区域 */
.message-section {
  padding: 24rpx 16rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  backdrop-filter: blur(10rpx);
}

.message-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.5) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.5) 80%,
    transparent 100%);
}

.message-item.unread {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 100%);
  border-color: rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.25),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

/* 订单消息样式 */
.message-item.order-type {
  border-color: rgba(245, 158, 11, 0.4);
}

.message-item.order-type::before {
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(245, 158, 11, 0.6) 20%,
    rgba(249, 115, 22, 0.6) 50%,
    rgba(245, 158, 11, 0.6) 80%,
    transparent 100%);
}

/* 物流消息样式 */
.message-item.logistics-type {
  border-color: rgba(34, 197, 94, 0.4);
}

.message-item.logistics-type::before {
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(34, 197, 94, 0.6) 20%,
    rgba(22, 163, 74, 0.6) 50%,
    rgba(34, 197, 94, 0.6) 80%,
    transparent 100%);
}

.message-item:active {
  transform: scale(0.98);
  background: rgba(147, 112, 219, 0.2);
}

.message-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.message-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.unread-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  border: 4rpx solid #020208;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.9),
              0 0 20rpx rgba(255, 255, 255, 0.5);
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.message-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
  background: rgba(147, 112, 219, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  display: inline-block;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.message-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 空状�?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部安全区域 */
.safe-area {
  height: 40rpx;
}





