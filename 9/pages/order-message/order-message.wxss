/* 订单消息页面样式 - 紫色霓虹灯风格 */

.page {
  min-height: 100vh;
  background: #020208;
  padding-bottom: 120rpx;
}

.page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* 顶部统计 */
.header-stats {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.stat-card.unread {
  border-color: rgba(186, 85, 211, 0.5);
  box-shadow: 0 0 25rpx rgba(186, 85, 211, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.6);
}

.stat-card.unread .stat-num {
  color: #d8b4fe;
  text-shadow: 0 0 15rpx rgba(216, 180, 254, 0.6);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 消息列表 */
.message-list {
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}

.message-item {
  display: flex;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.25);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.1),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
}

.message-item.unread {
  border-color: rgba(186, 85, 211, 0.4);
  box-shadow: 0 0 25rpx rgba(186, 85, 211, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.message-item.unread::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  border-radius: 20rpx 20rpx 0 0;
}

/* 左侧图标 */
.message-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: rgba(147, 112, 219, 0.2);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.message-icon-wrap.order_success {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(147, 112, 219, 0.3) 100%);
  border-color: rgba(200, 162, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(124, 58, 237, 0.4);
}

.message-icon-wrap.payment_success {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.3) 0%, rgba(74, 222, 128, 0.3) 100%);
  border-color: rgba(74, 222, 128, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.4);
}

.message-icon-wrap.seller_shipped {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.3) 0%, rgba(96, 165, 250, 0.3) 100%);
  border-color: rgba(96, 165, 250, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.message-icon-wrap.order_cancelled {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.3) 0%, rgba(248, 113, 113, 0.3) 100%);
  border-color: rgba(248, 113, 113, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4);
}

.message-icon-wrap.order_completed {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.3) 0%, rgba(52, 211, 153, 0.3) 100%);
  border-color: rgba(52, 211, 153, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.4);
}

.message-icon-wrap.refund_success {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.3) 0%, rgba(251, 191, 36, 0.3) 100%);
  border-color: rgba(251, 191, 36, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.4);
}

.message-icon {
  font-size: 40rpx;
}

.unread-dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 20rpx;
  height: 20rpx;
  background: #ba55d3;
  border-radius: 50%;
  border: 2rpx solid #020208;
  box-shadow: 0 0 10rpx rgba(186, 85, 211, 0.8);
}

/* 内容区域 */
.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.message-item.unread .message-title {
  color: #d8b4fe;
  text-shadow: 0 0 10rpx rgba(216, 180, 254, 0.5);
}

.message-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.message-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

/* 订单预览 */
.order-preview {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(147, 112, 219, 0.1);
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  margin-bottom: 16rpx;
}

.order-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.order-info {
  flex: 1;
  min-width: 0;
}

.order-name {
  display: block;
  font-size: 26rpx;
  color: #ffffff;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-price {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #d8b4fe;
  text-shadow: 0 0 10rpx rgba(216, 180, 254, 0.3);
}

/* 操作按钮 */
.message-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
              0 0 40rpx rgba(147, 112, 219, 0.3);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 100%);
  border-top: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 -4rpx 30rpx rgba(147, 112, 219, 0.15);
  z-index: 100;
}

.bottom-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin: 0 12rpx;
  background: rgba(147, 112, 219, 0.15);
  border-radius: 12rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
}

.bottom-btn.clear {
  background: rgba(239, 68, 68, 0.15);
  border-color: rgba(239, 68, 68, 0.3);
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #c4b5fd;
}

.bottom-btn.clear .btn-text {
  color: #fca5a5;
}
