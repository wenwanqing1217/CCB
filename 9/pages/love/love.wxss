  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 28rpx;
  z-index: -1;
}

.shake-btn-action::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  animation: btnShine 3s ease-in-out infinite;
  z-index: -1;
}

.shake-btn-action.primary {
  color: #c8a2ff;
  text-shadow: 
    0 0 15rpx rgba(147, 112, 219, 0.9),
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 45rpx rgba(186, 85, 211, 0.5);
}

.shake-btn-action.secondary {
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    0 0 30rpx rgba(255, 255, 255, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  text-shadow: 
    0 0 15rpx rgba(255, 255, 255, 0.7),
    0 0 30rpx rgba(255, 255, 255, 0.5);
}

.shake-btn-action.secondary::before {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.05) 100%);
}

.shake-btn-action:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.5),
    0 0 70rpx rgba(147, 112, 219, 0.3);
  border-color: rgba(147, 112, 219, 0.7);
}

.shake-btn-action.secondary:active {
  border-color: rgba(255, 255, 255, 0.5);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 50rpx rgba(255, 255, 255, 0.4);
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

/* 摇一摇结果弹窗 */
.shake-result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  z-index: 2001;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx);
}

.shake-result-close {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #ffffff;
  z-index: 2002;
}

.shake-result-close:active {
  background: rgba(0, 0, 0, 0.8);
}

.shake-result-content {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 100%);
  border-radius: 32rpx;
  padding: 48rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.5);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.8),
              0 0 80rpx rgba(147, 112, 219, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  min-width: 600rpx;
  animation: resultPop 0.5s ease-out;
}

@keyframes resultPop {
  0% {
    opacity: 0;
    transform: scale(0.5);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.result-card {
  position: relative;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border: 3rpx solid rgba(147, 112, 219, 0.5);
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
