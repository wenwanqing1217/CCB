/* 盲盒广场页面 - 抖音风格 */

page {
  background-color: #020208;
}

.container {
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow-x: hidden;
}

/* 顶部导航栏：摇一摇 + 搜索框 */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-bottom: none;
  box-shadow: none;
  backdrop-filter: blur(20rpx);
}

/* 摇一摇按钮 */
.shake-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 120rpx;
  height: 100rpx;
  padding: 0;
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(12, 12, 28, 0.9) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 18rpx;
  border: 1.5rpx solid rgba(124, 58, 237, 0.5);
  box-shadow: 
    0 6rpx 24rpx rgba(147, 112, 219, 0.25),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.shake-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 0.5rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.4) 30%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.4) 70%,
    transparent 100%);
  opacity: 0.5;
  box-shadow: 0 0 6rpx rgba(200, 162, 255, 0.3);
  z-index: 2;
}

.shake-btn::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10%;
  right: 10%;
  height: 0.5rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.4) 30%,
    rgba(186, 85, 211, 0.6) 50%,
    rgba(200, 162, 255, 0.4) 70%,
    transparent 100%);
  opacity: 0.5;
  box-shadow: 0 0 6rpx rgba(200, 162, 255, 0.3);
  z-index: 2;
}

.shake-btn:active {
  transform: translateY(-6rpx) scale(0.98);
  box-shadow: 
    0 12rpx 50rpx rgba(147, 112, 219, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.shake-btn:active::before {
  opacity: 1;
  box-shadow: 0 0 25rpx rgba(200, 162, 255, 0.6);
  animation: shine 1s ease-in-out;
}

.shake-icon {
  font-size: 40rpx;
  color: #ffffff;
  text-shadow:
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
  position: relative;
  z-index: 3;
}

.shake-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 800;
  letter-spacing: 2rpx;
  text-shadow:
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
  transition: all 0.3s ease;
  position: relative;
  z-index: 3;
}

/* 搜索框 */
.search-bar {
  flex: 1;
  padding: 4rpx 0;
}

.search-input {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 20rpx;
  padding: 6rpx 6rpx 6rpx 16rpx;
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.1),
              0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.search-input input {
  flex: 1;
  font-size: 20rpx;
  color: #f8fafc;
  background: transparent;
  border: none;
  outline: none;
  height: 36rpx;
  line-height: 36rpx;
  font-weight: 400;
  text-shadow: 
    0 0 8rpx rgba(147, 112, 219, 0.6),
    0 0 16rpx rgba(147, 112, 219, 0.4);
}

.search-input input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 20rpx;
  font-weight: 300;
}

.search-btn {
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.8) 0%, rgba(5, 5, 15, 0.9) 100%);
  border-radius: 18rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.search-btn-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}



/* 分类标签 */
.category-scroll {
  position: fixed;
  top: 100rpx;
  left: 0;
  right: 0;
  z-index: 99;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-bottom: none;
  white-space: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 30rpx rgba(147, 112, 219, 0.15);
  border-top: none;
}

.category-scroll::-webkit-scrollbar {
  display: none;
}

.category-list {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.category-item {
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #c8a2ff;
  white-space: nowrap;
  flex-shrink: 0;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    0 0 30rpx rgba(147, 112, 219, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  cursor: pointer;
  box-sizing: border-box;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6);
}

.category-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.6) 30%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.6) 70%,
    transparent 100%);
  opacity: 0.7;
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.4);
  z-index: 2;
}

.category-item::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 28rpx;
  z-index: -1;
}

.category-item.active {
  background: linear-gradient(135deg, rgba(124, 58, 237, 0.3) 0%, rgba(12, 12, 28, 0.9) 100%);
  border-color: rgba(124, 58, 237, 0.6);
  color: #ffffff;
  font-weight: 800;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.5),
    0 0 30rpx rgba(147, 112, 219, 0.3);
  box-shadow: 
    0 8rpx 40rpx rgba(147, 112, 219, 0.3),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  animation: mainTitleGlow 3s ease-in-out infinite;
}

.category-item:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 40rpx rgba(147, 112, 219, 0.4);
  border-color: rgba(147, 112, 219, 0.6);
}

.category-item text {
  position: relative;
  z-index: 3;
}

@keyframes mainTitleGlow {
  0%, 100% {
    text-shadow:
      0 0 10rpx rgba(147, 112, 219, 0.8),
      0 0 20rpx rgba(147, 112, 219, 0.5);
    filter: brightness(1);
  }
  50% {
    text-shadow:
      0 0 15rpx rgba(147, 112, 219, 1),
      0 0 30rpx rgba(147, 112, 219, 0.8),
      0 0 45rpx rgba(186, 85, 211, 0.5);
    filter: brightness(1.2);
  }
}

@keyframes brandGlow {
  0%, 100% {
    text-shadow:
      0 0 10rpx rgba(147, 112, 219, 0.8),
      0 0 20rpx rgba(147, 112, 219, 0.6),
      0 0 30rpx rgba(147, 112, 219, 0.4),
      0 0 40rpx rgba(186, 85, 211, 0.3);
    filter: brightness(1);
  }
  50% {
    text-shadow:
      0 0 15rpx rgba(147, 112, 219, 1),
      0 0 30rpx rgba(147, 112, 219, 0.8),
      0 0 45rpx rgba(186, 85, 211, 0.6),
      0 0 60rpx rgba(200, 162, 255, 0.4);
    filter: brightness(1.3);
  }
}

/* 盲盒列表容器 */
.box-list-container {
  width: 100%;
  height: calc(100vh - 200rpx);
  overflow-y: auto;
  padding-top: calc(200rpx + env(safe-area-inset-top));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 盲盒卡片列表 */
.box-card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
}

/* 盲盒卡片 */
.box-card {
  background: linear-gradient(135deg, rgba(25, 25, 50, 0.9) 0%, rgba(15, 15, 30, 0.95) 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4),
              0 0 30rpx rgba(147, 112, 219, 0.15);
  transition: all 0.3s ease;
}

.box-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3),
              0 0 20rpx rgba(147, 112, 219, 0.1);
}

/* 轮播图 */
.box-swiper {
  width: 100%;
  height: 400rpx;
}

.box-image {
  width: 100%;
  height: 100%;
}

/* 商品信息区域 */
.box-info-section {
  padding: 20rpx;
}

.box-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.box-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.4;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.box-price-tag {
  flex-shrink: 0;
}

.box-price {
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.box-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.box-category-tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #c8a2ff;
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.5),
    0 0 10rpx rgba(147, 112, 219, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  text-shadow: 
    0 0 5rpx rgba(147, 112, 219, 0.6),
    0 0 10rpx rgba(147, 112, 219, 0.4);
  backdrop-filter: blur(20rpx);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.box-category-tag::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.05) 0%, rgba(186, 85, 211, 0.02) 100%);
  border-radius: 16rpx;
  z-index: -1;
}

.box-campus {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.box-stock {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 加载更多 */
.loading {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

/* 错误提示 */
.error-message {
  text-align: center;
  padding: 32rpx;
  background: rgba(244, 63, 94, 0.1);
  border: 2rpx solid rgba(244, 63, 94, 0.3);
  border-radius: 16rpx;
  margin: 24rpx;
  color: #f43f5e;
  font-size: 24rpx;
}

/* 推荐商品 */
.recommended-section {
  padding: 24rpx;
  margin-top: 24rpx;
  background: rgba(25, 25, 50, 0.8);
  border-top: 2rpx solid rgba(147, 112, 219, 0.2);
}

.recommended-header {
  margin-bottom: 20rpx;
}

.recommended-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.recommended-list {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 40rpx;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.recommended-list::-webkit-scrollbar {
  display: none;
}

.recommended-item {
  flex: 0 0 220rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: linear-gradient(135deg, rgba(25, 25, 50, 0.9) 0%, rgba(15, 15, 30, 0.95) 100%);
  border-radius: 16rpx;
  padding: 12rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.recommended-item:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.recommended-image {
  width: 100%;
  height: 170rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
}

.recommended-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommended-price {
  font-size: 24rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f43f5e 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.2;
  padding-top: 4rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .video-grid {
    gap: 12rpx;
    padding: 12rpx;
  }
  
  .box-price {
    font-size: 28rpx;
  }
  
  .box-name {
    font-size: 22rpx;
  }
  
  .search-input {
    font-size: 26rpx;
  }
  
  .category-item {
    padding: 10rpx 20rpx;
    font-size: 22rpx;
  }
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.video-card, .video-item {
  animation: fadeInUp 0.5s ease-out;
}

.video-card:nth-child(2), .video-item:nth-child(2) {
  animation-delay: 0.1s;
}

.video-card:nth-child(3), .video-item:nth-child(3) {
  animation-delay: 0.2s;
}

.video-card:nth-child(4), .video-item:nth-child(4) {
  animation-delay: 0.3s;
}

/* 盲盒详情页（商品轮播图形式） */
.box-detail-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #020208;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}



.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-right: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  transition: all 0.3s;
  padding: 8rpx 12rpx;
  border-radius: 16rpx;
  min-width: 80rpx;
}

.action-item:active {
  transform: scale(0.95);
  background: rgba(147, 112, 219, 0.15);
}

.action-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 4rpx;
  transition: all 0.3s;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.action-item:active .action-icon {
  color: #c8a2ff;
  transform: scale(1.15);
  text-shadow: 0 0 20rpx rgba(147, 112, 219, 0.6);
}

.action-icon.liked {
  color: #c8a2ff;
  animation: heartBeat 0.5s ease;
}

.action-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.buy-button {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 0 90rpx rgba(186, 85, 211, 0.25),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  cursor: pointer;
}

.buy-button::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.buy-button::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 0 90rpx rgba(186, 85, 211, 0.25),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 0 120rpx rgba(186, 85, 211, 0.35),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  15% { transform: scale(1.4); }
  30% { transform: scale(1.1); }
  45% { transform: scale(1.3); }
  60% { transform: scale(1.1); }
}

.buy-button:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

/* 商品图片区域 */
.detail-image-section {
  width: 100%;
  aspect-ratio: 4 / 3;
  position: relative;
  overflow: hidden;
  background: #000;
}

.detail-main-image {
  width: 100%;
  height: 100%;
}

.detail-image-indicator {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

/* 商品信息区域 - 可滚动 */
.detail-content {
  flex: 1;
  overflow-y: auto;
  padding: 0;
  padding-bottom: 140rpx;
}

