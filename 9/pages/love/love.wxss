  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.3) 0%, rgba(186, 85, 211, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(147, 112, 219, 0.5);
  box-shadow: 0 0 40rpx rgba(147, 112, 219, 0.4);
  position: relative;
  overflow: hidden;
}

.shake-animation::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(147, 112, 219, 0.3) 0%, transparent 70%);
