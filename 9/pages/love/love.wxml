<view class="container">
  <!-- 顶部导航栏：搜索框 + 摇一摇 -->
  <view class="top-nav" wx:if="{{!showDetail}}">
    <view class="search-bar">
      <view class="search-input">
        <input 
          placeholder="搜索商品、盲盒"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
          value="{{searchKeyword}}"
          disabled="{{searchLoading}}"
        />
        <view class="search-btn" bindtap="onSearch">
          <text class="search-btn-text">搜索</text>
        </view>
      </view>
    </view>
    <view class="shake-btn" bindtap="startShake">
      <text class="shake-icon">📳</text>
      <text class="shake-text">摇一摇</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x wx:if="{{!showDetail}}">
    <view class="category-list">
      <view
        class="category-item {{activeCategory === 'all' ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="all"
      >
        <text>全部</text>
      </view>
      <view
        class="category-item {{activeCategory === 'electronics' ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="electronics"
      >
        <text>电子产品</text>
      </view>
      <view
        class="category-item {{activeCategory === 'life' ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="life"
      >
        <text>生活用品</text>
      </view>
      <view
        class="category-item {{activeCategory === 'study' ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="study"
      >
        <text>学习资料</text>
      </view>
      <view
        class="category-item {{activeCategory === 'sports' ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="sports"
      >
        <text>运动装备</text>
      </view>
      <view
        class="category-item {{activeCategory === 'fashion' ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="fashion"
      >
        <text>时尚配饰</text>
      </view>
    </view>
  </scroll-view>

  <!-- 错误提示 -->
  <view wx:if="{{error}}" class="error-message">
    <text>{{error}}</text>
  </view>

  <!-- 盲盒列表 - 轮播图卡片形式 -->
  <scroll-view
    class="box-list-container"
    scroll-y
    bindscrolltolower="loadMore"
    wx:if="{{!showDetail}}"
  >
    <view class="box-card-list">
      <view
        class="box-card"
        wx:for="{{filteredBlindBoxes}}"
        wx:key="_id"
        bindtap="showBoxDetail"
        data-id="{{item._id}}"
        bindtouchstart="onCardTouchStart"
        bindtouchmove="onCardTouchMove"
        bindtouchend="onCardTouchEnd"
        data-index="{{index}}"
      >
        <!-- 商品轮播图 -->
        <swiper class="box-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#c8a2ff">
          <swiper-item wx:for="{{item.images}}" wx:for-item="img" wx:key="index">
            <image class="box-image" src="{{img}}" mode="aspectFill" />
          </swiper-item>
        </swiper>

        <!-- 商品信息 -->
        <view class="box-info-section">
          <view class="box-header-row">
            <text class="box-title">{{item.title}}</text>
            <view class="box-price-tag">
              <text class="box-price">¥{{item.price}}</text>
            </view>
          </view>
          <view class="box-meta-row">
            <text class="box-category-tag">{{item.categoryName}}</text>
            <text class="box-campus">📍 {{item.campus}}</text>
            <text class="box-stock">剩余 {{item.stock}} 件</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 推荐商品 -->
    <view wx:if="{{recommendedBoxes.length > 0 && !showDetail}}" class="recommended-section">
      <view class="recommended-header">
        <text class="recommended-title">为你推荐</text>
      </view>
      <view class="recommended-list">
        <view
          class="recommended-item"
          wx:for="{{recommendedBoxes}}"
          wx:key="_id"
          bindtap="showBoxDetail"
          data-id="{{item._id}}"
        >
          <image class="recommended-image" src="{{item.images[0]}}" mode="aspectFill" />
          <text class="recommended-name">{{item.title}}</text>
          <text class="recommended-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>

    <!-- 底部加载更多 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- 盲盒详情页（商品轮播图形式） -->
  <view class="box-detail-page" wx:if="{{showDetail}}">
    <!-- 商品大图轮播 -->
    <view class="detail-hero-section">
      <swiper class="detail-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#c8a2ff" autoplay interval="3000" circular>
        <swiper-item wx:for="{{currentBox.images}}" wx:key="index">
          <image class="detail-hero-image" src="{{item}}" mode="aspectFill" />
        </swiper-item>
      </swiper>
    </view>

    <!-- 商品信息区域 - 可滚动 -->
    <scroll-view class="detail-content" scroll-y>
      <!-- 价格卡片 -->
      <view class="price-card">
        <view class="price-main">
          <text class="price-symbol">¥</text>
          <text class="price-number">{{currentBox.price}}</text>
          <view class="price-tag">盲盒特惠</view>
        </view>
        <view class="price-original">
          <text>原价 ¥{{originalPrice}}</text>
          <text class="price-save">省 ¥{{priceSave}}</text>
        </view>
        <view class="buy-button" bindtap="buyBlindBox">
          <text>立即购买</text>
        </view>
      </view>

      <!-- 标题卡片 -->
      <view class="title-card">
        <view class="title-row">
          <view class="title-tag">神秘盲盒</view>
          <text class="title-text">{{currentBox.title}}</text>
        </view>
        <text class="title-desc">{{currentBox.description}}</text>
      </view>

      <!-- 信息卡片 -->
      <view class="info-card">
        <view class="info-row">
          <view class="info-item">
            <text class="info-label">库存</text>
            <text class="info-value">{{currentBox.stock}}件</text>
          </view>
          <view class="info-divider"></view>
          <view class="info-item">
            <text class="info-label">校区</text>
            <text class="info-value">{{currentBox.campus}}</text>
          </view>
          <view class="info-divider"></view>
          <view class="info-item">
            <text class="info-label">分类</text>
            <text class="info-value">{{currentBox.categoryName}}</text>
          </view>
        </view>
      </view>

      <!-- 须知卡片 -->
      <view class="notice-card">
        <view class="notice-header">
          <text class="notice-title">购买须知</text>
        </view>
        <view class="notice-list">
          <view class="notice-item">
            <text class="notice-dot">•</text>
            <text>盲盒内含多件商品，价值远超售价</text>
          </view>
          <view class="notice-item">
            <text class="notice-dot">•</text>
            <text>商品随机分配，不接受指定款式</text>
          </view>
          <view class="notice-item">
            <text class="notice-dot">•</text>
            <text>拆封后不支持退换，请知悉</text>
          </view>
          <view class="notice-item">
            <text class="notice-dot">•</text>
            <text>质量问题可联系卖家处理</text>
          </view>
        </view>
      </view>

      <!-- 卖家卡片 -->
      <view class="seller-card">
        <view class="seller-header">
          <text class="seller-title">卖家信息</text>
        </view>
        <view class="seller-content">
          <image class="seller-avatar" src="{{currentBox.userAvatar}}" />
          <view class="seller-info">
            <text class="seller-name">{{currentBox.userName}}</text>
            <view class="seller-stats">
              <text class="stat-text">在售 {{currentBox.sellerCount || 5}} 件</text>
              <text class="stat-divider">|</text>
              <text class="stat-text">{{currentBox.rating || 4.8}} 分</text>
            </view>
          </view>
          <view class="seller-action {{isFollowing ? 'followed' : ''}}" bindtap="followUser">
            <text>{{isFollowing ? '已关注' : '+ 关注'}}</text>
          </view>
        </view>
      </view>

      <!-- 底部占位 -->
      <view class="detail-bottom-placeholder"></view>
    </scroll-view>
  </view>

  <!-- 底部加载更多 -->
  <view class="loading" wx:if="{{loading && !showDetail}}">
    <text>加载中...</text>
  </view>

  <!-- 摇一摇弹窗 -->
  <view class="shake-modal" wx:if="{{showShakeModal}}">
    <view class="shake-content">
      <view class="shake-close" bindtap="closeShakeModal">✕</view>
      <view class="shake-animation {{isShaking ? 'shaking' : ''}}">
        <text class="shake-emoji">📦</text>
      </view>
      <text class="shake-title">摇一摇开盲盒</text>
      <text class="shake-desc">摇动手机，随机开启一个惊喜盲盒！</text>
      <view class="shake-coin-info">
        <text class="coin-label">当前盲盒积分:</text>
        <text class="coin-value">{{userCoins}}</text>
        <text class="coin-cost">消耗: {{shakeCost}}币/次</text>
      </view>
      <view class="shake-btn-group">
        <view class="shake-btn-action primary" bindtap="startShakeAction">
          <text>{{isShaking ? '摇动中...' : '开始摇动'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 摇一摇结果弹窗 -->
  <view class="shake-result-modal" wx:if="{{showShakeResult}}">
    <view class="shake-result-close" bindtap="closeShakeResult">✕</view>
    <view class="shake-result-content">
      <view class="result-card">
        <view class="result-image-wrapper">
          <image class="result-image" src="{{shakedBox.images[0]}}" mode="aspectFill" />
        </view>
        <view class="result-info">
          <text class="result-title">恭喜你摇到了！</text>
          <text class="result-name">{{shakedBox.title}}</text>
          <view class="result-price-row">
            <text class="result-price">¥{{shakedBox.price}}</text>
            <text class="result-original-price">¥{{shakedBox.originalPrice}}</text>
          </view>
        </view>
      </view>
      <view class="result-actions">
        <view class="result-btn secondary" bindtap="saveToMyBoxes">
          <text>存入我的盲盒</text>
        </view>
        <view class="result-btn primary" bindtap="sendDirectly">
          <text>直接发货</text>
        </view>
      </view>
    </view>
  </view>
</view>