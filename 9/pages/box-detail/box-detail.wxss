.container {
  min-height: 100vh;
  background: #020208;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 20%, rgba(147, 112, 219, 0.1) 0%, transparent 40%),
              radial-gradient(circle at 70% 60%, rgba(186, 85, 211, 0.08) 0%, transparent 40%);
  animation: bgFloat 20s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(2%, 1%) rotate(1deg); }
  66% { transform: translate(-1%, 2%) rotate(-1deg); }
}

/* 自定义顶部导航栏 */
.detail-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 1) 100%);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
}

.detail-header::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.detail-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.9) 0%, rgba(5, 5, 15, 0.95) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 50%;
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.15);
  transition: all 0.3s;
}

.detail-back:active {
  transform: scale(0.9);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.3);
}

.back-icon {
  font-size: 32rpx;
  color: #c8a2ff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.5);
}

.detail-title-bar {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.detail-share {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.9) 0%, rgba(5, 5, 15, 0.95) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 24rpx;
  transition: all 0.3s;
}

.detail-share:active {
  transform: scale(0.95);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.3);
}

.share-text {
  font-size: 24rpx;
  color: #c8a2ff;
  font-weight: 600;
}

.detail-empty {
  width: 88rpx;
}

/* 商品大图轮播 */
.detail-hero-section {
  width: 100%;
  height: 560rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  overflow: hidden;
}

.detail-hero-section::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.detail-swiper {
  width: 100%;
  height: 100%;
}

.detail-hero-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.detail-swiper:active .detail-hero-image {
  transform: scale(1.02);
}

/* 商品信息区域 */
.detail-content {
  width: 100%;
  min-height: calc(100vh - 560rpx);
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

/* 价格卡片 */
.price-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(20rpx);
  position: relative;
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.price-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.price-main {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.price-number {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
}

.price-tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #c8a2ff;
  font-weight: 600;
}

.price-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.price-stock {
  font-size: 24rpx;
  color: #ef4444;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(239, 68, 68, 0.5);
}

/* 简化操作栏 - 右下角固定 */
.detail-actions-mini {
  position: fixed;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 50;
}

.buy-button-fixed {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 36rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  border-radius: 40rpx;
  box-shadow: 
    0 4rpx 30rpx rgba(147, 112, 219, 0.6),
    0 8rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.3s ease;
}

.buy-button-fixed:active {
  transform: scale(0.95);
  box-shadow: 
    0 2rpx 20rpx rgba(147, 112, 219, 0.4),
    0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.buy-button-fixed text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.3);
}

.buy-price {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx !important;
}

/* 操作栏 - 旧版样式保留但不使用 */
.detail-actions {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(20rpx);
  position: relative;
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.detail-actions::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.action-buttons {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
  min-width: 100rpx;
}

.action-item:active {
  transform: scale(0.95);
  background: rgba(147, 112, 219, 0.15);
}

.action-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
  transition: all 0.3s;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.action-icon.favorited {
  color: #ef4444;
  text-shadow: 0 0 20rpx rgba(239, 68, 68, 0.6);
}

.action-item:active .action-icon {
  transform: scale(1.15);
}

.action-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.buy-button {
  width: 100%;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 0 90rpx rgba(186, 85, 211, 0.25),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 15rpx rgba(255, 255, 255, 0.8);
  position: relative;
  overflow: hidden;
  animation: btnPulse 2s ease-in-out infinite;
  transition: all 0.3s;
}

.buy-button::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, #c8a2ff, #ba55d3, #c8a2ff);
  border-radius: 34rpx;
  z-index: -1;
  filter: blur(12rpx);
  opacity: 0.7;
}

.buy-button::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 0 90rpx rgba(186, 85, 211, 0.25),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 0 120rpx rgba(186, 85, 211, 0.35),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.buy-button:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.3),
    0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

/* 标题卡片 */
.title-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(20rpx);
  position: relative;
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.title-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.title-tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #c8a2ff;
  font-weight: 600;
}

.title-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #f8fafc;
  line-height: 1.4;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

.title-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #c8a2ff;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.15);
}

/* 通用信息卡片 */
.info-card, .delivery-card, .note-card, .seller-card, .notice-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(20rpx);
  position: relative;
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.info-card::before, .delivery-card::before, .note-card::before, .seller-card::before, .notice-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
}

.info-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.2);
  padding-bottom: 16rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #f8fafc;
  text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.info-item {
  text-align: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.08) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 12rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
}

/* 配送信息 */
.delivery-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.delivery-item {
  flex: 1;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.08) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.delivery-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 10rpx;
}

.delivery-value {
  font-size: 28rpx;
  color: #f8fafc;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.delivery-arrow {
  font-size: 36rpx;
  color: rgba(200, 162, 255, 0.5);
  flex-shrink: 0;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

/* 商品备注 */
.note-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.08) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  border-radius: 20rpx;
}

/* 卖家信息 */
.seller-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.seller-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  flex-shrink: 0;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2);
}

.seller-info {
  flex: 1;
}

.seller-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #f8fafc;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.seller-rating {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(200, 162, 255, 0.8);
}

.seller-action {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.9) 0%, rgba(5, 5, 15, 0.95) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #c8a2ff;
  font-weight: 600;
  text-align: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.15);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.seller-action::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(200, 162, 255, 0.15), transparent);
  transition: left 0.6s;
}

.seller-action:active::before {
  left: 100%;
}

.seller-action:active {
  transform: scale(0.95);
  box-shadow: 0 0 30rpx rgba(147, 112, 219, 0.3);
}

/* 购买须知 */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.08) 0%, rgba(186, 85, 211, 0.05) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.2);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.notice-dot {
  font-size: 32rpx;
  color: #c8a2ff;
  line-height: 1.2;
  flex-shrink: 0;
}

.notice-item text:last-child {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

/* 底部占位 */
.detail-bottom-placeholder {
  height: 80rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .detail-hero-section {
    height: 480rpx;
  }
  
  .price-number {
    font-size: 48rpx;
  }
  
  .info-grid {
    gap: 16rpx;
  }
  
  .info-item {
    padding: 20rpx;
  }
}

@media (min-width: 414px) {
  .detail-hero-section {
    height: 600rpx;
  }
  
  .price-number {
    font-size: 64rpx;
  }
  
  .info-grid {
    gap: 24rpx;
  }
  
  .info-item {
    padding: 28rpx;
  }
}
