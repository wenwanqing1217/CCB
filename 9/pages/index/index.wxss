@keyframes fire {
  0%, 100% { 
    transform: scale(1) rotate(-5deg);
  }
  50% { 
    transform: scale(1.15) rotate(5deg);
  }
}

.dorm-warm-icon {
  font-size: 28rpx;
  margin-left: 12rpx;
  filter: drop-shadow(0 0 6rpx rgba(236, 72, 153, 0.6));
}

.heat-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 2;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  box-shadow: 0 0 10rpx currentColor;
}

.legend-dot.hot {
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: rgba(139, 92, 246, 0.5);
}

.legend-dot.warm {
  background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
  color: rgba(236, 72, 153, 0.4);
}

.legend-dot.normal {
  background: linear-gradient(135deg, #64748b 0%, #475569 100%);
  color: rgba(100, 116, 139, 0.4);
}

.legend-item text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.hot-section {
  margin: 0 8rpx 32rpx;
  position: relative;
  z-index: 1;
}

.section-more {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
  transition: color 0.3s ease;
}

.scroll-box {
  width: 100%;
  white-space: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}

.scroll-box::-webkit-scrollbar {
  display: none;
}

.scroll-content {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 4rpx;
}

.box-card {
  display: inline-block;
  width: 260rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.box-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 15rpx rgba(200, 162, 255, 0.5);
  z-index: 2;
}

.box-card:active {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 0 40rpx rgba(147, 112, 219, 0.35),
              0 12rpx 40rpx rgba(0, 0, 0, 0.7);
  border-color: rgba(147, 112, 219, 0.6);
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 200rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(20, 20, 40, 0.95) 0%, rgba(10, 10, 25, 0.98) 100%);
  border-bottom: 2rpx solid rgba(147, 112, 219, 0.25);
}

.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.box-card:active .card-image {
  transform: scale(1.05);
}

.card-price {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(12rpx);
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.card-info {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-dorm {
  font-size: 24rpx;
  color: rgba(147, 112, 219, 0.7);
}

.card-sales {
  font-size: 24rpx;
  color: rgba(139, 92, 246, 0.8);
  font-weight: 500;
}

.community-section {
  margin: 0 8rpx 32rpx;
  position: relative;
  z-index: 1;
}

.community-feed {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feed-card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
