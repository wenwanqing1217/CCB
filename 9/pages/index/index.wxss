}

.feed-card-header {
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(147, 112, 219, 0.1);
}

.feed-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3);
  flex-shrink: 0;
}

.feed-user-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.feed-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.feed-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.feed-type-tag {
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.feed-type-tag.donation {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(22, 163, 74, 0.15) 100%);
  color: #4ade80;
  border: 1rpx solid rgba(34, 197, 94, 0.4);
}

.feed-type-tag.exchange {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(37, 99, 235, 0.15) 100%);
  color: #60a5fa;
  border: 1rpx solid rgba(59, 130, 246, 0.4);
}

.feed-type-tag.sale {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  color: #c8a2ff;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
}

.feed-card-body {
  display: flex;
  padding: 20rpx 20rpx 20rpx;
  gap: 20rpx;
}

.feed-content-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feed-action {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.feed-desc {
  font-size: 28rpx;
  color: #f8fafc;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.feed-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
  transition: transform 0.3s ease;
}

.feed-card:active .feed-image {
  transform: scale(1.05);
}

.rider-banner {
  margin: 0 8rpx 32rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.3s ease;
}

.rider-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(139, 92, 246, 0.35) 50%, transparent 100%);
}

.rider-banner::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.rider-content {
  flex: 1;
  position: relative;
  z-index: 2;
}

.rider-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.rider-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

.rider-stats {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  background: rgba(139, 92, 246, 0.15);
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  position: relative;
  z-index: 2;
}

.rider-num {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-variant-numeric: tabular-nums;
}

.rider-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* AI悬浮按钮 - 可拖�?*/
.ai-float-btn {
  position: fixed;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.85) 100%);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(139, 92, 246, 0.4);
  z-index: 100;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  touch-action: none;
}

.ai-float-btn.dragging {
  transition: none;
  transform: scale(1.1);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.6),
              0 0 40rpx rgba(139, 92, 246, 0.4);
}

.ai-float-btn:active {
  transform: scale(0.95);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.6);
  border-color: rgba(139, 92, 246, 0.6);
}

.ai-float-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-text {
  font-size: 40rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
}

.ai-float-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(255, 255, 255, 0.6), 0 0 30rpx rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10rpx);
  animation: badgePulse 2s ease-in-out infinite;
}

.ai-float-pulse {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.3);
  animation: pulse-ring 2.5s ease-out infinite;
}

.ai-float-pulse.delay {
  animation-delay: 1.25s;
}

@keyframes pulse-ring {
  0% {
    transform: scale(1);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.6);
    opacity: 0;
  }
}

.ai-float-tip {
  position: fixed;
  right: 156rpx;
  bottom: 220rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, rgba(26, 26, 46, 0.95) 0%, rgba(22, 33, 62, 0.85) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  z-index: 100;
  animation: fadeInLeft 0.5s ease-out;
}

@keyframes fadeInLeft {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.ai-float-tip text {
  font-size: 28rpx;
  color: #f8fafc;
  font-weight: 500;
}

.tip-close {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}/* 骨架屏样式 */
.skeleton {
  padding: 20rpx;
}

.skeleton-hero {
  margin-bottom: 32rpx;
}

.skeleton-brand {
  width: 120rpx;
  height: 40rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-slogan {
  width: 300rpx;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-stats {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.skeleton-stat {
  flex: 1;
  height: 60rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
