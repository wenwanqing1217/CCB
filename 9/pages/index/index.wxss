@keyframes livePulse {
  0%, 100% { 
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 0 20rpx rgba(200, 162, 255, 1), 0 0 30rpx rgba(240, 171, 252, 0.8);
  }
  50% { 
    opacity: 0.8;
    transform: scale(1.4);
    box-shadow: 0 0 25rpx rgba(200, 162, 255, 1), 0 0 40rpx rgba(240, 171, 252, 1);
  }
}

.live-badge text {
  font-size: 24rpx;
  color: #f8fafc;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(139, 92, 246, 0.6);
}

.section-desc {
  font-size: 28rpx;
  color: rgba(147, 112, 219, 0.6);
}

.dorm-heat-grid {
