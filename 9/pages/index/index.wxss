@keyframes sloganGlow {
  0%, 100% {
    text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.5);
  }
  50% {
    text-shadow: 0 0 25rpx rgba(147, 112, 219, 0.7);
  }
