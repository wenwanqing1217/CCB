.grab-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.5);
  border-radius: 28rpx;
  padding: 20rpx 40rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  z-index: 3;
  cursor: pointer;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    0 0 40rpx rgba(147, 112, 219, 0.4),
    0 0 60rpx rgba(147, 112, 219, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.grab-action::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.1) 100%);
  border-radius: 28rpx;
  z-index: -1;
}

.grab-action::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  animation: btnShine 3s ease-in-out infinite;
  z-index: -1;
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.grab-action:active {
  transform: scale(0.95);
  box-shadow: 
    0 12rpx 40rpx rgba(0, 0, 0, 0.6),
    0 0 50rpx rgba(147, 112, 219, 0.5),
    0 0 70rpx rgba(147, 112, 219, 0.3);
  border-color: rgba(147, 112, 219, 0.7);
}

.grab-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #c8a2ff;
  text-shadow: 
    0 0 15rpx rgba(147, 112, 219, 0.9),
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 45rpx rgba(186, 85, 211, 0.5);
  z-index: 1;
}

.grab-btn-arrow {
  font-size: 32rpx;
  color: #c8a2ff;
  text-shadow: 
    0 0 15rpx rgba(147, 112, 219, 0.9),
    0 0 30rpx rgba(147, 112, 219, 0.7),
    0 0 45rpx rgba(186, 85, 211, 0.5);
  z-index: 1;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin: 0 16rpx 12rpx;
  position: relative;
  z-index: 1;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .quick-actions {
    gap: 8rpx;
  }
  
  .action-icon {
    font-size: 40rpx;
  }
  
  .action-main-title {
    font-size: 24rpx;
  }
  
  .action-sub-title {
    font-size: 16rpx;
  }
}

@media (min-width: 414px) {
  .quick-actions {
    gap: 16rpx;
  }
  
  .action-icon {
    font-size: 52rpx;
  }
  
  .action-main-title {
    font-size: 30rpx;
  }
  
  .action-sub-title {
    font-size: 20rpx;
  }
}

