  align-items: center;
  gap: 12rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: 0.5rpx;
}

.live-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 16rpx;
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.5),
    0 0 10rpx rgba(147, 112, 219, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  text-shadow: 
    0 0 5rpx rgba(147, 112, 219, 0.6),
    0 0 10rpx rgba(147, 112, 219, 0.4);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  box-sizing: border-box;
}

.live-badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.05) 0%, rgba(186, 85, 211, 0.02) 100%);
  border-radius: 16rpx;
  z-index: -1;
}

.live-dot {
  width: 16rpx;
  height: 16rpx;
  background: linear-gradient(135deg, #c8a2ff 0%, #f0abfc 100%);
