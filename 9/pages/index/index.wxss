.dorm-heat-section {
  margin: 0 8rpx 32rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.dorm-heat-section::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 30%, rgba(147, 112, 219, 0.35) 0%, transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(186, 85, 211, 0.3) 0%, transparent 40%),
              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.25) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
  animation: heroGlow 8s ease-in-out infinite;
}

.dorm-heat-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(139, 92, 246, 0.3) 50%, transparent 100%);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title-wrap {
