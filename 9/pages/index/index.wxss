}

.skeleton-community {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.skeleton-feed-item {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 12rpx;
}

.skeleton-rider {
  width: 100%;
  height: 120rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

@keyframes loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 通用动画类 - 只保留实际使用的动画 */
.animate-fade-in {
  animation: fadeIn 0.5s ease-out;
}

.animate-slide-up {
  animation: slideUp 0.5s ease-out;
}

/* 动画定义 - 只保留实际使用的动画 */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 交互反馈 */
.interactive-card {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.interactive-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.3);
}

/* 按钮交互效果 */
.interactive-btn {
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.interactive-btn:active {
  transform: scale(0.95);
}

.interactive-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.interactive-btn:active::after {
  width: 300rpx;
  height: 300rpx;
}

/* 滚动视差效果 */
.parallax-bg {
  transform: translateZ(0);
  will-change: transform;
}

/* 加载动画 */
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(147, 112, 219, 0.3);
  border-top: 4rpx solid #c8a2ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 发光效果 */
.glow-effect {
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
              0 0 40rpx rgba(147, 112, 219, 0.3);
}

/* 毛玻璃效果 */
.glass-effect {
  background: rgba(26, 26, 46, 0.7);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 响应式动画延迟 */
.delay-100 {
  animation-delay: 0.1s;
}

.delay-200 {
  animation-delay: 0.2s;
}

.delay-300 {
  animation-delay: 0.3s;
}

.delay-400 {
  animation-delay: 0.4s;
}

.delay-500 {
  animation-delay: 0.5s;
}

