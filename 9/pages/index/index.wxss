/* 移除重复的页面样式，只保留container样式 */


/* 搜索栏 */
.search-bar {
  padding: 0 8rpx 8rpx;
}

.search-input {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.2),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  animation: heroBorderGlow 3s ease-in-out infinite;
}

.search-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.search-input input {
  flex: 1;
  font-size: 24rpx;
  color: #f8fafc;
  background: transparent;
  border: none;
  outline: none;
  height: 40rpx;
  line-height: 40rpx;
}

.search-input input::placeholder {
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

.search-btn {
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.8) 0%, rgba(5, 5, 15, 0.9) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.4);
  box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.2);
  transition: all 0.3s ease;
}

.search-btn-text {
  font-size: 24rpx;
  font-weight: 800;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6),
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 40rpx rgba(186, 85, 211, 0.3);
  animation: brandGlow 3s ease-in-out infinite;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.4);
}

.card {
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  border-radius: 24rpx;
  padding: 20rpx;
  margin: 16rpx;
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.2),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.5) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.5) 80%,
    transparent 100%);
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tag {
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.95) 0%, rgba(5, 5, 15, 0.98) 100%);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #c8a2ff;
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.5),
    0 0 20rpx rgba(147, 112, 219, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  text-shadow: 
    0 0 10rpx rgba(147, 112, 219, 0.8),
    0 0 20rpx rgba(147, 112, 219, 0.6);
  backdrop-filter: blur(20rpx);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.tag::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 999rpx;
  z-index: -1;
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  margin: 16rpx;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.btn-primary {
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(200, 162, 255, 0.5);
  box-shadow: 0 0 25rpx rgba(147, 112, 219, 0.5);
  padding: 16rpx 20rpx;
}

.btn-primary::after {
  border: none;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.container {
  min-height: 100vh;
  background: #020208;
  padding-bottom: 160rpx;
  position: relative;
  overflow-x: hidden;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.1) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

@keyframes backgroundMove {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

.hero-section {
  position: relative;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  overflow: hidden;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  border-radius: 24rpx;
  margin: 8rpx 4rpx 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

@keyframes heroBorderGlow {
  0%, 100% {
    box-shadow: 
      0 4rpx 30rpx rgba(147, 112, 219, 0.2),
      0 0 60rpx rgba(147, 112, 219, 0.15),
      0 0 100rpx rgba(147, 112, 219, 0.1);
    border-color: rgba(147, 112, 219, 0.5);
  }
  50% {
    box-shadow: 
      0 4rpx 40rpx rgba(147, 112, 219, 0.3),
      0 0 80rpx rgba(147, 112, 219, 0.25),
      0 0 120rpx rgba(147, 112, 219, 0.2);
    border-color: rgba(147, 112, 219, 0.8);
  }
}

.hero-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-sub-slogan {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
  letter-spacing: 0.5rpx;
  text-shadow: 0 0 10rpx rgba(200, 162, 255, 0.3);
  animation: fadeInDown 0.8s ease-out 0.6s both;
  position: relative;
  z-index: 2;
}

/* 底部发光边框�?*/
.hero-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(147, 112, 219, 0.6) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(147, 112, 219, 0.6) 80%,
    transparent 100%);
  box-shadow: 0 0 18rpx rgba(147, 112, 219, 0.5);
  z-index: 2;
}

/* 背景光晕效果 */
.hero-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 30%, rgba(147, 112, 219, 0.25) 0%, transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(186, 85, 211, 0.2) 0%, transparent 40%),
              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.15) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
  animation: heroGlow 8s ease-in-out infinite;
}

@keyframes heroGlow {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}

.hero-brand {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 2;
  justify-content: center;
}

.brand-name {
  font-size: 56rpx;
  font-weight: 900;
  color: #c8a2ff;
  letter-spacing: 3rpx;
  text-shadow: 0 0 8rpx rgba(147, 112, 219, 0.5),
               0 0 20rpx rgba(147, 112, 219, 0.3),
               0 0 30rpx rgba(147, 112, 219, 0.2);
  animation: blingBling 2s ease-in-out infinite;
}

@keyframes blingBling {
  0%, 100% {
    text-shadow: 0 0 8rpx rgba(147, 112, 219, 0.5),
                 0 0 20rpx rgba(147, 112, 219, 0.3),
                 0 0 30rpx rgba(147, 112, 219, 0.2);
    opacity: 1;
  }
  50% {
    text-shadow: 0 0 15rpx rgba(147, 112, 219, 0.8),
                 0 0 30rpx rgba(147, 112, 219, 0.6),
                 0 0 50rpx rgba(147, 112, 219, 0.4),
                 0 0 70rpx rgba(147, 112, 219, 0.2);
    opacity: 0.9;
  }
}

.brand-sub {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 1rpx;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
}

.hero-slogan {
  font-size: 24rpx;
  color: #ffffff;
  margin-bottom: 8rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.7),
               0 0 20rpx rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 2;
  text-align: center;
  display: block;
  line-height: 1.4;
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 0;
  background: linear-gradient(135deg, rgba(12, 12, 28, 0.98) 0%, rgba(5, 5, 15, 0.99) 50%, rgba(12, 12, 28, 0.98) 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

.hero-stats::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.5) 20%,
    rgba(186, 85, 211, 0.5) 50%,
    rgba(200, 162, 255, 0.5) 80%,
    transparent 100%);
}

/* 积分显示 */
.coins-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.1) 0%, rgba(253, 224, 71, 0.05) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(251, 191, 36, 0.3);
}

.coins-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.coins-icon {
  font-size: 36rpx;
}

.coins-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #fbbf24;
  text-shadow: 0 0 10rpx rgba(251, 191, 36, 0.6);
}

.coins-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.coins-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(251, 191, 36, 0.4);
}

.coins-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.stat-item {
  text-align: center;
  flex: 1;
  position: relative;
}

.stat-item::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60%;
  background: linear-gradient(180deg, transparent, rgba(147, 112, 219, 0.2), transparent);
}

.stat-item:last-child::after {
  display: none;
}

.stat-number {
  font-size: 38rpx;
  font-weight: 900;
  color: #c8a2ff;
  display: block;
  margin-bottom: 8rpx;
  font-variant-numeric: tabular-numeric;
  text-shadow: 0 0 8rpx rgba(147, 112, 219, 0.7),
               0 0 16rpx rgba(147, 112, 219, 0.5);
  background: linear-gradient(135deg, #c8a2ff 0%, #f0abfc 50%, #e879f9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  font-weight: 500;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.3);
}

.rider-grab-section {
  margin: 0 8rpx 16rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, 
    rgba(12, 12, 28, 0.98) 0%, 
    rgba(5, 5, 15, 0.99) 50%, 
    rgba(12, 12, 28, 0.98) 100%
  );
  backdrop-filter: blur(10rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(147, 112, 219, 0.15),
              0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.3s ease;
}

.grab-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.grab-title-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.grab-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8rpx 0;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.1) 0%, rgba(186, 85, 211, 0.05) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
}

@keyframes grabBodyGlow {
  0%, 100% {
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.3),
      0 0 60rpx rgba(147, 112, 219, 0.15),
      0 4rpx 16rpx rgba(0, 0, 0, 0.3);
    border-color: rgba(147, 112, 219, 0.5);
  }
  50% {
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.4),
      0 0 80rpx rgba(147, 112, 219, 0.25),
      0 4rpx 16rpx rgba(0, 0, 0, 0.3);
    border-color: rgba(147, 112, 219, 0.8);
  }
}

.grab-slogan {
  flex: 1;
}

.grab-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.2) 0%, rgba(186, 85, 211, 0.15) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(147, 112, 219, 0.2);
}

.grab-icon .icon {
  font-size: 48rpx;
  animation: iconFloat 2s ease-in-out infinite;
}

@keyframes iconFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-4rpx) rotate(2deg); }
  50% { transform: translateY(0) rotate(0deg); }
  75% { transform: translateY(4rpx) rotate(-2deg); }
}

.rider-grab-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(200, 162, 255, 0.8) 20%,
    rgba(186, 85, 211, 0.8) 50%,
    rgba(200, 162, 255, 0.8) 80%,
    transparent 100%);
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  animation: headerGlow 3s ease-in-out infinite;
  z-index: 3;
}

@keyframes headerGlow {
  0%, 100% {
    opacity: 0.7;
    box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.6);
  }
  50% {
    opacity: 1;
    box-shadow: 0 0 30rpx rgba(200, 162, 255, 0.9),
                0 0 40rpx rgba(186, 85, 211, 0.7);
  }
}

.rider-grab-section::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 30%, rgba(147, 112, 219, 0.25) 0%, transparent 40%),
              radial-gradient(circle at 80% 70%, rgba(186, 85, 211, 0.2) 0%, transparent 40%),
              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.15) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
  animation: heroGlow 8s ease-in-out infinite;
}

@keyframes backgroundPulse {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.6;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.1);
    opacity: 0.8;
  }
}

.rider-grab-section:active {
  transform: translateY(-6rpx) scale(1.02);
  box-shadow: 
    0 0 60rpx rgba(147, 112, 219, 0.4),
    0 16rpx 48rpx rgba(0, 0, 0, 0.9),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.grab-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 3;
}

.grab-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.grab-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  border: none;
  background: linear-gradient(135deg, #7c3aed 0%, #9370db 30%, #ba55d3 70%, #c8a2ff 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(147, 112, 219, 0.5),
              0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  text-shadow: 0 0 5rpx rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.7),
      0 0 60rpx rgba(147, 112, 219, 0.4),
      0 0 90rpx rgba(186, 85, 211, 0.25),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 40rpx rgba(147, 112, 219, 0.9),
      0 0 80rpx rgba(147, 112, 219, 0.5),
      0 0 120rpx rgba(186, 85, 211, 0.35),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

@keyframes badgePulse {
  0%, 100% {
    box-shadow: 0 4rpx 12rpx rgba(147, 112, 219, 0.4);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 6rpx 16rpx rgba(147, 112, 219, 0.6);
    transform: scale(1.03);
  }
}

.grab-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.3);
  letter-spacing: 2rpx;
}

.grab-count {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.15) 0%, rgba(186, 85, 211, 0.1) 100%);
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(147, 112, 219, 0.3);
  box-shadow: 0 4rpx 12rpx rgba(147, 112, 219, 0.2),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

@keyframes grabCountPulse {
  0%, 100% {
    box-shadow: 0 0 15rpx rgba(147, 112, 219, 0.3),
                inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 0 20rpx rgba(147, 112, 219, 0.5),
                inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
    transform: scale(1.01);
  }
}

.count-num {
  font-size: 40rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 50%, #ba55d3 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 5rpx rgba(147, 112, 219, 0.5);
}

.count-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(147, 112, 219, 0.4);
}

.slogan-text {
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  text-align: center;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #c8a2ff 50%, #ba55d3 100%);
