/* CBB校园盲盒 - 紫色霓虹灯风格 */
/* 强烈的霓虹灯发光效果，神秘感和科技感 */

/* ========== CSS变量 ========== */
page {
  /* 颜色变量 */
  --primary-color: #7c3aed;
  --primary-light: #c8a2ff;
  --primary-dark: #6d28d9;
  --secondary-color: #ba55d3;
  --secondary-light: #d8b4fe;
  --background-dark: #020208;
  --background-card: rgba(12, 12, 28, 0.95);
  --text-primary: #ffffff;
  --text-secondary: rgba(255, 255, 255, 0.7);
  --text-tertiary: rgba(255, 255, 255, 0.5);
  --text-muted: rgba(255, 255, 255, 0.4);
  
  /* 字体变量 */
  --font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 40rpx;
  
  /* 间距变量 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 40rpx;
  
  /* 圆角变量 */
  --border-radius-sm: 12rpx;
  --border-radius-md: 20rpx;
  --border-radius-lg: 24rpx;
  --border-radius-xl: 32rpx;
  --border-radius-full: 999rpx;
  
  /* 阴影变量 */
  --shadow-sm: 0 0 15rpx rgba(147, 112, 219, 0.1), 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 0 25rpx rgba(147, 112, 219, 0.2), 0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  --shadow-lg: 0 0 40rpx rgba(147, 112, 219, 0.3), 0 12rpx 48rpx rgba(0, 0, 0, 0.8);
  
  /* 动画变量 */
  --animation-duration: 0.3s;
  --animation-easing: cubic-bezier(0.4, 0, 0.2, 1);
}

/* ========== 基础重置 ========== */
page {
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  line-height: 1.6;
  color: var(--text-primary);
  background-color: var(--background-dark);
  -webkit-font-smoothing: antialiased;
}

/* ========== 布局工具类 ========== */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 20%, rgba(147, 112, 219, 0.15) 0%, transparent 50%),
              radial-gradient(circle at 80% 80%, rgba(123, 104, 238, 0.12) 0%, transparent 50%),
              radial-gradient(circle at 50% 30%, rgba(186, 85, 211, 0.08) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

.container::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 30% 25%, rgba(200, 162, 255, 0.05) 0%, transparent 35%),
    radial-gradient(circle at 70% 75%, rgba(138, 43, 226, 0.04) 0%, transparent 35%);
  animation: neonPulse 3s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes neonPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.flex {
  display: flex;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ========== 间距工具类 ========== */
.m-0 { margin: 0; }
.m-xs { margin: var(--spacing-xs); }
.m-sm { margin: var(--spacing-sm); }
.m-md { margin: var(--spacing-md); }

.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }

.p-0 { padding: 0; }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }

/* ========== 文字工具类 ========== */
.text-xs { font-size: var(--font-size-xs); }
.text-sm { font-size: var(--font-size-sm); }
.text-base { font-size: var(--font-size-base); }
.text-lg { font-size: var(--font-size-lg); }
.text-xl { font-size: var(--font-size-xl); }

.text-white { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-muted { color: var(--text-muted); }

.text-primary { color: var(--primary-light); }
.text-pink { color: var(--secondary-light); }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

/* ========== 组件样式 ========== */

/* 卡片 - 强烈紫色霓虹灯风格 */
.card {
  position: relative;
  background: linear-gradient(135deg, var(--background-card) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  border: 2rpx solid transparent;
  background-clip: padding-box;
  overflow: hidden;
  backdrop-filter: blur(20rpx);
  box-shadow: var(--shadow-md);
  animation: cardGlow 2.5s ease-in-out infinite;
}

.card::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, 
    rgba(186, 85, 211, 0.9) 0%,
    rgba(147, 112, 219, 0.8) 50%,
    rgba(186, 85, 211, 0.9) 100%);
  border-radius: calc(var(--border-radius-md) + 2rpx);
  z-index: -1;
  animation: borderGlow 1.8s ease-in-out infinite;
}

.card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    var(--primary-light) 20%,
    var(--secondary-color) 50%,
    var(--primary-light) 80%,
    transparent 100%);
  box-shadow: 0 0 25rpx rgba(200, 162, 255, 0.9),
              0 0 50rpx rgba(186, 85, 211, 0.5);
  animation: topGlow 2s ease-in-out infinite;
}

@keyframes cardGlow {
  0%, 100% { 
    box-shadow: var(--shadow-md);
  }
  50% { 
    box-shadow: 
      0 0 35rpx rgba(147, 112, 219, 0.3),
      0 0 70rpx rgba(147, 112, 219, 0.15),
      0 8rpx 32rpx rgba(0, 0, 0, 0.6),
      inset 0 1rpx 0 var(--secondary-light);
  }
}

@keyframes borderGlow {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

@keyframes topGlow {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}

.card-hover {
  background: rgba(30, 30, 55, 0.9);
}

/* 按钮 - 强烈紫色霓虹灯主按钮 */
.btn-primary {
  position: relative;
  background: linear-gradient(135deg, var(--primary-color) 0%, #9370db 30%, var(--secondary-color) 70%, var(--primary-light) 100%);
  color: var(--text-primary);
  border-radius: var(--border-radius-full);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-size-lg);
  font-weight: 700;
  text-align: center;
  border: none;
  box-shadow: 
    0 0 25rpx rgba(147, 112, 219, 0.7),
    0 0 50rpx rgba(147, 112, 219, 0.4),
    0 0 75rpx var(--secondary-color),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  overflow: hidden;
  animation: btnPulse 1.8s ease-in-out infinite;
  text-shadow: 0 0 15rpx var(--secondary-light);
  transition: transform var(--animation-duration) var(--animation-easing);
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, var(--primary-light), var(--secondary-color), var(--primary-light));
  border-radius: calc(var(--border-radius-full) + 2rpx);
  z-index: -1;
  filter: blur(10rpx);
  opacity: 0.8;
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { 
    box-shadow: 
      0 0 25rpx rgba(147, 112, 219, 0.7),
      0 0 50rpx rgba(147, 112, 219, 0.4),
      0 0 75rpx var(--secondary-color),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
  50% { 
    box-shadow: 
      0 0 35rpx rgba(147, 112, 219, 0.9),
      0 0 70rpx rgba(147, 112, 219, 0.5),
      0 0 100rpx var(--secondary-color),
      0 8rpx 24rpx rgba(0, 0, 0, 0.5);
  }
}

@keyframes btnShine {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 
    0 0 18rpx rgba(147, 112, 219, 0.6),
    0 0 36rpx rgba(147, 112, 219, 0.3),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

/* 按钮 - 次要按钮 */
.btn-secondary {
  position: relative;
  background: rgba(8, 8, 20, 0.95);
  color: var(--primary-light);
  border: 2rpx solid rgba(147, 112, 219, 0.6);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-sm) var(--spacing-xl);
  font-size: var(--font-size-base);
  font-weight: 600;
  text-align: center;
  backdrop-filter: blur(12rpx);
  box-shadow: 
    0 0 18rpx rgba(147, 112, 219, 0.4),
    0 0 36rpx rgba(147, 112, 219, 0.2),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  transition: all var(--animation-duration) var(--animation-easing);
}

.btn-secondary:active {
  background: rgba(147, 112, 219, 0.18);
  border-color: var(--secondary-color);
  color: var(--text-primary);
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.6),
    0 0 60rpx rgba(147, 112, 219, 0.3),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

/* 按钮 - 文字按钮 */
.btn-text {
  color: var(--primary-light);
  font-size: 26rpx;
  font-weight: 500;
  background: transparent;
  border: none;
  padding: 12rpx 16rpx;
  text-shadow: 0 0 18rpx var(--primary-light),
               0 0 36rpx var(--primary-light);
  position: relative;
  transition: all var(--animation-duration) var(--animation-easing);
}

.btn-text::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.7);
  transition: all var(--animation-duration) var(--animation-easing);
  transform: translateX(-50%);
}

.btn-text:active::after {
  width: 100%;
}

/* 按钮 - 禁用状态 */
.btn-disabled {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.3);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-sm) var(--spacing-xl);
  font-size: var(--font-size-base);
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  cursor: not-allowed;
}

/* 输入框 - 霓虹灯效果 */
.input {
  position: relative;
  width: 100%;
  background: rgba(5, 5, 15, 0.9);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: var(--border-radius-sm);
  padding: 22rpx 24rpx;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
  transition: all var(--animation-duration) var(--animation-easing);
  box-shadow: 
    0 0 12rpx rgba(147, 112, 219, 0.15),
    inset 0 0 24rpx rgba(147, 112, 219, 0.08);
}

.input::placeholder {
  color: var(--text-muted);
}

.input:focus {
  border-color: var(--secondary-color);
  background: rgba(10, 10, 25, 0.95);
  box-shadow: 
    0 0 24rpx rgba(147, 112, 219, 0.5),
    0 0 48rpx rgba(147, 112, 219, 0.25),
    0 0 0 4rpx rgba(147, 112, 219, 0.2),
    inset 0 0 36rpx rgba(147, 112, 219, 0.12);
  outline: none;
}

/* 文本域 - 霓虹灯效果 */
.textarea {
  position: relative;
  width: 100%;
  min-height: 200rpx;
  background: rgba(5, 5, 15, 0.9);
  border: 2rpx solid rgba(147, 112, 219, 0.4);
  border-radius: var(--border-radius-sm);
  padding: 22rpx 24rpx;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
  transition: all var(--animation-duration) var(--animation-easing);
  box-shadow: 
    0 0 12rpx rgba(147, 112, 219, 0.15),
    inset 0 0 24rpx rgba(147, 112, 219, 0.08);
}

.textarea::placeholder {
  color: var(--text-muted);
}

.textarea:focus {
  border-color: var(--secondary-color);
  background: rgba(10, 10, 25, 0.95);
  box-shadow: 
    0 0 24rpx rgba(147, 112, 219, 0.5),
    0 0 48rpx rgba(147, 112, 219, 0.25),
    0 0 0 4rpx rgba(147, 112, 219, 0.2),
    inset 0 0 36rpx rgba(147, 112, 219, 0.12);
  outline: none;
}

/* Tab 组件 - 霓虹灯风格 */
.tab-container {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
}

.tab-item {
  flex: 1;
  padding: 22rpx 0;
  background: rgba(5, 5, 15, 0.9);
  border-radius: 18rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  border: 2rpx solid rgba(147, 112, 219, 0.3);
  backdrop-filter: blur(10rpx);
  transition: all var(--animation-duration) var(--animation-easing);
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 12rpx rgba(147, 112, 219, 0.08);
}

.tab-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--primary-light), transparent);
  opacity: 0;
  transition: opacity var(--animation-duration) var(--animation-easing);
  box-shadow: 0 0 18rpx var(--primary-light);
}

.tab-item.active {
  background: linear-gradient(135deg, rgba(147, 112, 219, 0.28) 0%, rgba(186, 85, 211, 0.2) 100%);
  color: var(--text-primary);
  border-color: var(--secondary-color);
  box-shadow: 
    0 0 24rpx rgba(147, 112, 219, 0.5),
    0 0 48rpx rgba(147, 112, 219, 0.25),
    0 4rpx 16rpx rgba(0, 0, 0, 0.35);
  font-weight: 600;
}

.tab-item.active::before {
  opacity: 1;
}

/* 标签 - 霓虹灯风格 */
.tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  background: rgba(147, 112, 219, 0.22);
  border-radius: var(--border-radius-sm);
  font-size: 22rpx;
  color: var(--primary-light);
  border: 1rpx solid rgba(147, 112, 219, 0.6);
  box-shadow: 0 0 14rpx rgba(147, 112, 219, 0.35);
  text-shadow: 0 0 10rpx var(--primary-light);
}

.tag-pink {
  background: rgba(186, 85, 211, 0.22);
  color: var(--secondary-light);
  border-color: var(--secondary-color);
  box-shadow: 0 0 14rpx var(--secondary-color);
  text-shadow: 0 0 10rpx var(--secondary-light);
}

/* 分割线 - 霓虹灯效果 */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    var(--primary-light) 20%,
    var(--secondary-color) 50%,
    var(--primary-light) 80%,
    transparent 100%);
  margin: var(--spacing-md) 0;
  box-shadow: 0 0 18rpx var(--primary-light),
              0 0 36rpx var(--primary-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-sm);
  opacity: 0.65;
  filter: drop-shadow(0 0 24rpx var(--primary-light))
          drop-shadow(0 0 48rpx var(--primary-light));
  animation: iconGlow 1.8s ease-in-out infinite;
}

@keyframes iconGlow {
  0%, 100% { 
    filter: drop-shadow(0 0 24rpx var(--primary-light))
            drop-shadow(0 0 48rpx var(--primary-light));
  }
  50% { 
    filter: drop-shadow(0 0 36rpx var(--primary-light))
            drop-shadow(0 0 72rpx var(--primary-light));
  }
}

.empty-title {
  font-size: var(--font-size-base);
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 8rpx;
  text-shadow: 0 0 12rpx var(--primary-light);
}

.empty-desc {
  font-size: var(--font-size-sm);
  color: var(--text-tertiary);
}

/* 加载状态 - 强烈霓虹灯旋转 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.08);
  border-top: 3rpx solid var(--primary-light);
  border-right: 3rpx solid var(--secondary-color);
  border-bottom: 3rpx solid #9370db;
  border-left: 3rpx solid var(--secondary-light);
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
  box-shadow: 
    0 0 24rpx var(--primary-light),
    0 0 48rpx var(--primary-light),
    0 0 72rpx var(--secondary-color);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* 平滑滚动 */
page {
  scroll-behavior: smooth;
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 底部导航栏文字发光效果 */
.tab-bar-item {
  font-weight: 600 !important;
  letter-spacing: 1rpx !important;
  transition: all var(--animation-duration) var(--animation-easing);
}

.tab-bar-item.active {
  font-weight: 800 !important;
  text-shadow: 
    0 0 10rpx var(--primary-light),
    0 0 20rpx var(--primary-light),
    0 0 30rpx var(--primary-light) !important;
  transform: translateY(-2rpx);
}

/* ========== 无障碍支持 ========== */
/* 文本对比度优化 */
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* 焦点样式 */
button:focus,
input:focus,
textarea:focus,
select:focus,
a:focus {
  outline: 2rpx solid var(--primary-light);
  outline-offset: 4rpx;
  box-shadow: 0 0 20rpx rgba(200, 162, 255, 0.5);
}

/* 按钮焦点样式 */
.btn-primary:focus {
  outline: 2rpx solid var(--primary-light);
  outline-offset: 4rpx;
  box-shadow: 
    0 0 35rpx rgba(147, 112, 219, 0.9),
    0 0 70rpx rgba(147, 112, 219, 0.5),
    0 0 100rpx var(--secondary-color),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5),
    0 0 0 4rpx var(--primary-light);
}

.btn-secondary:focus {
  outline: 2rpx solid var(--primary-light);
  outline-offset: 4rpx;
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.6),
    0 0 60rpx rgba(147, 112, 219, 0.3),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4),
    0 0 0 4rpx var(--primary-light);
}

/* 输入框焦点样式 */
.input:focus,
.textarea:focus {
  outline: 2rpx solid var(--primary-light);
  outline-offset: 4rpx;
  box-shadow: 
    0 0 24rpx rgba(147, 112, 219, 0.5),
    0 0 48rpx rgba(147, 112, 219, 0.25),
    0 0 0 4rpx rgba(147, 112, 219, 0.2),
    inset 0 0 36rpx rgba(147, 112, 219, 0.12);
}

/* 卡片焦点样式 */
.card:focus {
  outline: 2rpx solid var(--primary-light);
  outline-offset: 4rpx;
  box-shadow: 
    0 0 35rpx rgba(147, 112, 219, 0.3),
    0 8rpx 32rpx rgba(0, 0, 0, 0.6),
    0 0 0 4rpx var(--primary-light);
}

/* 标签焦点样式 */
.tag:focus {
  outline: 2rpx solid var(--primary-light);
  outline-offset: 4rpx;
  box-shadow: 0 0 20rpx var(--primary-light), 0 0 0 4rpx var(--primary-light);
}

/* 无障碍文本 */
.accessible-text {
  color: var(--text-primary);
  font-size: var(--font-size-base);
  line-height: 1.6;
}

/* 高对比度模式支持 */
@media (prefers-contrast: high) {
  .card {
    border: 2rpx solid var(--primary-light);
  }
  
  .btn-primary {
    border: 2rpx solid var(--primary-light);
  }
  
  .input,
  .textarea {
    border: 2rpx solid var(--primary-light);
  }
}

/* 减少动画模式支持 */
@media (prefers-reduced-motion: reduce) {
  button,
  input,
  textarea,
  select,
  a,
  .card,
  .btn-primary,
  .btn-secondary,
  .tag,
  .tab-item {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* 键盘导航优化 */
button,
input,
textarea,
select,
a {
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}

/* 确保所有可交互元素都有适当的tabindex */
button,
input,
textarea,
select,
a {
  tabindex: 0;
}

/* 禁用元素的样式 */
[disabled] {
  opacity: 0.6;
  cursor: not-allowed;
  pointer-events: none;
}

/* 页面切换动画 */
.page-enter {
  animation: pageEnter 0.5s ease-out;
}

.page-leave {
  animation: pageLeave 0.3s ease-in;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pageLeave {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(-20rpx);
  }
}

/* 元素悬停效果 */
.hover-lift {
  transition: all var(--animation-duration) var(--animation-easing);
}

.hover-lift:hover {
  transform: translateY(-4rpx);
  box-shadow: 
    0 0 35rpx rgba(147, 112, 219, 0.3),
    0 8rpx 32rpx rgba(0, 0, 0, 0.6);
}

/* 卡片悬停效果 */
.card-hover {
  background: rgba(30, 30, 55, 0.9);
  transform: translateY(-4rpx);
  box-shadow: 
    0 0 35rpx rgba(147, 112, 219, 0.3),
    0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  transition: all var(--animation-duration) var(--animation-easing);
}

/* 按钮悬停效果 */
.btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: 
    0 0 35rpx rgba(147, 112, 219, 0.9),
    0 0 70rpx rgba(147, 112, 219, 0.5),
    0 0 100rpx var(--secondary-color),
    0 8rpx 24rpx rgba(0, 0, 0, 0.5);
}

.btn-secondary:hover {
  background: rgba(147, 112, 219, 0.18);
  border-color: var(--secondary-color);
  color: var(--text-primary);
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.6),
    0 0 60rpx rgba(147, 112, 219, 0.3),
    0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  transform: translateY(-2rpx);
}

/* 输入框焦点动画 */
.input:focus {
  border-color: var(--secondary-color);
  background: rgba(10, 10, 25, 0.95);
  box-shadow: 
    0 0 24rpx rgba(147, 112, 219, 0.5),
    0 0 48rpx rgba(147, 112, 219, 0.25),
    0 0 0 4rpx rgba(147, 112, 219, 0.2),
    inset 0 0 36rpx rgba(147, 112, 219, 0.12);
  outline: none;
  transform: scale(1.02);
}

/* 文本域焦点动画 */
.textarea:focus {
  border-color: var(--secondary-color);
  background: rgba(10, 10, 25, 0.95);
  box-shadow: 
    0 0 24rpx rgba(147, 112, 219, 0.5),
    0 0 48rpx rgba(147, 112, 219, 0.25),
    0 0 0 4rpx rgba(147, 112, 219, 0.2),
    inset 0 0 36rpx rgba(147, 112, 219, 0.12);
  outline: none;
  transform: scale(1.02);
}

/* 标签悬停效果 */
.tag:hover {
  background: rgba(147, 112, 219, 0.35);
  box-shadow: 0 0 20rpx var(--primary-light);
  transform: translateY(-2rpx);
  transition: all var(--animation-duration) var(--animation-easing);
}

.tag-pink:hover {
  background: rgba(186, 85, 211, 0.35);
  box-shadow: 0 0 20rpx var(--secondary-color);
  transform: translateY(-2rpx);
  transition: all var(--animation-duration) var(--animation-easing);
}

/* 加载动画增强 */
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.08);
  border-top: 3rpx solid var(--primary-light);
  border-right: 3rpx solid var(--secondary-color);
  border-bottom: 3rpx solid #9370db;
  border-left: 3rpx solid var(--secondary-light);
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
  box-shadow: 
    0 0 24rpx var(--primary-light),
    0 0 48rpx var(--primary-light),
    0 0 72rpx var(--secondary-color);
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 脉冲动画 */
.pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.8;
  }
}

/* 呼吸动画 */
.breath {
  animation: breath 3s ease-in-out infinite;
}

@keyframes breath {
  0%, 100% {
    box-shadow: 0 0 25rpx var(--primary-light);
  }
  50% {
    box-shadow: 0 0 40rpx var(--primary-light), 0 0 60rpx var(--secondary-color);
  }
}

/* 渐变背景动画 */
.gradient-bg {
  background: linear-gradient(-45deg, var(--primary-color), var(--secondary-color), var(--primary-color), var(--secondary-color));
  background-size: 400% 400%;
  animation: gradient 15s ease infinite;
}

@keyframes gradient {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

/* Toast 弹窗 - 紫色霓虹灯风格 */
.toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.4);
}

.toast-container {
  position: relative;
  background: linear-gradient(135deg, var(--background-card) 0%, rgba(5, 5, 15, 0.98) 100%);
  border-radius: var(--border-radius-md);
  padding: 32rpx 48rpx;
  min-width: 240rpx;
  max-width: 560rpx;
  text-align: center;
  border: 2rpx solid rgba(147, 112, 219, 0.6);
  box-shadow: 
    0 0 30rpx rgba(147, 112, 219, 0.4),
    0 0 60rpx rgba(147, 112, 219, 0.25),
    0 8rpx 32rpx rgba(0, 0, 0, 0.6),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  animation: toastGlow 1.8s ease-in-out infinite;
}

.toast-container::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, 
    rgba(186, 85, 211, 0.9) 0%,
    rgba(147, 112, 219, 0.8) 50%,
    rgba(186, 85, 211, 0.9) 100%);
  border-radius: calc(var(--border-radius-md) + 2rpx);
  z-index: -1;
  opacity: 0.8;
  animation: toastBorderGlow 2s ease-in-out infinite;
}

.toast-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    var(--primary-light) 20%,
    var(--secondary-color) 50%,
    var(--primary-light) 80%,
    transparent 100%);
  box-shadow: 0 0 25rpx rgba(200, 162, 255, 0.9),
              0 0 50rpx rgba(186, 85, 211, 0.5);
  animation: toastTopGlow 2s ease-in-out infinite;
}

.toast-text {
  font-size: var(--font-size-base);
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.5;
  text-shadow: 
    0 0 12rpx rgba(216, 180, 254, 0.8),
    0 0 24rpx rgba(147, 112, 219, 0.5);
}

.toast-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
  filter: drop-shadow(0 0 20rpx rgba(147, 112, 219, 0.8))
          drop-shadow(0 0 40rpx rgba(147, 112, 219, 0.4));
  animation: toastIconGlow 2s ease-in-out infinite;
}

@keyframes toastGlow {
  0%, 100% { 
    box-shadow: 
      0 0 30rpx rgba(147, 112, 219, 0.4),
      0 0 60rpx rgba(147, 112, 219, 0.25),
      0 8rpx 32rpx rgba(0, 0, 0, 0.6),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  }
  50% { 
    box-shadow: 
      0 0 45rpx rgba(147, 112, 219, 0.6),
      0 0 90rpx rgba(147, 112, 219, 0.35),
      0 8rpx 32rpx rgba(0, 0, 0, 0.6),
      inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  }
}

@keyframes toastBorderGlow {
  0%, 100% { opacity: 0.7; }
  50% { opacity: 1; }
}

@keyframes toastTopGlow {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 1; }
}

@keyframes toastIconGlow {
  0%, 100% { 
    filter: drop-shadow(0 0 20rpx rgba(147, 112, 219, 0.8))
            drop-shadow(0 0 40rpx rgba(147, 112, 219, 0.4));
  }
  50% { 
    filter: drop-shadow(0 0 30rpx rgba(147, 112, 219, 1))
            drop-shadow(0 0 60rpx rgba(147, 112, 219, 0.6));
  }
}
