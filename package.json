{
  "name": "campus-blindbox",
  "version": "2.0.0",
  "description": "校园盲盒即时配送平台",
  "scripts": {
    "lint": "eslint cloudfunctions pages utils components --ext .js",
    "lint:fix": "eslint cloudfunctions pages utils components --ext .js --fix",
    "format": "prettier --write \"cloudfunctions/**/*.js\" \"pages/**/*.js\" \"utils/**/*.js\" \"components/**/*.js\"",
    "format:check": "prettier --check \"cloudfunctions/**/*.js\" \"pages/**/*.js\" \"utils/**/*.js\" \"components/**/*.js\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
